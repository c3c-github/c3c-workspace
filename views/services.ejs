<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestão de Serviços - C3C Workspace</title>
    
    <!-- Tailwind & Lucide -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { 'c3c-blue': '#2978FF', 'c3c-dark': '#1E293B' },
                    backgroundImage: { 'c3c-gradient': 'linear-gradient(135deg, #2978FF 0%, #1E40AF 100%)' },
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .input-modern { @apply bg-white border border-gray-300 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-100/50 focus:border-c3c-blue outline-none transition-all shadow-sm; }
        .modal-tab-active { @apply border-b-4 border-c3c-blue text-c3c-blue; }
        .modal-tab-inactive { @apply border-b-4 border-transparent text-gray-400 hover:text-gray-600; }
        .input-inline { @apply w-full bg-transparent border-none p-0 text-xs focus:ring-0 outline-none; }
        .table-dense th, .table-dense td { padding: 8px 12px; font-size: 11px; vertical-align: middle; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* MODO DEMO */
        .demo-mode-active .demo-blur { 
            filter: blur(8px) !important; 
            pointer-events: none !important; 
            user-select: none !important; 
            transition: all 0.3s ease;
        }
    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#F8FAFC]">

    <%- include('partials/sidebar', { page: 'services' }) %>

    <main class="flex-1 md:ml-64 flex flex-col min-w-0 overflow-hidden relative">
        <!-- HEADER PRINCIPAL -->
        <header class="bg-white border-b border-gray-100 px-8 py-6 flex justify-between items-center shrink-0 shadow-sm z-10">
            <div class="text-left">
                <h1 class="text-2xl font-black text-gray-800 uppercase tracking-tighter leading-none">Gestão de Serviços</h1>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Visão 360º de Projetos, Alocações e Faturamento</p>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="flex items-center bg-gray-50 border border-gray-100 rounded-xl px-4 py-2 gap-3 shadow-sm focus-within:ring-2 focus-within:ring-c3c-blue transition-all w-64">
                    <i data-lucide="search" class="w-4 h-4 text-gray-400"></i>
                    <input type="text" id="search-input" oninput="filterServices()" placeholder="Pesquisar serviços..." class="bg-transparent text-[10px] font-black text-gray-600 uppercase tracking-widest outline-none w-full placeholder:text-gray-300">
                </div>

                <div class="flex items-center bg-gray-50 border border-gray-100 rounded-xl px-3 py-1.5 gap-2 shadow-sm focus-within:ring-2 focus-within:ring-c3c-blue transition-all">
                    <i data-lucide="filter" class="w-3.5 h-3.5 text-c3c-blue"></i>
                    <select id="status-filter" onchange="filterServices()" class="bg-transparent text-[10px] font-black text-gray-500 uppercase tracking-widest outline-none cursor-pointer pr-6">
                        <option value="active" selected>Ativos</option>
                        <option value="inactive">Inativos</option>
                        <option value="all">Todos</option>
                    </select>
                </div>

                <button onclick="openServiceModal()" class="bg-c3c-gradient text-white text-[10px] font-black uppercase tracking-widest px-6 py-3 rounded-xl shadow-lg shadow-blue-100 transition-all active:scale-95 flex items-center gap-2">
                    <i data-lucide="plus" class="w-4 h-4"></i> Novo Serviço
                </button>
            </div>
        </header>

        <!-- CONTEÚDO -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 fade-in custom-scrollbar bg-gray-50/30 text-left">
            <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6" id="services-grid">
                <!-- Cards de Serviço injetados via JS -->
            </div>
            <div id="no-results" class="hidden flex-col items-center justify-center py-32 text-center opacity-30">
                <i data-lucide="search-x" class="w-16 h-16 text-gray-300 mb-4"></i>
                <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest">Nenhum serviço encontrado</h3>
            </div>
        </div>
    </main>

    <!-- MEGA MODAL SERVIÇO PREMIUM -->
    <div id="service-modal" class="fixed inset-0 bg-black/60 backdrop-blur-md hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-[40px] shadow-2xl w-full max-w-[95vw] h-[95vh] flex flex-col transform scale-95 transition-all overflow-hidden border border-white/20">
            
            <!-- LOADER -->
            <div id="modal-loader" class="absolute inset-0 bg-white/80 backdrop-blur-sm z-[150] flex items-center justify-center hidden">
                <div class="flex flex-col items-center gap-4">
                    <div class="w-12 h-12 border-4 border-blue-100 border-t-c3c-blue rounded-full animate-spin"></div>
                    <p class="text-[10px] font-black text-c3c-blue uppercase tracking-[0.3em] animate-pulse">Processando dados...</p>
                </div>
            </div>

            <!-- MODAL HEADER CONSOLIDADO -->
            <div class="px-10 py-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/30 shrink-0">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-2xl bg-c3c-gradient flex items-center justify-center text-white shadow-lg shadow-blue-100">
                        <i data-lucide="layers" class="w-6 h-6"></i>
                    </div>
                    <div class="text-left">
                        <div class="flex items-center gap-2">
                            <h2 id="modal-svc-title" class="text-lg font-black text-gray-800 uppercase tracking-tighter">Editar Serviço</h2>
                            <span id="badge-status" class="bg-blue-50 text-c3c-blue text-[8px] font-black px-2 py-0.5 rounded-full border border-blue-100 uppercase tracking-widest">Em Edição</span>
                        </div>
                        <p id="modal-svc-subtitle" class="text-[10px] font-bold text-c3c-blue uppercase tracking-widest mt-0.5 truncate max-w-md">Gestão de Escopo, Alocação e Faturamento</p>
                    </div>
                </div>

                <!-- INDICADORES NO HEADER -->
                <div class="flex items-center gap-6">
                    <div class="text-right hidden">
                        <p class="text-[8px] font-black text-gray-400 uppercase tracking-widest mb-0.5">Baseline</p>
                        <p id="card-prop-rev" class="text-xs font-black text-gray-800">R$ 0,00</p>
                        <p id="card-prop-margin" class="text-[9px] font-black text-c3c-blue">0% MG</p>
                    </div>
                    <div class="w-px h-8 bg-gray-100 hidden"></div>
                    <div class="text-right hidden">
                        <p class="text-[8px] font-black text-gray-400 uppercase tracking-widest mb-0.5">Previsão</p>
                        <p id="card-fcst-rev" class="text-xs font-black text-gray-800">R$ 0,00</p>
                        <p id="card-fcst-margin" class="text-[9px] font-black text-indigo-600">0% MG</p>
                    </div>
                    <div class="w-px h-8 bg-gray-100 hidden"></div>
                    <div class="text-right">
                        <p class="text-[8px] font-black text-gray-400 uppercase tracking-widest mb-0.5">Real YTD</p>
                        <p id="card-act-rev" class="text-xs font-black text-gray-800">R$ 0,00</p>
                        <p id="card-act-margin" class="text-[9px] font-black text-teal-600">0% MG</p>
                    </div>
                    <div class="w-px h-8 bg-gray-100 ml-2"></div>
                    <div class="flex gap-2 ml-2">
                        <button onclick="saveService()" class="px-6 py-3 bg-c3c-gradient text-white font-black uppercase text-[10px] tracking-widest rounded-xl shadow-xl shadow-blue-100 hover:opacity-90 transition-all active:scale-95 flex items-center gap-2"><i data-lucide="save" class="w-4 h-4"></i> Salvar</button>
                        <button onclick="closeModal('service-modal')" class="p-3 text-gray-300 hover:text-gray-600 hover:bg-gray-50 rounded-xl transition-all"><i data-lucide="x" class="w-5 h-5"></i></button>
                    </div>
                </div>
            </div>

            <!-- TABS -->
            <div class="px-10 border-b border-gray-100 flex gap-8 bg-white shrink-0 overflow-x-auto no-scrollbar">
                <button id="tab-general" onclick="switchTab('general')" class="modal-tab-active py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Geral</button>
                <button id="tab-attachments" onclick="switchTab('attachments')" class="modal-tab-inactive py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Anexos</button>
                <button id="tab-billing" onclick="switchTab('billing')" class="modal-tab-inactive py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Faturamento</button>
                <button id="tab-commercial" onclick="switchTab('commercial')" class="modal-tab-inactive py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Comercial</button>
                <button id="tab-execution" onclick="switchTab('execution')" class="modal-tab-inactive py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Planejamento</button>
                <button id="tab-realized" onclick="switchTab('realized')" class="modal-tab-inactive py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Execução</button>
            </div>

            <div class="flex-1 overflow-y-auto p-10 space-y-10 no-scrollbar bg-white">
                
                <!-- 1. GERAL -->
                <div id="view-general" class="fade-in max-w-6xl mx-auto text-left">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-8">
                        <!-- LINHA 1 -->
                        <div class="md:col-span-2">
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Nome do Serviço</label>
                            <input id="input-svc-name" type="text" class="input-modern w-full" placeholder="Ex: Consultoria Estratégica V2">
                        </div>
                        <div class="md:col-span-1">
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Tipo de Serviço</label>
                            <select id="input-svc-type" class="input-modern w-full">
                                <option value="Projeto">Projeto</option>
                                <option value="Recorrente">Recorrente</option>
                                <option value="Suporte">Suporte</option>
                                <option value="Hunting">Hunting</option>
                                <option value="Alocação">Alocação</option>
                            </select>
                        </div>

                        <!-- LINHA 2 -->
                        <div class="relative group">
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Cliente (SF)</label>
                            <input id="input-sf-account" list="sf-accounts-list" class="input-modern w-full pr-8" placeholder="Buscar...">
                            <button onclick="document.getElementById('input-sf-account').value=''" class="absolute right-3 bottom-3 text-gray-300 hover:text-red-500 transition-all opacity-0 group-hover:opacity-100"><i data-lucide="x" class="w-4 h-4"></i></button>
                        </div>
                        <div class="relative group">
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Cliente (ERP)</label>
                            <input id="input-ca-client" list="ca-clients-list" onchange="validateCaClientSelection()" class="input-modern w-full pr-8" placeholder="Vincular...">
                            <button onclick="document.getElementById('input-ca-client').value=''; validateCaClientSelection();" class="absolute right-3 bottom-3 text-gray-300 hover:text-red-500 transition-all opacity-0 group-hover:opacity-100"><i data-lucide="x" class="w-4 h-4"></i></button>
                            <div id="ca-client-status" class="absolute right-10 bottom-3 hidden">
                                <i data-lucide="check-circle-2" class="w-4 h-4 text-teal-500"></i>
                            </div>
                        </div>                        <div>
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Tabela de Preços</label>
                            <select id="select-pricebook" onchange="onPricebookChange()" class="input-modern w-full"></select>
                        </div>

                        <!-- LINHA 3 -->
                        <div class="relative group">
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Líder Projeto</label>
                            <input id="input-lead-project" list="people-list" class="input-modern w-full pr-8" placeholder="Lead">
                            <button onclick="document.getElementById('input-lead-project').value=''" class="absolute right-3 bottom-3 text-gray-300 hover:text-red-500 transition-all opacity-0 group-hover:opacity-100"><i data-lucide="x" class="w-4 h-4"></i></button>
                        </div>
                        <div class="relative group">
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Coordenador</label>
                            <input id="input-coordinator" list="people-list" class="input-modern w-full pr-8" placeholder="Coord.">
                            <button onclick="document.getElementById('input-coordinator').value=''" class="absolute right-3 bottom-3 text-gray-300 hover:text-red-500 transition-all opacity-0 group-hover:opacity-100"><i data-lucide="x" class="w-4 h-4"></i></button>
                        </div>
                        <div class="relative group">
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Líder Técnico</label>
                            <input id="input-tech-lead" list="people-list" class="input-modern w-full pr-8" placeholder="Tech">
                            <button onclick="document.getElementById('input-tech-lead').value=''" class="absolute right-3 bottom-3 text-gray-300 hover:text-red-500 transition-all opacity-0 group-hover:opacity-100"><i data-lucide="x" class="w-4 h-4"></i></button>
                        </div>

                        <!-- LINHA 4 -->
                        <div>
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Data Início</label>
                            <input id="input-svc-start" type="date" class="input-modern w-full">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Fim Original</label>
                            <input id="input-svc-end-orig" type="date" class="input-modern w-full">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Fim Real</label>
                            <input id="input-svc-end-real" type="date" class="input-modern w-full">
                        </div>
                    </div>
                </div>

                <!-- 1.1 ANEXOS (NOVA ABA) -->
                <div id="view-attachments" class="hidden fade-in max-w-6xl mx-auto space-y-8 text-left">
                    <div class="flex justify-between items-center mb-4">
                        <div>
                            <h4 class="text-xs font-black text-gray-800 uppercase tracking-[0.3em] flex items-center gap-2"><i data-lucide="file-text" class="w-4 h-4 text-c3c-blue"></i> Documentação do Serviço</h4>
                            <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mt-1">Gestão de arquivos e propostas vinculadas</p>
                        </div>
                        <button onclick="openUploadModal()" class="bg-blue-50 hover:bg-blue-100 text-c3c-blue text-[10px] font-black uppercase tracking-widest px-6 py-3 rounded-xl transition-all flex items-center gap-2">
                            <i data-lucide="upload-cloud" class="w-4 h-4"></i> Anexar Documento
                        </button>
                    </div>
                    
                    <div id="docs-list-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        <!-- Documentos injetados via JS -->
                    </div>
                </div>

                <!-- 2. COMERCIAL -->
                <div id="view-commercial" class="hidden fade-in space-y-8 text-left">
                    <div class="flex justify-between items-center">
                        <h4 class="text-xs font-black text-gray-800 uppercase tracking-[0.3em] flex items-center gap-2"><i data-lucide="shopping-cart" class="w-4 h-4 text-c3c-blue"></i> Escopo Comercial (Vendido)</h4>
                        <div class="flex gap-4 items-center">
                            <div class="text-right px-4 py-2 bg-blue-50/50 rounded-2xl border border-blue-100">
                                <p class="text-[8px] font-black text-gray-400 uppercase tracking-widest">Total Vendido</p>
                                <p id="comm-total-rev-foot" class="text-xs font-black text-c3c-blue">R$ 0,00</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-[32px] border border-gray-100 shadow-xl overflow-hidden">
                        <table class="w-full text-left table-dense">
                            <thead class="bg-gray-50/80 border-b border-gray-100">
                                <tr>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest py-5 px-6">Produto / Serviço</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Valor Hora</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Custo Est.</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Início</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Término</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Dias</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Aloc%</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Total Hrs</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Receita</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Custo</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center px-6">Ação</th>
                                </tr>
                            </thead>
                            <tbody id="commercial-rows" class="divide-y divide-gray-50"></tbody>
                            <tfoot class="bg-gray-50/30 font-black text-gray-600">
                                <tr>
                                    <td class="py-4 px-6 uppercase text-[9px] tracking-widest">Totais de Baseline</td>
                                    <td colspan="6"></td>
                                    <td id="comm-total-hours" class="text-right px-2">0h</td>
                                    <td id="comm-total-rev" class="text-right px-2 text-c3c-blue">-</td>
                                    <td id="comm-total-cost" class="text-right px-2 text-red-500">-</td>
                                    <td id="comm-total-margin" class="text-center text-teal-600">-</td>
                                </tr>
                            </tfoot>
                        </table>
                        <div class="p-4 bg-gray-50/30 border-t border-gray-50"><button onclick="addCommercialRow()" class="w-full py-4 bg-white border border-gray-100 hover:border-c3c-blue hover:bg-blue-50 text-[10px] font-black text-c3c-blue uppercase tracking-[0.2em] rounded-2xl transition-all flex items-center justify-center gap-2 active:scale-[0.99] shadow-sm"><i data-lucide="plus" class="w-4 h-4"></i> Adicionar Item de Escopo</button></div>
                    </div>

                    <!-- FORECAST BASELINE ESPECÍFICO -->
                    <div class="bg-white p-8 rounded-[32px] border border-gray-100 shadow-sm space-y-4 hidden">
                        <div class="flex justify-between items-center">
                            <h5 class="text-[10px] font-black text-gray-400 uppercase tracking-widest flex items-center gap-2"><i data-lucide="calendar-range" class="w-4 h-4"></i> Forecast Mensal (Baseline)</h5>
                            <select id="forecast-year-comm" onchange="refreshAllForecasts()" class="input-modern py-1 text-[10px]"><option value="2024">2024</option><option value="2025" selected>2025</option><option value="2026">2026</option></select>
                        </div>
                        <div class="overflow-x-auto no-scrollbar">
                            <table class="w-full text-[10px]">
                                <thead id="monthly-forecast-header" class="text-gray-400 border-b border-gray-50 font-black uppercase"></thead>
                                <tbody id="monthly-forecast-body" class="font-bold text-gray-700"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 3. EXECUÇÃO -->
                <div id="view-execution" class="hidden fade-in space-y-8 text-left">
                    <div class="flex justify-between items-center">
                        <h4 class="text-xs font-black text-gray-800 uppercase tracking-[0.3em] flex items-center gap-2"><i data-lucide="users" class="w-4 h-4 text-indigo-500"></i> Plano de Alocação (Previsto)</h4>
                        <div class="text-right px-4 py-2 bg-indigo-50/50 rounded-2xl border border-indigo-100">
                            <p class="text-[8px] font-black text-gray-400 uppercase tracking-widest">Total Previsto</p>
                            <p id="exec-total-rev-foot" class="text-xs font-black text-indigo-600">R$ 0,00</p>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-[32px] border border-gray-100 shadow-xl overflow-hidden">
                        <table class="w-full text-left table-dense">
                            <thead class="bg-gray-50/80 border-b border-gray-100">
                                <tr>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest py-5 px-6 w-40">Item Baseline</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest py-5">Recurso</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right w-20">P.Venda</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right w-20">C.Real</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Início</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Término</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Aloc%</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Dias</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Hrs</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Receita</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Custo</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">MG%</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center px-6">Ação</th>
                                </tr>
                            </thead>
                            <tbody id="execution-rows" class="divide-y divide-gray-50"></tbody>
                            <tfoot class="bg-gray-50/30 font-black text-gray-600">
                                <tr>
                                    <td class="py-4 px-6 uppercase text-[9px] tracking-widest">Totais de Alocação</td>
                                    <td colspan="7"></td>
                                    <td id="exec-total-hours" class="text-right px-2">0h</td>
                                    <td id="exec-total-rev" class="text-right px-2 text-indigo-600">-</td>
