<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal de Notas - C3C Workplace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { 
                        c3c: { 
                            blue: '#2978FF', 
                            teal: '#1DDDBD', 
                            gray: '#F2F2F2',
                            dark: '#000000'
                        } 
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .bg-c3c-gradient { background: transparent linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%) 0% 0% no-repeat padding-box; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
        
        /* STEPPER PATH STYLES */
        .step-path { @apply relative flex items-center justify-between w-full gap-2 px-2; }
        .step-item { @apply relative flex flex-col items-center flex-1 cursor-pointer transition-all duration-300; }
        .step-node { @apply w-12 h-12 rounded-full border-4 border-white shadow-md flex items-center justify-center text-sm font-black transition-all duration-500 z-10; }
        .step-line { @apply absolute top-6 left-[50%] w-full h-1 bg-gray-100 -z-0 transition-all duration-500; }
        .step-item:last-child .step-line { @apply hidden; }
        
        .step-item.active .step-node { @apply bg-c3c-blue text-white scale-110 shadow-blue-200 shadow-xl border-blue-100; }
        .step-item.active .step-line { @apply bg-c3c-blue; }
        .step-item.active p { @apply text-c3c-blue font-black; }

        /* TOAST STYLES */
        #toast-container { position: fixed; top: 2rem; right: 2rem; z-index: 9999; display: flex; flex-direction: column; gap: 1rem; }
        .toast { 
            animation: toastIn 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
            background-color: white; border: 1px solid #F1F5F9; border-radius: 24px; padding: 1rem; display: flex; align-items: center; gap: 1rem; min-width: 320px; max-width: 400px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }
        @keyframes toastIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        .toast.hiding { animation: toastOut 0.5s ease-in forwards; }
        @keyframes toastOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#F8FAFC]">

    <!-- TOAST CONTAINER -->
    <div id="toast-container"></div>

    <%- include('partials/sidebar', { page: 'billing_portal' }) %>

    <main class="flex-1 flex flex-col md:ml-64 relative w-full transition-all duration-300 overflow-hidden">
        
        <!-- HEADER -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-20 shrink-0">
            <div class="flex items-center gap-4 text-left">
                <button onclick="document.getElementById('sidebar').classList.toggle('-translate-x-full')" class="md:hidden p-2 text-gray-600 hover:bg-gray-100 rounded-lg">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <div>
                    <h1 class="text-lg md:text-xl font-bold text-gray-800 flex items-center gap-2 tracking-tight">Portal de Notas <span class="text-c3c-blue">📄</span></h1>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest hidden sm:block">Gerencie seus faturamentos e Notas Fiscais</p>
                </div>
            </div>
        </header>

        <!-- CONTEÚDO -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 fade-in custom-scrollbar text-left">
            
            <!-- KPIS FINANCEIROS -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
                <div class="bg-white p-6 rounded-[32px] shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-all text-left">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="p-2.5 bg-blue-50 text-c3c-blue rounded-2xl"><i data-lucide="send" class="w-5 h-5"></i></div>
                        <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Liberado p/ Envio</span>
                    </div>
                    <p class="text-3xl font-black text-gray-800 tracking-tighter" id="kpi-liberado">R$ 0,00</p>
                </div>
                <div class="bg-white p-6 rounded-[32px] shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-all text-left">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="p-2.5 bg-orange-50 text-orange-500 rounded-2xl"><i data-lucide="clock" class="w-5 h-5"></i></div>
                        <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Em Validação</span>
                    </div>
                    <p class="text-3xl font-black text-gray-800 tracking-tighter" id="kpi-validacao">R$ 0,00</p>
                </div>
                <div class="bg-c3c-gradient p-6 rounded-[32px] shadow-xl shadow-blue-100 relative overflow-hidden group hover:scale-[1.02] transition-all text-left text-white">
                    <div class="flex items-center gap-3 mb-4 relative z-10">
                        <div class="p-2.5 bg-white/20 text-white rounded-2xl backdrop-blur-sm"><i data-lucide="wallet" class="w-5 h-5"></i></div>
                        <span class="text-[10px] font-black text-blue-50 uppercase tracking-widest">Saldo Total</span>
                    </div>
                    <p class="text-3xl font-black text-white tracking-tighter relative z-10" id="kpi-total">R$ 0,00</p>
                    <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full blur-3xl -mr-10 -mt-10"></div>
                </div>
            </div>

            <!-- STEPPER PATH (Jornada da Nota) -->
            <div class="mb-10 bg-white p-8 rounded-[40px] shadow-sm border border-gray-100 overflow-hidden">
                <div id="funnel-container">
                    <!-- Gerado via JS -->
                </div>
            </div>

            <div class="mb-10">
                <h2 class="text-2xl font-black text-gray-800 tracking-tighter uppercase leading-tight">Meus Ciclos</h2>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mt-1">Acompanhe a liberação e realize o envio das suas Notas Fiscais</p>
            </div>

            <!-- TABELA -->
            <div class="bg-white rounded-[32px] shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-gray-50/50 border-b border-gray-100">
                            <tr class="text-[10px] font-black text-gray-400 uppercase tracking-widest">
                                <th class="px-8 py-5">Ciclo / Referência</th>
                                <th class="px-8 py-5">Status do Ciclo</th>
                                <th class="px-8 py-5 text-right">Valor Líquido</th>
                                <th class="px-8 py-5 text-center">Status da Nota</th>
                                <th class="px-8 py-5 text-center">Arquivo</th>
                                <th class="px-8 py-5 text-right">Ações</th>
                            </tr>
                        </thead>
                        <tbody id="period-table-body" class="divide-y divide-gray-50">
                            <tr><td colspan="6" class="text-center py-20 text-gray-300 font-bold uppercase text-[10px] tracking-widest"><i data-lucide="loader-2" class="w-6 h-6 animate-spin inline-block mb-2"></i><br>Carregando seus ciclos...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- INSTRUÇÕES / AJUDA -->
            <div class="mt-12 bg-blue-50/50 rounded-[32px] p-8 border border-blue-100/50 flex flex-col md:flex-row items-center gap-8">
                <div class="w-20 h-20 rounded-full overflow-hidden border-4 border-white shadow-lg shrink-0">
                    <img src="/assets/signatures/assinaturaCapivorce.png" alt="Capivorce" class="w-full h-full object-cover">
                </div>
                <div class="text-left">
                    <h4 class="text-sm font-black text-c3c-blue uppercase tracking-widest mb-2">Dica da Capivorce 💡</h4>
                    <p class="text-xs font-bold text-gray-500 leading-relaxed max-w-2xl uppercase">
                        Sua nota fiscal só pode ser enviada quando o ciclo estiver com o status <span class="text-c3c-blue">"Liberado para Nota Fiscal"</span>. 
                        Nossa IA analisará o arquivo automaticamente para agilizar seu processo!
                    </p>
                </div>
            </div>
        </div>
    </main>

    <!-- MODAL UPLOAD PREMIUM -->
    <div id="modal-upload" class="fixed inset-0 bg-black/60 backdrop-blur-md z-[60] hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-[40px] shadow-2xl w-full max-w-lg overflow-hidden transform scale-95 transition-all flex flex-col max-h-[90vh]">
            
            <header class="p-8 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <div>
                    <h3 class="text-2xl font-black text-gray-800 tracking-tighter uppercase leading-tight">Enviar Nota Fiscal</h3>
                    <p id="modal-period-name" class="text-[10px] font-black text-c3c-blue uppercase tracking-[0.2em] mt-1 italic">Ciclo...</p>
                </div>
                <button onclick="closeUploadModal()" class="p-3 text-gray-400 hover:bg-white hover:text-red-500 rounded-full shadow-sm transition-all"><i data-lucide="x"></i></button>
            </header>
            
            <div class="p-8 overflow-y-auto custom-scrollbar flex-1">
                <input type="hidden" id="upload-period-id">
                
                <div class="space-y-6">
                    <!-- DROPZONE STYLE FILE INPUT -->
                    <div class="relative group">
                        <label class="block text-[10px] font-black text-gray-400 uppercase mb-3 tracking-widest">Arquivo da Nota (PDF ou Imagem)</label>
                        <div class="relative border-2 border-dashed border-gray-200 rounded-[24px] p-8 text-center hover:border-c3c-blue transition-all bg-gray-50/50 group-hover:bg-white">
                            <input type="file" id="nf-file" accept=".pdf, .jpg, .jpeg, .png" onchange="analyzeFile(this)" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                            <div id="file-placeholder" class="space-y-2">
                                <div class="w-12 h-12 rounded-2xl bg-blue-100 text-c3c-blue flex items-center justify-center mx-auto mb-4"><i data-lucide="upload-cloud"></i></div>
                                <p class="text-xs font-black text-gray-800 uppercase tracking-tighter">Clique para selecionar</p>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">PDF, JPG ou PNG até 10MB</p>
                            </div>
                            <div id="analyze-loader" class="hidden absolute inset-0 bg-white/90 backdrop-blur-sm rounded-[24px] flex flex-col items-center justify-center z-20">
                                <div class="w-12 h-12 rounded-full border-4 border-blue-100 border-t-c3c-blue animate-spin mb-4"></div>
                                <p class="text-xs font-black text-c3c-blue uppercase tracking-widest animate-pulse">Inteligência Artificial analisando...</p>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="text-left">
                            <label class="block text-[10px] font-black text-gray-400 uppercase mb-2 tracking-widest px-2">Número da Nota</label>
                            <input type="text" id="nf-numero" disabled placeholder="..." oninput="validateForm()" class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-5 py-3 text-sm font-bold focus:ring-4 focus:ring-blue-100 focus:border-c3c-blue outline-none transition-all disabled:text-gray-400">
                        </div>
                        <div class="text-left">
                            <label class="block text-[10px] font-black text-gray-400 uppercase mb-2 tracking-widest px-2">Data Emissão</label>
                            <input type="date" id="nf-data-emissao" disabled oninput="validateForm()" class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-5 py-3 text-sm font-bold focus:ring-4 focus:ring-blue-100 focus:border-c3c-blue outline-none transition-all disabled:text-gray-400">
                        </div>
                    </div>

                    <div class="text-left">
                        <label class="block text-[10px] font-black text-gray-400 uppercase mb-2 tracking-widest px-2">Sua Empresa (Emitente)</label>
                        <input type="text" id="nf-emitente" disabled placeholder="..." oninput="validateForm()" class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-5 py-3 text-sm font-bold focus:ring-4 focus:ring-blue-100 focus:border-c3c-blue outline-none transition-all disabled:text-gray-400">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="text-left">
                            <label class="block text-[10px] font-black text-gray-400 uppercase mb-2 tracking-widest px-2">CNPJ Emitente</label>
                            <input type="text" id="cnpj-emissor" disabled placeholder="..." oninput="validateForm()" class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-5 py-3 text-sm font-bold focus:ring-4 focus:ring-blue-100 focus:border-c3c-blue outline-none transition-all disabled:text-gray-400">
                        </div>
                        <div class="text-left">
                            <label class="block text-[10px] font-black text-gray-400 uppercase mb-2 tracking-widest px-2">CNPJ Receptor</label>
                            <input type="text" id="cnpj-receptor" disabled placeholder="..." oninput="validateForm()" class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-5 py-3 text-sm font-bold focus:ring-4 focus:ring-blue-100 focus:border-c3c-blue outline-none transition-all disabled:text-gray-400">
                        </div>
                    </div>

                    <div class="text-left">
                        <label class="block text-[10px] font-black text-gray-400 uppercase mb-2 tracking-widest px-2">Valor da Nota</label>
                        <div class="relative">
                            <span class="absolute left-5 top-1/2 -translate-y-1/2 text-sm font-black text-c3c-blue">R$</span>
                            <input type="number" id="nf-valor" step="0.01" disabled oninput="validateForm()" class="w-full bg-blue-50 border-2 border-blue-100 rounded-2xl px-12 py-4 text-xl font-black text-c3c-blue focus:ring-4 focus:ring-blue-100 outline-none transition-all disabled:opacity-80">
                        </div>
                    </div>
                </div>
            </div>

            <footer class="p-8 border-t border-gray-100 bg-gray-50/50 flex justify-end gap-4 shrink-0">
                <button onclick="closeUploadModal()" class="px-6 py-3 text-gray-400 font-black uppercase text-[10px] hover:text-gray-600 transition-colors tracking-widest">Cancelar</button>
                <button id="btn-process-upload" onclick="processUpload()" disabled class="px-10 py-4 bg-c3c-gradient text-white font-black uppercase text-xs tracking-widest rounded-2xl shadow-xl hover:opacity-90 active:scale-95 transition-all disabled:bg-gray-200 disabled:text-gray-400 disabled:shadow-none disabled:bg-none">Enviar Nota Fiscal</button>
            </footer>
        </div>
    </div>

    <script>
        lucide.createIcons();
        let allPeriods = [];
        let currentStatusFilter = '';

        document.addEventListener('DOMContentLoaded', loadPeriods);

        function showToast(title, message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = 'toast';
            const icon = type === 'success' ? 'check-circle' : (type === 'error' ? 'alert-triangle' : 'info');
            const iconColor = type === 'success' ? 'text-teal-500 bg-teal-50' : (type === 'error' ? 'text-red-500 bg-red-50' : 'text-blue-500 bg-blue-50');
            toast.innerHTML = `<div class="p-3 rounded-2xl ${iconColor}"><i data-lucide="${icon}" class="w-6 h-6"></i></div><div class="flex-1"><h4 class="text-xs font-black text-gray-800 uppercase tracking-widest">${title}</h4><p class="text-[10px] font-bold text-gray-400 uppercase mt-0.5 tracking-tight">${message}</p></div>`;
            container.appendChild(toast);
            lucide.createIcons();
            setTimeout(() => { toast.classList.add('hiding'); setTimeout(() => toast.remove(), 500); }, 4000);
        }

        async function loadPeriods() {
            try {
                const res = await fetch('/api/billing/periods');
                allPeriods = await res.json();
                
                // Cálculo de KPIs
                let lib = 0, val = 0, tot = 0;
                allPeriods.forEach(p => {
                    tot += (p.valorHoras || 0);
                    if (p.statusPeriodo === 'Liberado para Nota Fiscal' && !p.hasNF) lib += (p.valorHoras || 0);
                    if (p.hasNF && p.nfStatus !== 'Aprovada') val += (p.valorHoras || 0);
                });
                document.getElementById('kpi-liberado').innerText = lib.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                document.getElementById('kpi-validacao').innerText = val.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                document.getElementById('kpi-total').innerText = tot.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });

                renderFunnel();
                renderTable();
            } catch(e) { console.error(e); showToast('Erro de Conexão', 'Não foi possível carregar seus ciclos.', 'error'); }
        }

        function renderFunnel() {
            const container = document.getElementById('funnel-container');
            container.innerHTML = '';
            container.className = 'relative flex flex-row justify-between items-start w-full py-4';

            const steps = [
                { id: 'Em apuração', label: '1. Em Apuração', icon: 'clock', filter: 'Em apuração' },
                { id: 'Liberado', label: '2. Liberado', icon: 'send', filter: 'Liberado para Nota Fiscal' },
                { id: 'Validacao', label: '3. Em Validação', icon: 'shield-check', filter: 'VALIDACAO' },
                { id: 'Pago', label: '4. Concluído', icon: 'check-circle', filter: 'Finalizado/Pago' }
            ];

            const backgroundLine = document.createElement('div');
            backgroundLine.className = 'absolute top-[38px] left-[10%] right-[10%] h-1 bg-gray-100 -z-0';
            container.appendChild(backgroundLine);

            steps.forEach(step => {
                let count = 0;
                if (step.id === 'Validacao') count = allPeriods.filter(p => p.hasNF && p.nfStatus !== 'Aprovada').length;
                else if (step.id === 'Liberado') count = allPeriods.filter(p => p.statusPeriodo === 'Liberado para Nota Fiscal' && !p.hasNF).length;
                else count = allPeriods.filter(p => p.statusPeriodo === step.filter).length;

                const isActive = currentStatusFilter === step.id;
                const stepEl = document.createElement('div');
                stepEl.className = 'relative z-10 flex flex-col items-center cursor-pointer transition-all duration-300 flex-1 group';
                stepEl.onclick = () => filterByStatus(step.id);
                stepEl.innerHTML = `
                    <div class="w-10 h-10 rounded-full border-4 ${isActive ? 'bg-c3c-blue border-blue-100 text-white shadow-xl scale-125' : 'bg-white border-gray-50 text-gray-300 group-hover:text-c3c-blue'} flex items-center justify-center transition-all duration-500">
                        <i data-lucide="${step.icon}" class="w-4 h-4"></i>
                    </div>
                    <div class="mt-3 text-center">
                        <p class="text-[8px] font-black uppercase tracking-widest ${isActive ? 'text-c3c-blue' : 'text-gray-400'}">${step.label}</p>
                        <p class="text-lg font-black ${isActive ? 'text-c3c-blue' : 'text-gray-800'} tracking-tighter">${count}</p>
                    </div>
                `;
                container.appendChild(stepEl);
            });
            lucide.createIcons();
        }

        function filterByStatus(st) {
            currentStatusFilter = (currentStatusFilter === st) ? '' : st;
            renderFunnel();
            renderTable();
        }

        function renderTable() {
            const periods = allPeriods.filter(p => {
                if (!currentStatusFilter) return true;
                if (currentStatusFilter === 'Validacao') return p.hasNF && p.nfStatus !== 'Aprovada';
                if (currentStatusFilter === 'Liberado') return p.statusPeriodo === 'Liberado para Nota Fiscal' && !p.hasNF;
                if (currentStatusFilter === 'Em apuração') return p.statusPeriodo === 'Em apuração';
                if (currentStatusFilter === 'Pago') return p.statusPeriodo === 'Finalizado/Pago';
                return true;
            });

            const tbody = document.getElementById('period-table-body');
            tbody.innerHTML = '';

            if (periods.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="py-32 px-6">
                    <div class="flex flex-col items-center justify-center text-center fade-in">
                        <div class="w-20 h-20 bg-gray-50 text-gray-200 rounded-full flex items-center justify-center mb-6 border border-gray-100 shadow-inner"><i data-lucide="file-x" class="w-10 h-10"></i></div>
                        <h3 class="text-lg font-black text-gray-800 uppercase tracking-tighter mb-2">Nada por aqui</h3>
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] max-w-xs mx-auto italic">Você não possui ciclos nesta etapa no momento.</p>
                    </div></td></tr>`;
                lucide.createIcons();
                return;
            }

            periods.forEach(p => {
                const vHoras = (p.valorHoras || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                
                let nfStatusBadge = '<span class="text-gray-300">-</span>';
                if(p.hasNF) {
                    const colors = { 
                        'Rascunho': 'bg-gray-50 text-gray-400 border-gray-100', 
                        'Em Revisão': 'bg-blue-50 text-c3c-blue border-blue-100', 
                        'Aprovada': 'bg-teal-50 text-teal-600 border-teal-100', 
                        'Reprovada': 'bg-red-50 text-red-600 border-red-100' 
                    };
                    nfStatusBadge = `<span class="px-3 py-1 rounded-full text-[9px] font-black uppercase border ${colors[p.nfStatus] || 'bg-gray-50'}" title="${p.nfMotivo || ''}">${p.nfStatus}</span>`;
                }

                let actions = '';
                if (p.statusPeriodo === 'Liberado para Nota Fiscal' || p.nfStatus === 'Reprovada') {
                    actions = `<button onclick="openUploadModal('${p.id}', '${p.name}', ${p.valorHoras})" class="bg-c3c-gradient hover:opacity-90 text-white px-5 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-blue-100 flex items-center gap-2 transition-all active:scale-95"><i data-lucide="upload-cloud" class="w-3.5 h-3.5"></i> Enviar Nota</button>`;
                } else if (p.hasNF) {
                    actions = `<div class="flex items-center justify-end gap-2 text-[10px] font-black text-gray-400 uppercase tracking-widest"><i data-lucide="clock" class="w-3.5 h-3.5 text-c3c-blue animate-pulse"></i> Em validação</div>`;
                }

                const nfFile = (p.hasNF && p.nfDocumentoId) ? `<div class="flex justify-center"><a href="/api/billing/download/${p.nfDocumentoId}" class="p-2 hover:bg-blue-50 rounded-lg transition-colors text-c3c-blue"><i data-lucide="download" class="w-5 h-5"></i></a></div>` : '<span class="text-gray-300">-</span>';

                const motivoHTML = p.nfStatus === 'Reprovada' && p.nfMotivo ? `<div class="flex items-start gap-1 mt-2 text-red-500 bg-red-50 p-2 rounded-lg border border-red-100"><i data-lucide="alert-circle" class="w-3 h-3 shrink-0 mt-0.5"></i><p class="text-[9px] font-bold uppercase tracking-tight leading-tight">${p.nfMotivo}</p></div>` : '';

                tbody.innerHTML += `
                    <tr class="hover:bg-gray-50/50 transition-colors group">
                        <td class="px-8 py-6">
                            <p class="font-black text-gray-800 uppercase text-xs tracking-tighter">${p.name}</p>
                            <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mt-1">Ref: ${p.inicio} — ${p.fim}</p>
                            ${motivoHTML}
                        </td>
                        <td class="px-8 py-6">
                            <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">${p.statusPeriodo}</span>
                        </td>
                        <td class="px-8 py-6 text-right font-black text-gray-800 text-sm tracking-tighter">${vHoras}</td>
                        <td class="px-8 py-6 text-center">${nfStatusBadge}</td>
                        <td class="px-8 py-6 text-center">${nfFile}</td>
                        <td class="px-8 py-6 text-right">${actions}</td>
                    </tr>
                `;
            });
            lucide.createIcons();
        }

        function openUploadModal(id, name, val) {
            document.getElementById('upload-period-id').value = id;
            document.getElementById('modal-period-name').innerText = name;
            
            const fields = ['nf-numero', 'nf-data-emissao', 'nf-emitente', 'cnpj-emissor', 'cnpj-receptor'];
            fields.forEach(f => {
                const el = document.getElementById(f);
                el.value = ''; el.disabled = true;
                el.classList.remove('border-teal-500', 'bg-teal-50/30');
            });

            const vField = document.getElementById('nf-valor');
            vField.value = val; vField.disabled = true;
            vField.classList.remove('border-teal-500', 'bg-teal-50/30');

            document.getElementById('nf-file').value = '';
            document.getElementById('analyze-loader').classList.add('hidden');
            document.getElementById('btn-process-upload').disabled = true;

            document.getElementById('modal-upload').classList.remove('hidden');
            setTimeout(() => document.getElementById('modal-upload').querySelector('div').classList.remove('scale-95'), 10);
        }

        function closeUploadModal() {
            document.getElementById('modal-upload').querySelector('div').classList.add('scale-95');
            setTimeout(() => document.getElementById('modal-upload').classList.add('hidden'), 200);
        }

        function validateForm() {
            const numero = document.getElementById('nf-numero').value;
            const data = document.getElementById('nf-data-emissao').value;
            const emitente = document.getElementById('nf-emitente').value;
            const cnpjE = document.getElementById('cnpj-emissor').value;
            const cnpjR = document.getElementById('cnpj-receptor').value;
            const valor = document.getElementById('nf-valor').value;
            const file = document.getElementById('nf-file').files[0];
            const isValid = numero && data && emitente && cnpjE && cnpjR && valor && parseFloat(valor) > 0 && file;
            document.getElementById('btn-process-upload').disabled = !isValid;
        }

        let isManualFill = false;

        async function analyzeFile(input) {
            if (!input.files[0]) return;
            const loader = document.getElementById('analyze-loader');
            loader.classList.remove('hidden');
            isManualFill = false;
            const formData = new FormData();
            formData.append('file', input.files[0]);
            try {
                const res = await fetch('/api/billing/analyze', { method: 'POST', body: formData });
                const result = await res.json();
                if (result.success && result.data) {
                    const d = result.data;
                    const mapping = { 'nf-numero': d.numeroNota, 'nf-data-emissao': d.dataEmissao, 'nf-emitente': d.nomeEmitente, 'cnpj-emissor': d.cnpjEmissor, 'cnpj-receptor': d.cnpjReceptor, 'nf-valor': d.valorTotal };
                    
                    Object.keys(mapping).forEach(id => {
                        const el = document.getElementById(id);
                        let val = mapping[id];
                        
                        // Verifica se é nulo, undefined, string "null", string "n/a" ou vazio
                        const isNullString = typeof val === 'string' && (val.toLowerCase() === 'null' || val.toLowerCase() === 'n/a' || val.trim() === '');
                        const isInvalidValue = !val || isNullString;
                        const isInvalidPrice = id === 'nf-valor' && (parseFloat(val) <= 0 || isNaN(parseFloat(val)));
                        
                        const isInvalid = isInvalidValue || isInvalidPrice;
                        
                        console.log(`[IA Analysis] Field: ${id}, Value: ${val}, isInvalid: ${isInvalid}`);

                        el.classList.remove('border-teal-500', 'bg-teal-50/30');
                        
                        if (!isInvalid) {
                            el.value = val; 
                            el.disabled = true;
                            el.classList.add('border-teal-500', 'bg-teal-50/30');
                        } else {
                            if (id !== 'nf-valor') el.value = '';
                            el.disabled = false; 
                            el.removeAttribute('disabled'); // Força a remoção do atributo
                            isManualFill = true; 
                            el.placeholder = "Preencha manualmente";
                        }
                    });
                } else { throw new Error("IA falhou"); }
            } catch (e) {
                isManualFill = true;
                ['nf-numero', 'nf-data-emissao', 'nf-emitente', 'cnpj-emissor', 'cnpj-receptor', 'nf-valor'].forEach(f => {
                    const el = document.getElementById(f);
                    el.disabled = false; 
                    el.classList.remove('border-teal-500', 'bg-teal-50/30');
                    el.placeholder = "Preencha manualmente";
                });
            } finally { loader.classList.add('hidden'); validateForm(); }
        }

        async function processUpload() {
            const btn = document.getElementById('btn-process-upload');
            const oldText = btn.innerText; btn.innerText = 'Enviando...'; btn.disabled = true;
            try {
                const formData = new FormData();
                formData.append('file', document.getElementById('nf-file').files[0]);
                formData.append('periodId', document.getElementById('upload-period-id').value);
                formData.append('valor', document.getElementById('nf-valor').value);
                formData.append('cnpjEmissor', document.getElementById('cnpj-emissor').value);
                formData.append('cnpjReceptor', document.getElementById('cnpj-receptor').value);
                formData.append('numeroNota', document.getElementById('nf-numero').value);
                formData.append('dataEmissao', document.getElementById('nf-data-emissao').value);
                formData.append('nomeEmitente', document.getElementById('nf-emitente').value);
                formData.append('preenchimento', isManualFill ? 'Manual' : 'Automático');
                
                const res = await fetch('/api/billing/upload', { method: 'POST', body: formData });
                const result = await res.json();

                if (result.success) { 
                    showToast('Sucesso!', 'Nota Fiscal enviada com sucesso.');
                    closeUploadModal(); 
                    loadPeriods(); 
                } else { 
                    showToast('Erro no Envio', result.error || 'Não foi possível enviar a nota.', 'error');
                }
            } catch(e) { 
                console.error(e); 
                showToast('Erro Crítico', 'Falha ao processar o upload.', 'error');
            } finally { btn.innerText = oldText; btn.disabled = false; validateForm(); }
        }
    </script>
</body>
</html>
