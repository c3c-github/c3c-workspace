        function calculateBillingTotals() {
            let total = 0;
            document.querySelectorAll('.billing-row').forEach(tr => {
                total += parseFloat(tr.dataset.value || 0);
            });
            const totalEl = document.getElementById('billing-total-value');
            if(totalEl) totalEl.innerHTML = moneyValue(total);
