            if(targetView) targetView.classList.remove('hidden'); 
            if(targetTab) targetTab.className = 'modal-tab-active py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all';

            // Lazy Load para as abas que não são "Geral" ou "Anexos"
