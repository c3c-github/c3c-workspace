<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mesa de Ops - C3C Workspace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { 
                        c3c: { 
                            blue: '#2978FF', 
                            teal: '#1DDDBD', 
                            gray: '#F2F2F2',
                            dark: '#000000'
                        } 
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .bg-c3c-gradient { background: transparent linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%) 0% 0% no-repeat padding-box; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
        .tab-active { color: #2978FF; border-bottom: 4px solid #2978FF; }
        
        .path-container { display: flex; width: 100%; border-radius: 24px; overflow: hidden; border: 1px solid #F1F5F9; background: #F8FAFC; gap: 6px; padding: 6px; }
        .path-step { flex: 1; text-align: center; padding: 14px 4px; font-size: 10px; font-weight: 900; color: #94A3B8; cursor: pointer; transition: all 0.2s; border-radius: 18px; text-transform: uppercase; letter-spacing: 0.1em; }
        .path-step.active { background: #2978FF; color: white; box-shadow: 0 8px 20px rgba(41, 120, 255, 0.25); }
        .path-step.completed { background: #1DDDBD; color: white; }
        .path-step:hover:not(.active):not(.completed) { background: #E2E8F0; color: #475569; }

        .timer-active { animation: pulse-timer 2s infinite; }
        @keyframes pulse-timer { 0% { box-shadow: 0 0 0 0 rgba(41, 120, 255, 0.4); } 70% { box-shadow: 0 0 0 15px rgba(41, 120, 255, 0); } 100% { box-shadow: 0 0 0 0 rgba(41, 120, 255, 0); } }
    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#F8FAFC]">

    <div id="loading-overlay" class="fixed inset-0 bg-white/80 backdrop-blur-sm z-[200] hidden flex flex-col items-center justify-center">
        <div class="w-12 h-12 border-4 border-blue-100 border-t-c3c-blue rounded-full animate-spin mb-4"></div>
        <p class="text-[10px] font-black text-c3c-blue uppercase tracking-widest animate-pulse">Workspace em sincronia...</p>
    </div>

    <%- include('partials/sidebar', { page: 'operations' }) %>

    <!-- VIEW: LISTA (FULL WIDTH) -->
    <main id="main-list-view" class="flex-1 flex flex-col md:ml-64 relative w-full transition-all duration-300 overflow-hidden text-left">
        
        <!-- HEADER LISTA -->
        <header class="h-20 bg-white border-b border-gray-100 flex items-center justify-between px-8 sticky top-0 z-20 shrink-0">
            <div class="flex items-center gap-4">
                <button onclick="document.getElementById('sidebar').classList.toggle('-translate-x-full')" class="md:hidden p-2 text-gray-600 hover:bg-gray-100 rounded-lg"><i data-lucide="menu"></i></button>
                <div class="text-left">
                    <h1 class="text-xl font-black text-gray-800 flex items-center gap-3 tracking-tighter uppercase leading-tight">Mesa de Operações <span class="text-c3c-blue">⚙️</span></h1>
                    <p class="text-[9px] text-gray-400 font-black uppercase tracking-[0.3em] mt-1 hidden sm:block">Central de Atendimento Workspace</p>
                </div>
            </div>
            <button onclick="openNewTicketModal()" class="bg-c3c-gradient text-white text-[10px] font-black uppercase tracking-[0.2em] px-8 py-3.5 rounded-full shadow-xl shadow-blue-100 hover:opacity-90 transition-all active:scale-95 flex items-center gap-3"><i data-lucide="plus" class="w-4 h-4"></i> Novo Chamado</button>
        </header>

        <!-- CONTEÚDO LISTA -->
        <div class="flex-1 overflow-y-auto p-8 custom-scrollbar">
            
            <!-- DASHBOARD OPERACIONAL -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
                <div onclick="changeFilter('queue')" class="bg-white p-8 rounded-[40px] border border-gray-100 shadow-sm flex flex-col justify-between hover:shadow-xl hover:border-blue-100 transition-all group cursor-pointer text-left">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-3 bg-blue-50 text-c3c-blue rounded-2xl group-hover:scale-110 transition-transform"><i data-lucide="inbox"></i></div>
                        <span class="text-3xl font-black text-gray-800 tabular-nums" id="stat-total">0</span>
                    </div>
                    <div>
                        <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Fila em Aberto</span>
                        <p class="text-[8px] font-bold text-gray-300 uppercase mt-1">Chamados sem atuação do time</p>
                    </div>
                </div>
                <div onclick="filterCriticalOnly()" class="bg-white p-8 rounded-[40px] border border-gray-100 shadow-sm flex flex-col justify-between hover:shadow-xl hover:border-red-100 transition-all group cursor-pointer border-red-50 text-left">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-3 bg-red-50 text-red-500 rounded-2xl group-hover:scale-110 transition-transform"><i data-lucide="alert-triangle"></i></div>
                        <span class="text-3xl font-black text-red-600 tabular-nums" id="stat-urgent">0</span>
                    </div>
                    <div>
                        <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Críticos na Fila</span>
                        <p class="text-[8px] font-bold text-gray-300 uppercase mt-1">Alta prioridade sem dono</p>
                    </div>
                </div>
                <div onclick="changeFilter('my')" class="bg-white p-8 rounded-[40px] border border-gray-100 shadow-sm flex flex-col justify-between hover:shadow-xl hover:border-teal-100 transition-all group cursor-pointer text-left">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-3 bg-teal-50 text-teal-500 rounded-2xl group-hover:scale-110 transition-transform"><i data-lucide="user-check"></i></div>
                        <span class="text-3xl font-black text-teal-600 tabular-nums" id="stat-my">0</span>
                    </div>
                    <div>
                        <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Meus Atendimentos</span>
                        <p class="text-[8px] font-bold text-gray-300 uppercase mt-1">Tickets sob sua responsabilidade</p>
                    </div>
                </div>
                <div class="bg-c3c-gradient p-8 rounded-[40px] shadow-2xl shadow-blue-100 flex flex-col justify-center text-white relative overflow-hidden group text-left">
                    <div class="relative z-10">
                        <span class="text-[10px] font-black uppercase tracking-widest opacity-80 mb-2 block">Tempo de Resposta</span>
                        <p class="text-2xl font-black tracking-tighter" id="stat-sla">100% SLA</p>
                    </div>
                    <i data-lucide="zap" class="absolute right-[-10px] bottom-[-10px] w-32 h-32 opacity-10"></i>
                </div>
            </div>

            <!-- FILTROS E PESQUISA INTEGRADA -->
            <div class="bg-white rounded-[48px] border border-gray-100 shadow-sm overflow-hidden flex flex-col">
                <div class="px-8 py-6 border-b border-gray-50 flex flex-col lg:flex-row justify-between items-center gap-6 bg-gray-50/30">
                    <div class="flex flex-wrap gap-2 p-1.5 bg-white rounded-[20px] border border-gray-100 shadow-sm w-full lg:w-auto">
                        <button onclick="changeFilter('my')" id="tab-my" class="px-8 py-3 text-[10px] font-black uppercase tracking-widest rounded-[14px] transition-all bg-c3c-blue text-white shadow-lg shadow-blue-100">Meus</button>
                        <button onclick="changeFilter('queue')" id="tab-queue" class="px-8 py-3 text-[10px] font-black uppercase tracking-widest rounded-[14px] text-gray-400 hover:text-gray-600 transition-all">Fila</button>
                        <button onclick="changeFilter('team')" id="tab-team" class="px-8 py-3 text-[10px] font-black uppercase tracking-widest rounded-[14px] text-gray-400 hover:text-gray-600 transition-all">Equipe</button>
                        <button onclick="changeFilter('all')" id="tab-all" class="px-8 py-3 text-[10px] font-black uppercase tracking-widest rounded-[14px] text-gray-400 hover:text-gray-600 transition-all">Todos</button>
                    </div>

                    <div class="relative group w-full lg:w-96">
                        <i data-lucide="search" class="w-4 h-4 text-gray-300 absolute left-5 top-1/2 -translate-y-1/2 group-focus-within:text-c3c-blue transition-colors"></i>
                        <input type="text" id="search-tickets-input" placeholder="Buscar por número, título ou cliente..." class="w-full pl-12 pr-6 py-3.5 bg-white border-2 border-gray-100 rounded-full text-xs font-black focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all shadow-sm">
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] border-b border-gray-50">
                                <th class="px-10 py-6">Ticket</th>
                                <th class="px-6 py-6">Cliente</th>
                                <th class="px-6 py-6">Assunto</th>
                                <th class="px-6 py-6 text-center">Status</th>
                                <th class="px-6 py-6 text-center">Data / SLA</th>
                                <th class="px-10 py-6 text-right">Ação</th>
                            </tr>
                        </thead>
                        <tbody id="tickets-table-body" class="divide-y divide-gray-50"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- VIEW: DETALHES -->
    <main id="main-detail-view" class="flex-1 flex flex-col md:ml-64 relative w-full transition-all duration-300 overflow-hidden hidden text-left">
        <header class="h-24 bg-white border-b border-gray-100 flex items-center justify-between px-10 sticky top-0 z-20 shrink-0">
            <div class="flex items-center gap-6">
                <button onclick="closeTicketDetails()" class="p-4 bg-gray-50 text-gray-400 hover:text-c3c-blue rounded-3xl transition-all active:scale-90"><i data-lucide="arrow-left" class="w-6 h-6"></i></button>
                <div class="text-left">
                    <div class="flex items-center gap-3 mb-1">
                        <span class="text-[10px] font-black text-gray-400 tracking-widest uppercase" id="detail-number">#0000</span>
                        <div class="w-1 h-1 bg-gray-200 rounded-full"></div>
                        <span class="text-[10px] font-black text-c3c-blue uppercase tracking-widest" id="detail-client">CLIENTE</span>
                    </div>
                    <h1 class="text-2xl font-black text-gray-800 tracking-tighter uppercase truncate max-w-[600px]" id="detail-title">...</h1>
                </div>
            </div>

            <div class="flex items-center gap-6">
                <div class="flex items-center bg-gray-50 border border-gray-100 rounded-[24px] px-6 py-3 transition-all" id="timer-container">
                    <div class="text-2xl font-black text-gray-800 mr-6 w-32 text-center tabular-nums" id="global-timer">00:00:00</div>
                    <div class="flex gap-2">
                        <button id="global-play" onclick="startGlobalTimer()" class="p-3 bg-teal-500 hover:bg-teal-600 text-white rounded-2xl shadow-lg transition-all active:scale-95 disabled:opacity-30 flex items-center gap-2 px-4">
                            <i data-lucide="play" class="w-4 h-4 fill-current"></i>
                            <span class="text-[9px] font-black uppercase tracking-widest">Iniciar</span>
                        </button>
                        <button id="global-stop" onclick="stopGlobalTimer()" class="hidden p-3 bg-red-500 hover:bg-red-600 text-white rounded-2xl shadow-lg transition-all active:scale-95 flex items-center gap-2 px-4">
                            <i data-lucide="square" class="w-4 h-4 fill-current"></i>
                            <span class="text-[9px] font-black uppercase tracking-widest">Pausar</span>
                        </button>
                    </div>
                </div>
                <div id="header-actions" class="flex gap-3"></div>
            </div>
        </header>

        <div class="flex-1 overflow-hidden flex flex-col">
            <div class="flex px-10 border-b border-gray-100 bg-white gap-12 shrink-0">
                <div onclick="switchDetailTab('info')" id="dt-info" class="hidden"></div>
                <button onclick="switchDetailTab('info')" id="dt-info-btn" class="pb-6 pt-8 text-[11px] font-black uppercase tracking-[0.2em] tab-active whitespace-nowrap">Central de Atuação</button>
                <button onclick="switchDetailTab('logs')" id="dt-logs" class="pb-6 pt-8 text-[11px] font-black uppercase tracking-[0.2em] text-gray-400 hover:text-gray-600 transition-all whitespace-nowrap">Extrato de Horas</button>
                <button onclick="switchDetailTab('attach')" id="dt-attach" class="pb-6 pt-8 text-[11px] font-black uppercase tracking-[0.2em] text-gray-400 hover:text-gray-600 transition-all whitespace-nowrap">Anexos & Evidências</button>
            </div>

            <div class="flex-1 overflow-y-auto p-10 custom-scrollbar bg-gray-50/30 text-left">
                <div id="status-path-container" class="mb-10 max-w-5xl mx-auto"></div>

                <div id="view-info" class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-10 fade-in">
                    <div class="lg:col-span-2 space-y-10">
                        <div class="bg-white p-12 rounded-[48px] border border-gray-100 shadow-sm text-left relative overflow-hidden">
                            <div class="absolute top-0 left-0 w-2 h-full bg-c3c-blue"></div>
                            <h4 class="text-[11px] font-black text-gray-400 uppercase tracking-[0.2em] mb-8">Detalhamento do Chamado</h4>
                            <div class="text-base text-gray-700 leading-relaxed font-medium whitespace-pre-wrap" id="detail-desc">...</div>
                        </div>

                        <div class="grid grid-cols-2 gap-8">
                            <div class="bg-white p-8 rounded-[40px] border border-gray-100 shadow-sm text-left">
                                <h4 class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-6">Informações</h4>
                                <div class="space-y-4">
                                    <div class="flex justify-between"><span class="text-[10px] font-black text-gray-300 uppercase">Prioridade</span><span class="text-xs font-black text-gray-800" id="info-prio">-</span></div>
                                    <div class="flex justify-between"><span class="text-[10px] font-black text-gray-300 uppercase">Tipo</span><span class="text-xs font-black text-gray-800" id="info-type">-</span></div>
                                    <div class="flex justify-between"><span class="text-[10px] font-black text-gray-300 uppercase">Origem</span><span class="text-xs font-black text-gray-800" id="info-origin">-</span></div>
                                </div>
                            </div>
                            <div class="bg-white p-8 rounded-[40px] border border-gray-100 shadow-sm text-left">
                                <h4 class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-6">Prazos</h4>
                                <div class="space-y-4">
                                    <div class="flex justify-between"><span class="text-[10px] font-black text-gray-300 uppercase">Abertura</span><span class="text-xs font-black text-gray-800" id="ts-open">-</span></div>
                                    <div class="flex justify-between"><span class="text-[10px] font-black text-red-400 uppercase">Expectativa Cliente</span><span class="text-xs font-black text-red-500" id="ts-expect">-</span></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <!-- DESTAQUE: PREVISÃO DE ENTREGA -->
                        <div class="bg-white p-6 rounded-[32px] border border-gray-100 shadow-sm relative overflow-hidden group">
                            <div class="absolute top-0 left-0 w-1 h-full bg-c3c-blue"></div>
                            <div class="flex justify-between items-center mb-4 px-1">
                                <h4 class="text-[9px] font-black text-gray-400 uppercase tracking-[0.2em]">Previsão de Entrega</h4>
                                <span class="text-[8px] font-black text-red-500 uppercase flex items-center gap-1"><div class="w-1 h-1 bg-red-500 rounded-full animate-pulse"></div> Obrigatório</span>
                            </div>
                            
                            <div class="flex items-center gap-2">
                                <div class="relative flex-1">
                                    <input type="date" id="edit-estimation" class="w-full bg-gray-50 border-2 border-gray-100 rounded-[16px] px-4 py-3 text-xs font-black focus:ring-4 focus:ring-blue-50 focus:bg-white transition-all outline-none text-gray-800">
                                </div>
                                <button onclick="saveTicketUpdates()" id="btn-save-estimation" title="Salvar Previsão" class="p-3.5 bg-gray-800 hover:bg-black text-white rounded-[16px] shadow-lg transition-all active:scale-90 shrink-0">
                                    <i data-lucide="save" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </div>

                        <!-- CHAT COM CLIENTE -->
                        <div class="bg-white p-10 rounded-[48px] border border-gray-100 shadow-sm flex flex-col h-[500px] text-left">
                            <h4 class="text-[11px] font-black text-gray-400 uppercase tracking-[0.2em] mb-8 px-2">Interação com Cliente</h4>
                            <div id="comments-list" class="flex-1 space-y-6 overflow-y-auto custom-scrollbar pr-4 mb-8"></div>
                            <div class="pt-8 border-t border-gray-50 flex gap-4">
                                <input type="text" id="quick-comment" placeholder="Enviar mensagem..." class="flex-1 bg-gray-50 border-2 border-gray-100 rounded-[24px] px-6 py-4 text-xs font-black outline-none focus:ring-4 focus:ring-blue-50 focus:bg-white transition-all">
                                <button onclick="postComment()" class="p-5 bg-blue-50 text-c3c-blue rounded-[24px] hover:bg-c3c-blue hover:text-white transition-all active:scale-90 shadow-sm"><i data-lucide="send" class="w-5 h-5"></i></button>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="view-logs" class="hidden fade-in space-y-10 max-w-7xl mx-auto text-left text-left"><div class="bg-white rounded-[48px] shadow-sm border border-gray-100 overflow-hidden text-left"><table class="w-full text-left"><thead class="bg-gray-50/50 border-b border-gray-100"><tr class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]"><th class="px-10 py-6">Data</th><th class="px-8 py-6">Recurso</th><th class="px-8 py-6">Atividade</th><th class="px-8 py-6 text-center">Status</th><th class="px-6 py-6 text-center">Horas</th><th class="px-10 py-6 text-center">Ações</th></tr></thead><tbody id="logs-table-body" class="divide-y divide-gray-50"></tbody></table></div></div>
                <div id="view-attach" class="hidden fade-in space-y-10 max-w-5xl mx-auto text-left text-left">
                    <div class="bg-blue-50/20 p-16 border-4 border-dashed border-blue-100 rounded-[60px] text-center group relative hover:border-c3c-blue transition-all">
                        <input type="file" id="attach-new-file" multiple onchange="uploadFiles(activeTicketId)" class="absolute inset-0 opacity-0 cursor-pointer z-10">
                        <div class="w-24 h-24 bg-white rounded-[32px] shadow-xl text-c3c-blue flex items-center justify-center mx-auto mb-8 group-hover:scale-110 transition-transform"><i data-lucide="cloud-upload" class="w-10 h-10"></i></div>
                        <p class="text-lg font-black text-gray-800 uppercase tracking-[0.2em]">Dropzone Digital</p>
                        <p class="text-xs font-bold text-gray-400 uppercase mt-2 tracking-widest text-center">Selecione arquivos de evidência ou arraste aqui</p>
                    </div>
                    <div id="attach-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"></div>
                </div>
            </div>
        </div>
    </main>

    <!-- MODAL NOVO CHAMADO -->
    <div id="new-ticket-modal" class="fixed inset-0 bg-black/80 backdrop-blur-2xl hidden z-[300] flex items-center justify-center p-4">
        <div class="bg-white rounded-[60px] shadow-2xl w-full max-w-5xl overflow-hidden transform scale-95 transition-all flex flex-col max-h-[95vh] text-left text-left">
            <header class="p-12 border-b border-gray-100 bg-gray-50/50 flex justify-between items-center shrink-0">
                <div class="text-left text-left"><h3 class="text-4xl font-black text-gray-800 tracking-tighter uppercase leading-tight">Novo Chamado</h3><p class="text-[10px] font-black text-c3c-blue uppercase tracking-[0.3em] mt-3">Campos com (*) são obrigatórios</p></div>
                <button onclick="closeModal('new-ticket-modal')" class="p-5 text-gray-400 hover:bg-white hover:text-red-500 rounded-full transition-all"><i data-lucide="x" class="w-8 h-8"></i></button>
            </header>
            <div class="p-12 overflow-y-auto custom-scrollbar flex-1 bg-white text-left">
                <form id="form-create-ticket" class="space-y-12">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div><label class="block text-[11px] font-black text-gray-400 uppercase mb-4 tracking-widest px-4">Serviço <span class="text-red-500">*</span></label><select id="new-service" onchange="onServiceChange()" required class="w-full bg-gray-50 border-2 border-gray-100 rounded-[24px] px-8 py-5 text-sm font-black focus:ring-4 focus:ring-blue-50 outline-none cursor-pointer"><option value="">Selecione...</option></select><input type="hidden" id="new-account-id"></div>
                        <div><label class="block text-[11px] font-black text-gray-400 uppercase mb-4 tracking-widest px-4 flex justify-between">Contato <span class="text-red-500">*</span> <button type="button" onclick="toggleContactMode()" class="text-c3c-blue font-bold lowercase hover:underline">+ novo contato</button></label><div id="contact-select-mode"><select id="new-contact" disabled required class="w-full bg-gray-50 border-2 border-gray-100 rounded-[24px] px-8 py-5 text-sm font-black focus:ring-4 focus:ring-blue-50 outline-none disabled:opacity-50"><option value="">Selecione o serviço...</option></select></div><div id="contact-create-mode" class="hidden space-y-4 p-6 bg-blue-50/30 rounded-[32px] border border-blue-100/50 text-left"><input type="text" id="new-contact-name" placeholder="Nome Completo *" class="w-full bg-white border-2 border-gray-100 rounded-[16px] px-6 py-4 text-xs font-black outline-none"><input type="email" id="new-contact-email" placeholder="E-mail *" class="w-full bg-white border-2 border-gray-100 rounded-[16px] px-6 py-4 text-xs font-black outline-none"><div class="flex gap-3"><input type="text" id="new-contact-mobile" placeholder="Celular (Opcional)" class="flex-1 bg-white border-2 border-gray-100 rounded-[16px] px-6 py-4 text-xs font-black outline-none"><button type="button" onclick="saveNewContact()" class="px-6 bg-teal-500 text-white rounded-2xl hover:bg-teal-600 shadow-lg transition-all"><i data-lucide="check"></i></button><button type="button" onclick="toggleContactMode()" class="px-6 bg-gray-100 text-gray-400 rounded-2xl hover:bg-gray-200 transition-all"><i data-lucide="x"></i></button></div></div></div>
                    </div>
                    <div><label class="block text-[11px] font-black text-gray-400 uppercase mb-4 tracking-widest px-4">Assunto do Chamado <span class="text-red-500">*</span></label><input type="text" id="new-subject" required placeholder="Título claro..." class="w-full bg-gray-50 border-2 border-gray-100 rounded-[24px] px-8 py-5 text-sm font-black focus:ring-4 focus:ring-blue-50 outline-none"></div>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-left">
                        <div><label class="block text-[11px] font-black text-gray-400 uppercase mb-4 tracking-widest px-2">Criticidade <span class="text-red-500">*</span></label><select id="new-priority" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-5 py-4 text-[10px] font-black uppercase outline-none focus:ring-2 focus:ring-blue-100"><option value="Low">Baixa</option><option value="Medium" selected>Média</option><option value="High">Alta</option><option value="Critical">Crítica</option></select></div>
                        <div><label class="block text-[11px] font-black text-gray-400 uppercase mb-4 tracking-widest px-2">Tipo <span class="text-red-500">*</span></label><select id="new-type" required onchange="updateDescriptionTemplate()" class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-5 py-4 text-[10px] font-black uppercase outline-none focus:ring-2 focus:ring-blue-100"><option value="Bug">Bug</option><option value="Melhoria" selected>Melhoria</option><option value="Dúvida">Dúvida</option><option value="Outros">Outros</option></select></div>
                        <div><label class="block text-[11px] font-black text-gray-400 uppercase mb-4 tracking-widest px-2">Origem <span class="text-red-500">*</span></label><select id="new-origin" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-5 py-4 text-[10px] font-black uppercase outline-none focus:ring-2 focus:ring-blue-100"><option value="Email">E-mail</option><option value="Phone">Telefone</option><option value="Web" selected>Portal</option><option value="Chat">Chat</option></select></div>
                        <div><label class="block text-[11px] font-black text-gray-400 uppercase mb-4 tracking-widest px-2">Expectativa <span class="text-red-500">*</span></label><input type="date" id="new-expectation" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-5 py-4 text-[10px] font-black outline-none focus:ring-2 focus:ring-blue-100"></div>
                    </div>
                    <div><label class="block text-[11px] font-black text-gray-400 uppercase mb-4 tracking-widest px-4">Descrição Detalhada <span class="text-red-500">*</span></label><textarea id="new-desc" required rows="6" class="w-full bg-gray-50 border-2 border-gray-100 rounded-[40px] p-10 text-sm font-medium focus:ring-4 focus:ring-blue-50 outline-none resize-none" placeholder="Detalhes técnicos..."></textarea></div>
                    <div class="bg-blue-50/10 p-8 border-2 border-dashed border-blue-100 rounded-[40px] text-center group relative hover:border-c3c-blue transition-all">
                        <input type="file" id="new-files" multiple onchange="handleNewTicketFiles(this)" class="absolute inset-0 opacity-0 cursor-pointer z-10">
                        <div class="w-12 h-12 bg-white rounded-[16px] shadow-sm text-c3c-blue flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform"><i data-lucide="paperclip" class="w-5 h-5"></i></div>
                        <p class="text-[10px] font-black text-gray-800 uppercase tracking-widest">Anexar Evidências</p>
                    </div>
                    <!-- ÁREA DE GESTÃO DE ANEXOS -->
                    <div id="new-files-preview" class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-4"></div>
                </form>
            </div>
            <footer class="p-12 border-t border-gray-100 bg-gray-50/50 flex justify-between items-center shrink-0">
                <label class="flex items-center gap-4 cursor-pointer group bg-white px-8 py-4 rounded-3xl border border-gray-100 shadow-sm text-left"><input type="checkbox" id="new-assign" checked class="w-6 h-6 rounded-xl border-2 border-gray-200 text-teal-500 focus:ring-teal-100"><span class="text-xs font-black text-gray-500 uppercase tracking-widest group-hover:text-gray-800 transition-colors">Assumir este Chamado</span></label>
                <div class="flex gap-6"><button onclick="closeModal('new-ticket-modal')" class="px-10 py-5 text-gray-400 font-black uppercase tracking-[0.3em] hover:text-gray-600 transition-all text-left">Cancelar</button><button onclick="submitNewTicket()" class="px-16 py-6 bg-c3c-gradient text-white font-black uppercase text-xs tracking-[0.3em] rounded-[32px] shadow-2xl hover:opacity-90 active:scale-95 transition-all text-left">Criar Chamado</button></div>
            </footer>
        </div>
    </div>

    <!-- MODAL APONTAMENTO -->
    <div id="time-modal" class="fixed inset-0 bg-black/80 backdrop-blur-md hidden z-[400] flex items-center justify-center p-4">
        <div class="bg-white rounded-[60px] shadow-2xl w-full max-w-md p-12 text-center transform scale-95 transition-all flex flex-col items-center">
            <div class="w-24 h-24 bg-blue-50 rounded-[32px] flex items-center justify-center mb-8 text-c3c-blue shadow-inner group transition-transform hover:scale-110"><i data-lucide="clock" class="w-12 h-12"></i></div>
            <h3 class="text-3xl font-black text-gray-800 tracking-tighter uppercase mb-2">Apontar Jornada</h3>
            <p id="lock-warning" class="text-[10px] font-black text-red-500 bg-red-50 px-4 py-1.5 rounded-full border border-red-100 uppercase tracking-widest mb-8 hidden"></p>
            <input type="hidden" id="modal-log-id">
            <div class="w-full space-y-8 text-left">
                <div class="grid grid-cols-2 gap-6">
                    <div><label class="block text-[9px] font-black text-gray-400 uppercase mb-3 tracking-widest px-3">Data</label><input type="date" id="modal-date" onchange="fetchLimits()" class="w-full bg-gray-50 border-2 border-gray-100 rounded-[20px] px-6 py-4 text-xs font-black outline-none focus:ring-4 focus:ring-blue-50 transition-all"></div>
                    <div><label class="block text-[9px] font-black text-gray-400 uppercase mb-3 tracking-widest px-3">Atividade</label><select id="modal-activity-select" onchange="toggleNewActivityInput()" class="w-full bg-gray-50 border-2 border-gray-100 rounded-[20px] px-6 py-4 text-xs font-black outline-none focus:ring-4 focus:ring-blue-50 transition-all"></select><input type="text" id="modal-new-activity-name" placeholder="Nome da Atividade..." class="w-full mt-3 bg-gray-50 border-2 border-gray-100 rounded-xl px-5 py-3 text-xs font-black hidden"></div>
                </div>
                <div class="grid grid-cols-2 gap-6">
                    <div class="relative"><label class="block text-[10px] font-black text-teal-600 uppercase mb-3 tracking-widest px-3 text-center">Normais</label><input type="number" id="modal-hours-normal" step="0.5" onchange="formatHours(this)" placeholder="0.0" class="w-full bg-white border-2 border-gray-100 rounded-[24px] px-6 py-5 text-2xl font-black text-gray-800 outline-none focus:ring-4 focus:ring-teal-100 text-center"></div>
                    <div class="relative"><label class="block text-[10px] font-black text-orange-500 uppercase mb-3 tracking-widest px-3 flex justify-between">Extra <i data-lucide="lock" class="w-4 h-4" id="icon-lock-extra"></i></label><input type="number" id="modal-hours-extra" step="0.5" onchange="formatHours(this)" placeholder="0.0" disabled class="w-full bg-gray-50 border-2 border-gray-100 rounded-[24px] px-6 py-5 text-2xl font-black text-gray-400 outline-none focus:ring-4 focus:ring-orange-100 text-center"></div>
                </div>
                <div class="bg-gray-50 p-6 rounded-[32px] border border-gray-100 flex justify-around items-center"><div class="flex flex-col"><span class="text-[9px] font-black text-gray-400 uppercase tracking-widest text-left">Utilizado Dia</span><span id="val-used" class="text-sm font-black text-gray-800 tabular-nums">0.0h</span></div><div class="w-px h-8 bg-gray-200"></div><div class="flex flex-col"><span class="text-[9px] font-black text-gray-400 uppercase tracking-widest text-left text-left">Saldo Contrato</span><span id="val-saldo" class="text-sm font-black text-teal-600 tabular-nums">8.0h</span></div></div>
                <div id="justification-container" class="text-left hidden">
                    <label class="block text-[10px] font-black text-gray-400 uppercase mb-3 tracking-widest px-3 flex justify-between">Justificativa Interna <span class="text-red-500 font-bold">* obrigatória p/ extras</span></label>
                    <textarea id="modal-desc" rows="3" class="w-full bg-gray-50 border-2 border-gray-100 rounded-[32px] p-6 text-xs font-medium outline-none focus:ring-4 focus:ring-blue-50 transition-all resize-none placeholder:text-gray-300" placeholder="Descreva o motivo das horas extras..."></textarea>
                </div>
            </div>
            <div class="flex gap-6 w-full mt-12"><button onclick="closeModal('time-modal')" class="flex-1 py-5 text-gray-400 font-black uppercase text-[11px] tracking-[0.2em] hover:text-gray-600 transition-all">Voltar</button><button id="btn-save-log" onclick="saveLog()" class="flex-[2] py-5 bg-c3c-gradient text-white font-black uppercase text-xs tracking-[0.2em] rounded-[24px] shadow-2xl active:scale-95 transition-all">Confirmar Lançamento</button></div>
        </div>
    </div>

    <script>
        lucide.createIcons();
        function areIdsEqual(id1, id2) {
            if (!id1 || !id2) return false;
            const s1 = String(id1), s2 = String(id2);
            if (s1 === s2) return true;
            return s1.substring(0, 15) === s2.substring(0, 15);
        }
        let activeTicketId = null, ticketsCache = [], currentFilter = 'my', createOptionsCache = [], currentDayLimit = 0, currentDayUsed = 0, currentDayUsedExtra = 0, currentTicketData = null, newTicketFiles = [];
        let editingOriginalNormal = 0, editingOriginalExtra = 0, editingOriginalDate = '';
        
        function handleNewTicketFiles(input) {
            const files = Array.from(input.files);
            newTicketFiles = [...newTicketFiles, ...files];
            renderNewFilesPreview();
            input.value = ""; 
            const modalBody = document.querySelector('#new-ticket-modal .overflow-y-auto');
            if(modalBody) setTimeout(() => modalBody.scrollTo({ top: modalBody.scrollHeight, behavior: 'smooth' }), 100);
        }

        function renderNewFilesPreview() {
            const container = document.getElementById('new-files-preview');
            container.innerHTML = "";
            newTicketFiles.forEach((file, index) => {
                const size = (file.size / 1024).toFixed(1) + " KB";
                container.innerHTML += `
                    <div class="flex items-center justify-between p-4 bg-gray-50 border border-gray-100 rounded-2xl animate-in fade-in slide-in-from-bottom-2 duration-200">
                        <div class="flex items-center gap-3 overflow-hidden">
                            <div class="w-10 h-10 bg-white rounded-xl shadow-sm flex items-center justify-center text-c3c-blue shrink-0"><i data-lucide="file-text" class="w-5 h-5"></i></div>
                            <div class="truncate text-left">
                                <p class="text-[10px] font-black text-gray-800 uppercase truncate" title="${file.name}">${file.name}</p>
                                <p class="text-[8px] font-bold text-gray-400 uppercase mt-0.5">${size}</p>
                            </div>
                        </div>
                        <button type="button" onclick="removeFileFromNewTicket(${index})" class="p-2 text-gray-300 hover:text-red-500 transition-colors"><i data-lucide="x" class="w-4 h-4"></i></button>
                    </div>`;
            });
            lucide.createIcons();
        }

        function removeFileFromNewTicket(index) {
            newTicketFiles.splice(index, 1);
            renderNewFilesPreview();
        }
        function toggleLoading(show) { const el = document.getElementById('loading-overlay'); if(!el) return; if(show) el.classList.remove('hidden'); else el.classList.add('hidden'); }

        document.getElementById('search-tickets-input').addEventListener('input', (e) => {
            const t = e.target.value.toLowerCase();
            renderTable(ticketsCache.filter(x => x.title.toLowerCase().includes(t) || x.caseNumber.toLowerCase().includes(t) || x.client.toLowerCase().includes(t)));
        });

        function filterCriticalOnly() {
            changeFilter('queue').then(() => {
                const filtered = ticketsCache.filter(x => x.priority === 'High' || x.priority === 'Critical');
                renderTable(filtered);
                document.getElementById('tab-queue').className = 'px-8 py-3 text-[10px] font-black uppercase tracking-widest rounded-[14px] transition-all bg-red-500 text-white shadow-lg';
            });
        }

        async function changeFilter(type) {
            currentFilter = type;
            ['my','queue','team','all'].forEach(t => { 
                const b = document.getElementById(`tab-${t}`); 
                if(t===type) b.className = 'px-8 py-3 text-[10px] font-black uppercase tracking-widest rounded-[14px] transition-all bg-c3c-blue text-white shadow-lg';
                else b.className = 'px-8 py-3 text-[10px] font-black uppercase tracking-widest rounded-[14px] text-gray-400 hover:text-gray-600 transition-all';
            });
            const body = document.getElementById('tickets-table-body'); body.innerHTML = '<tr><td colspan="6" class="py-20 text-center text-left"><div class="w-10 h-10 border-4 border-blue-50 border-t-c3c-blue rounded-full animate-spin mx-auto"></div></td></tr>';
            try { 
                const res = await fetch(`/api/ops/tickets?filter=${type}`);
                const data = await res.json(); ticketsCache = data.tickets || []; renderTable(ticketsCache);
                if (data.stats) {
                    document.getElementById('stat-total').innerText = data.stats.totalInQueue;
                    document.getElementById('stat-urgent').innerText = data.stats.criticalInQueue;
                    document.getElementById('stat-my').innerText = data.stats.myActive;
                    document.getElementById('stat-sla').innerText = `${data.stats.slaPercent}% SLA`;
                }
            } catch(e) { body.innerHTML = '<tr><td colspan="6" class="text-center py-10 text-red-400 font-black uppercase text-left">Erro de conexão</td></tr>'; }
        }

        function renderTable(data) {
            const body = document.getElementById('tickets-table-body'); body.innerHTML = '';
            if(data.length === 0) return body.innerHTML = '<tr><td colspan="6" class="py-32 text-center opacity-30 text-left"><i data-lucide="inbox" class="w-12 h-12 mx-auto mb-4 text-left"></i><p class="text-[10px] font-black uppercase tracking-[0.3em] text-left">Vazio</p></td></tr>';
            data.forEach(t => {
                const isUrgent = t.priority === 'High' || t.priority === 'Critical';
                const prioLabel = isUrgent ? '<span class="bg-red-50 text-red-600 px-3 py-1 rounded-full text-[8px] font-black border border-red-100 ml-2">URGENTE</span>' : '';
                let actionBtn = '';
                if (currentFilter === 'queue' || (currentFilter === 'all' && !t.ownerName)) {
                    actionBtn = `<button onclick="pullTicket('${t.id}')" class="px-8 py-2.5 bg-c3c-blue text-white font-black text-[9px] uppercase tracking-widest rounded-xl hover:shadow-lg transition-all text-left">Puxar</button>`;
                } else if (currentFilter === 'all' && t.isClosed) {
                    actionBtn = `<button onclick="reopenAction('${t.id}')" class="px-8 py-2.5 bg-teal-500 text-white font-black text-[9px] uppercase tracking-widest rounded-xl hover:shadow-lg transition-all text-left">Reabrir</button>`;
                } else {
                    actionBtn = `<button onclick="loadTicketDetails('${t.id}')" class="px-8 py-2.5 bg-white border-2 border-blue-50 text-c3c-blue font-black text-[9px] uppercase tracking-widest rounded-xl hover:bg-c3c-blue hover:text-white transition-all text-left">Atuar</button>`;
                }
                body.innerHTML += `<tr class="hover:bg-gray-50/50 transition-all text-left"><td class="px-10 py-6 text-xs font-black text-gray-400 tracking-widest uppercase text-left">${t.caseNumber}</td><td class="px-6 py-6 text-left"><p class="text-xs font-black text-gray-800 uppercase tracking-tighter text-left">${t.client}</p></td><td class="px-6 py-6 text-sm font-black text-gray-700 max-w-md truncate text-left">${t.title} ${prioLabel}</td><td class="px-6 py-6 text-center text-left text-left"><span class="px-3 py-1 bg-white border border-gray-100 rounded-full text-[8px] font-black text-gray-500 uppercase text-left">${t.status}</span></td><td class="px-6 py-6 text-center text-[10px] font-black text-gray-400 uppercase text-left text-left">${t.date}</td><td class="px-10 py-6 text-right text-left text-left">${actionBtn}</td></tr>`;
            });
            lucide.createIcons();
        }

        async function pullTicket(id) { 
            if(!confirm("Assumir este chamado e iniciar atuação?")) return; 
            try { 
                toggleLoading(true); 
                const res = await fetch('/api/ops/tickets/assign', { 
                    method: 'POST', 
                    headers: {'Content-Type': 'application/json'}, 
                    body: JSON.stringify({ id }) 
                }); 

                if(res.ok) { 
                    // Atualiza o estado global antes de abrir
                    currentFilter = 'my';
                    await loadTicketDetails(id); 
                } else {
                    alert("Não foi possível assumir este chamado. Verifique se ele já possui um dono.");
                }
            } catch(e) { 
                console.error(e); 
                alert("Erro técnico ao puxar chamado.");
            } finally { 
                toggleLoading(false); 
            } 
        }
        async function reopenAction(id) { 
            if(!confirm("Reabrir e assumir este chamado para atuação?")) return; 
            try { 
                toggleLoading(true); 
                const res = await fetch('/api/ops/tickets/reopen', { 
                    method: 'POST', 
                    headers: {'Content-Type': 'application/json'}, 
                    body: JSON.stringify({ id }) 
                }); 
                
                if(res.ok) { 
                    currentFilter = 'my';
                    await loadTicketDetails(id); 
                } else {
                    alert("Não foi possível reabrir o chamado. Verifique as permissões.");
                }
            } catch(e) { 
                console.error(e); 
                alert("Erro técnico ao reabrir.");
            } finally { 
                toggleLoading(false); 
            } 
        }

        async function loadTicketDetails(id) {
            toggleLoading(true);
            try {
                const res = await fetch(`/api/ops/tickets/${id}/details`); 
                const det = await res.json(); 
                currentTicketData = det.ticket; 
                activeTicketId = id;

                // Troca as telas primeiro
                document.getElementById('main-list-view').classList.add('hidden'); 
                document.getElementById('main-detail-view').classList.remove('hidden');
                
                // Seta os valores com verificação
                const set = (id, val) => { const el = document.getElementById(id); if(el) el.innerText = val || '-'; };
                
                set('detail-number', currentTicketData.CaseNumber || id.substring(0,8));
                set('detail-client', currentTicketData.Account ? currentTicketData.Account.Name : 'CLIENTE');
                set('detail-title', currentTicketData.Subject);
                set('info-status', currentTicketData.Status); 
                set('info-prio', currentTicketData.Priority); 
                set('info-type', currentTicketData.Type); 
                set('info-origin', currentTicketData.Origin); 
                set('detail-desc', currentTicketData.Description);
                set('ts-open', formatDate(currentTicketData.CreatedDate)); 
                set('ts-expect', formatDate(currentTicketData.DataExpectativaCliente__c));

                // Popula campos de ajuste
                if(document.getElementById('edit-status')) document.getElementById('edit-status').value = currentTicketData.Status;
                if(document.getElementById('edit-priority')) document.getElementById('edit-priority').value = currentTicketData.Priority;
                if(document.getElementById('edit-estimation')) document.getElementById('edit-estimation').value = currentTicketData.DataEstimativaEntrega__c ? currentTicketData.DataEstimativaEntrega__c.split('T')[0] : '';

                renderStatusPath(currentTicketData.Status); 
                setupActions(); 
                switchDetailTab('info');
                
                renderLogs(det.logs); 
                renderComments(det.comments); 
                renderAttach(det.attachments);
            } catch(e) { 
                console.error(e); 
                alert("Erro ao carregar detalhes do chamado.");
            } finally { toggleLoading(false); }
        }

        function closeTicketDetails() { document.getElementById('main-detail-view').classList.add('hidden'); document.getElementById('main-list-view').classList.remove('hidden'); if(globalInterval) stopGlobalTimer(); changeFilter(currentFilter); }
        function formatDate(dt) { if(!dt) return '-'; const d = new Date(dt); return d.toLocaleDateString('pt-BR'); }
        function setupActions() {
            const acts = document.getElementById('header-actions'); 
            let btns = '';
            
            // Botão de lançamento manual sempre visível se for o dono
            const logBtn = `<button onclick="openLogModal(false)" class="bg-white border-2 border-blue-50 text-c3c-blue px-8 py-3 rounded-2xl text-[10px] font-black uppercase shadow-sm hover:bg-blue-50 transition-all flex items-center gap-3"><i data-lucide="plus" class="w-4 h-4"></i> Lançar Horas</button>`;
            
            if(currentFilter === 'my' || (currentTicketData && areIdsEqual(currentTicketData.Pessoa__c, '<%= user.id %>'))) {
                btns = `${logBtn}<button onclick="transferTicket('queue')" class="px-6 py-3 text-red-400 hover:text-red-600 text-[10px] font-black uppercase transition-all">Devolver para Fila</button>`;
                // Habilita os controles do Timer se for o dono
                document.getElementById('global-play').disabled = false;
            } else {
                btns = `<button onclick="assignTicket()" class="bg-c3c-gradient text-white px-10 py-4 rounded-2xl text-[10px] font-black uppercase shadow-2xl hover:opacity-90 active:scale-95 flex items-center gap-3"><i data-lucide="user-plus" class="w-4 h-4"></i> Assumir Chamado</button>`;
                // Desabilita o Timer se não for o dono
                document.getElementById('global-play').disabled = true;
            }
            acts.innerHTML = btns; 
            lucide.createIcons();
            
            const editTab = document.getElementById('dt-edit'); 
            if(editTab) { 
                if(currentFilter === 'my') editTab.classList.remove('hidden'); 
                else editTab.classList.add('hidden'); 
            }
        }

        function renderStatusPath(currentStatus) {
            const steps = ['New', 'In Progress', 'On Hold', 'Waiting', 'Closed']; let html = '<div class="path-container">';
            if (currentStatus === 'Closed') html = `<div class="w-full bg-teal-50 border border-teal-100 p-6 rounded-[32px] flex justify-between items-center shadow-sm text-left"><div class="flex items-center gap-4 text-left"><div class="w-12 h-12 bg-teal-500 rounded-full flex items-center justify-center text-white text-left text-left"><i data-lucide="check" class="w-8 h-8 text-left text-left"></i></div><div><span class="text-lg font-black text-teal-600 uppercase block leading-tight text-left">Ticket Encerrado</span><p class="text-[10px] font-black text-teal-400 uppercase mt-1 text-left text-left">Nenhum apontamento permitido</p></div></div><button onclick="reopenTicket()" class="bg-white text-teal-600 border-2 border-teal-100 text-[10px] font-black uppercase px-10 py-4 rounded-[20px] text-left">Reabrir</button></div>`;
            else { let passed = true; steps.forEach(s => { let cls = 'path-step'; if (s === currentStatus) { cls += ' active'; passed = false; } else if (passed) cls += ' completed'; html += `<div class="${cls}" onclick="updateStatus('${s}')">${s}</div>`; }); html += '</div>'; }
            document.getElementById('status-path-container').innerHTML = html; lucide.createIcons();
        }

        async function updateStatus(s) { 
            const estInput = document.getElementById('edit-estimation');
            if (s === 'Closed' && (!currentTicketData.DataEstimativaEntrega__c && (!estInput || !estInput.value))) {
                if(estInput) estInput.focus();
                return alert("Para finalizar o chamado, a Previsão de Entrega deve estar preenchida na lateral em destaque.");
            }
            try { toggleLoading(true); const r = await fetch('/api/ops/tickets/update', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ id: activeTicketId, status: s }) }); if(r.ok) { if(s==='Closed') closeTicketDetails(); else await loadTicketDetails(activeTicketId); } } catch(e) { console.error(e); } finally { toggleLoading(false); } 
        }
        async function reopenTicket() { try { toggleLoading(true); const r = await fetch('/api/ops/tickets/reopen', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ id: activeTicketId }) }); if(r.ok) loadTicketDetails(activeTicketId); } catch(e) { console.error(e); } finally { toggleLoading(false); } }
        function renderLogs(logs) { const tb = document.getElementById('logs-table-body'); tb.innerHTML = ''; logs.forEach(l => { let btns = `<span class="text-[9px] font-black text-gray-300 uppercase text-left text-left">${l.status || 'Draft'}</span>`; if (l.canEdit && currentTicketData.Status !== 'Closed') { btns = `<div class="flex items-center justify-center gap-4 text-left text-left"><button onclick="openEditLog('${l.id}','${l.rawDate}','${l.hoursNormal}','${l.hoursExtra}','${l.desc}')" class="text-blue-400 hover:text-c3c-blue transition-all text-left text-left text-left"><i data-lucide="pencil" class="w-4 h-4 text-left text-left text-left"></i></button><button onclick="deleteLog('${l.id}')" class="text-red-300 hover:text-red-500 transition-all text-left text-left text-left text-left text-left text-left"><i data-lucide="trash-2" class="w-4 h-4 text-left text-left text-left text-left text-left text-left"></i></button></div>`; } tb.innerHTML += `<tr class="hover:bg-gray-50/50 border-b border-gray-50 text-left text-left"><td class="px-10 py-6 text-[10px] font-bold text-gray-500 uppercase text-left text-left text-left">${l.date}</td><td class="px-8 py-6 text-xs font-black text-gray-700 uppercase text-left text-left text-left">${l.ownerName}</td><td class="px-8 py-6 text-xs text-gray-600 leading-tight font-medium text-left text-left text-left">${l.activity}</td><td class="px-8 py-6 text-center text-left text-left text-left"><span class="px-3 py-1 rounded-full bg-white shadow-sm border border-gray-50 text-[8px] font-black uppercase text-left text-left text-left">${l.status || 'Rascunho'}</span></td><td class="px-6 py-6 text-center text-teal-600 font-black text-sm tabular-nums text-left text-left text-left">${l.hoursNormal}h</td><td class="px-10 py-6 text-center text-left text-left text-left text-left text-left text-left text-left">${btns}</td></tr>`; }); lucide.createIcons(); }
        function renderComments(comments) { const l = document.getElementById('comments-list'); l.innerHTML = ''; if(comments.length === 0) l.innerHTML = '<div class="h-full flex items-center justify-center opacity-20 text-left text-left text-left text-left"><p class="text-[9px] font-black uppercase text-left text-left text-left text-left">Sem notas</p></div>'; comments.forEach(c => l.innerHTML += `<div class="bg-gray-50/50 p-6 rounded-3xl border border-gray-100 text-left hover:bg-white transition-all text-left text-left text-left text-left"><div class="flex justify-between items-center mb-2 text-left text-left text-left text-left text-left text-left text-left text-left"><span class="text-[10px] font-black text-c3c-blue uppercase text-left text-left text-left text-left text-left text-left text-left text-left">Workspace Note</span><span class="text-[8px] font-black text-gray-300 uppercase text-left text-left text-left text-left text-left text-left text-left text-left text-left">${c.time}</span></div><p class="text-xs font-medium text-gray-700 leading-relaxed text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left">${c.text}</p></div>`); }
        function renderAttach(atts) { const l = document.getElementById('attach-list'); l.innerHTML = ''; if(!atts||atts.length===0) return l.innerHTML='<div class="col-span-full py-20 text-center opacity-20 text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left"><i data-lucide="files" class="w-12 h-12 mx-auto mb-4 text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left"></i><p class="text-[10px] font-black uppercase text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left">Sem anexos</p></div>'; atts.forEach(a => l.innerHTML += `<div class="flex items-center justify-between p-6 bg-white border border-gray-100 rounded-3xl hover:shadow-xl transition-all text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left"><div class="flex items-center gap-4 overflow-hidden text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left"><div class="w-12 h-12 bg-gray-50 rounded-2xl flex items-center justify-center text-gray-400 shrink-0 text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left"><i data-lucide="file-text" class="w-6 h-6 text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left"></i></div><div class="truncate text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left"><p class="truncate text-[10px] font-black text-gray-800 uppercase text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left" title="${a.name}">${a.name}</p><p class="text-[8px] font-bold text-gray-400 uppercase mt-1 text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left">${(a.size/1024).toFixed(1)} KB</p></div></div><a href="/api/ops/attachments/${a.id}/download" target="_blank" class="p-4 bg-blue-50 text-c3c-blue rounded-2xl hover:bg-c3c-blue hover:text-white transition-all text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left"><i data-lucide="download" class="w-5 h-5 text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left text-left"></i></a></div>`); lucide.createIcons(); }
        function openEditLog(id, date, norm, extra, desc) { 
            document.getElementById('modal-log-id').value = id; 
            editingOriginalNormal = parseFloat(norm) || 0;
            editingOriginalExtra = parseFloat(extra) || 0;
            editingOriginalDate = date;
            
            openLogModal(false); 
            document.getElementById('modal-date').value = date; 
            fetchLimits().then(() => { 
                document.getElementById('modal-hours-normal').value = norm; 
                document.getElementById('modal-hours-extra').value = extra; 
                document.getElementById('modal-desc').value = desc; 
                checkLocks(); 
            }); 
        }
        async function deleteLog(id) { if(!confirm("Excluir?")) return; try { toggleLoading(true); await fetch('/api/ops/log/delete', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ logId: id }) }); loadTicketDetails(activeTicketId); } catch(e) { console.error(e); } finally { toggleLoading(false); } }
        async function fetchLimits() { 
            const d = document.getElementById('modal-date').value; 
            const logId = document.getElementById('modal-log-id').value;
            if(!d) return; 
            try { 
                const r = await fetch(`/api/ops/limits?date=${d}`); 
                const j = await r.json(); 
                const isL = j.isLocked && !logId; 
                document.getElementById('modal-hours-normal').disabled = isL; 
                document.getElementById('modal-hours-extra').disabled = isL; 
                document.getElementById('modal-desc').disabled = isL; 
                document.getElementById('btn-save-log').disabled = isL; 
                document.getElementById('lock-warning').classList.toggle('hidden', !isL); 
                if (isL) document.getElementById('lock-warning').innerText = `Ponto Bloqueado (${j.periodStatus})`; 
                
                currentDayLimit = j.limit; 
                currentDayUsed = j.usedNormal; 
                currentDayUsedExtra = j.usedExtra; 

                // Se estiver editando e a data for a mesma, subtrai os valores originais para permitir ajuste total
                if (logId && d === editingOriginalDate) {
                    currentDayUsed = Math.max(0, currentDayUsed - editingOriginalNormal);
                    currentDayUsedExtra = Math.max(0, currentDayUsedExtra - editingOriginalExtra);
                }

                checkLocks(); 
            } catch(e) { console.error(e); } 
        }
        function checkLocks() { 
            if(document.getElementById('btn-save-log').disabled) return; 
            const hNInput = document.getElementById('modal-hours-normal'),
                  hEInput = document.getElementById('modal-hours-extra');
            
            let hN = parseFloat(hNInput.value) || 0, 
                hE = parseFloat(hEInput.value) || 0; 
            
            // Trava rígida: Horas Normais não podem exceder o saldo do dia
            const saldoDisponivel = Math.max(0, currentDayLimit - currentDayUsed);
            if (hN > saldoDisponivel) {
                hN = saldoDisponivel;
                hNInput.value = hN;
            }

            document.getElementById('val-used').innerText = (currentDayUsed + currentDayUsedExtra + hN + hE).toFixed(1) + 'h'; 
            document.getElementById('val-saldo').innerText = (currentDayLimit - currentDayUsed - hN).toFixed(1) + 'h'; 
            
            const justCont = document.getElementById('justification-container');

            if (currentDayUsed >= (currentDayLimit - 0.01)) hNInput.classList.add('bg-gray-50', 'text-gray-400'); 
            else hNInput.classList.remove('bg-gray-50', 'text-gray-400'); 
            
            if ((currentDayUsed + hN) >= (currentDayLimit - 0.01)) { 
                hEInput.disabled = false; 
                hEInput.classList.replace('bg-gray-50', 'bg-white'); 
                document.getElementById('icon-lock-extra').classList.add('hidden'); 
            } else { 
                hEInput.disabled = true; 
                hEInput.value = ''; 
                hEInput.classList.replace('bg-white', 'bg-gray-50'); 
                document.getElementById('icon-lock-extra').classList.remove('hidden'); 
            }

            if (hE > 0) justCont.classList.remove('hidden');
            else {
                justCont.classList.add('hidden');
                document.getElementById('modal-desc').value = '';
            }
        }
        function formatHours(inp) { let v = parseFloat(inp.value); if(isNaN(v) || v < 0) { inp.value = ''; checkLocks(); return; } let r = Math.round(v*2)/2; if(r > 24) r = 24; inp.value = r; checkLocks(); }
        async function openLogModal(ft) { 
            if(!activeTicketId) return; 
            if(currentTicketData.Status === 'Closed') return alert("Reabra para lançar."); 
            openModal('time-modal'); 
            
            if (!document.getElementById('modal-log-id').value) { 
                document.getElementById('modal-date').value = new Date().toISOString().split('T')[0]; 
                document.getElementById('modal-hours-normal').value = ''; 
                document.getElementById('modal-hours-extra').value = ''; 
                document.getElementById('modal-desc').value = ''; 
                editingOriginalNormal = 0;
                editingOriginalExtra = 0;
                editingOriginalDate = '';
            } 
            await fetchLimits(); 
            const s = document.getElementById('modal-activity-select'); 
            const res = await fetch(`/api/ops/tickets/${activeTicketId}/activities`); 
            const a = await res.json(); 
            s.innerHTML = a.map(x => `<option value="${x.Id}">${x.Name}</option>`).join('') + `<option value="new">+ Nova</option>`; 
            toggleNewActivityInput(); 
            
            if(ft) { 
                document.getElementById('modal-hours-normal').value = (Math.ceil((globalSeconds/3600)*2)/2).toFixed(1); 
                checkLocks(); 
            } 
        }
        async function saveLog() { 
            const btn = document.getElementById('btn-save-log');
            const hE = parseFloat(document.getElementById('modal-hours-extra').value) || 0;
            const desc = document.getElementById('modal-desc').value.trim();
            if (hE > 0 && !desc) return alert("A justificativa é obrigatória para lançamentos de horas extras.");

            try { 
                toggleLoading(true); 
                if(btn) { btn.disabled = true; btn.innerText = "Sincronizando..."; }

                const p = { logId: document.getElementById('modal-log-id').value, caseId: activeTicketId, activityId: document.getElementById('modal-activity-select').value, newActivityName: document.getElementById('modal-new-activity-name').value, hoursNormal: document.getElementById('modal-hours-normal').value, hoursExtra: hE, desc: desc, date: document.getElementById('modal-date').value }; 
                const res = await fetch('/api/ops/log', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(p) }); 
                const data = await res.json();

                if(data.success) { 
                    closeModal('time-modal'); 
                    await loadTicketDetails(activeTicketId); 
                } else {
                    alert(data.error || "Erro ao salvar lançamento.");
                }
            } catch(e) { 
                console.error(e); 
                alert("Erro técnico no lançamento.");
            } finally { 
                toggleLoading(false); 
                if(btn) { btn.disabled = false; btn.innerText = "Confirmar Lançamento"; }
            } 
        }
        async function saveTicketUpdates() { 
            const btn = document.getElementById('btn-save-estimation');
            const estDate = document.getElementById('edit-estimation').value;
            
            if (currentTicketData.Status === 'Closed' && !estDate) {
                return alert("A Previsão de Entrega é obrigatória para este chamado.");
            }

            try { 
                toggleLoading(true); 
                if(btn) { btn.disabled = true; btn.innerHTML = '<div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>'; }

                const p = { id: activeTicketId, status: currentTicketData.Status, priority: currentTicketData.Priority, estimationDate: estDate }; 
                const res = await fetch('/api/ops/tickets/update', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(p) }); 
                
                if (res.ok) {
                    currentTicketData.DataEstimativaEntrega__c = estDate;
                    if(btn) { btn.classList.replace('bg-gray-800', 'bg-teal-500'); btn.innerHTML = '<i data-lucide="check" class="w-4 h-4"></i>'; lucide.createIcons(); }
                    setTimeout(() => { 
                        if(btn) { btn.classList.replace('bg-teal-500', 'bg-gray-800'); btn.innerHTML = '<i data-lucide="save" class="w-4 h-4"></i>'; lucide.createIcons(); }
                    }, 2000);
                } else { alert("Erro ao atualizar."); }
            } catch(e) { console.error(e); } finally { toggleLoading(false); if(btn) btn.disabled = false; } 
        }
        function switchDetailTab(t) { ['info','logs','edit','attach'].forEach(x => { const v=document.getElementById(`view-${x}`), b=document.getElementById(`dt-${x}`); if(v) v.classList.add('hidden'); if(b) b.className = 'pb-6 pt-8 text-[11px] font-black uppercase tracking-[0.2em] text-gray-400 hover:text-gray-600 transition-all whitespace-nowrap text-left'; if(x==='edit' && (!currentTicketData || currentTicketData.Pessoa__c !== '<%= user.id %>') && b) b.classList.add('hidden'); }); const v = document.getElementById(`view-${t}`), b = document.getElementById(`dt-${t}`); if(v) v.classList.remove('hidden'); if(b) b.className = 'pb-6 pt-8 text-[11px] font-black uppercase tracking-[0.2em] tab-active whitespace-nowrap text-left'; }
        function openModal(id) { const m = document.getElementById(id); m.classList.remove('hidden'); setTimeout(() => m.classList.remove('scale-95'), 10); }
        function closeModal(id) { const m = document.getElementById(id); m.querySelector('div').classList.add('scale-95'); setTimeout(() => m.classList.add('hidden'), 200); if(id==='time-modal') document.getElementById('modal-log-id').value = ''; }
        async function assignTicket() { try { toggleLoading(true); const r = await fetch('/api/ops/tickets/assign', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ id: activeTicketId }) }); if(r.ok) { await changeFilter('my'); loadTicketDetails(activeTicketId); } } catch(e) { console.error(e); } finally { toggleLoading(false); } }
        async function transferTicket(t) { try { toggleLoading(true); const r = await fetch('/api/ops/tickets/transfer', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ id: activeTicketId, target: t }) }); if(r.ok) closeTicketDetails(); } catch(e) { console.error(e); } finally { toggleLoading(false); } }
        async function postComment() { const t = document.getElementById('quick-comment').value; if(!t) return; const r = await fetch('/api/ops/comment', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ caseId: activeTicketId, text: t }) }); if(r.ok) { document.getElementById('quick-comment').value = ''; loadTicketDetails(activeTicketId); } }
        function toggleContactMode() { const s = document.getElementById('contact-select-mode'), c = document.getElementById('contact-create-mode'); s.classList.toggle('hidden'); c.classList.toggle('hidden'); }
        async function saveNewContact() { 
            const name = document.getElementById('new-contact-name').value;
            const email = document.getElementById('new-contact-email').value;
            if(!name || !email) return alert("Nome e E-mail são obrigatórios.");

            try { 
                toggleLoading(true); 
                const res = await fetch('/api/ops/contact/create', { 
                    method: 'POST', 
                    headers: {'Content-Type': 'application/json'}, 
                    body: JSON.stringify({ 
                        accountId: document.getElementById('new-account-id').value, 
                        name: name, 
                        email: email, 
                        mobile: document.getElementById('new-contact-mobile').value 
                    }) 
                }); 
                const j = await res.json(); 
                if(j.success) { 
                    toggleContactMode(); 
                    const s = document.getElementById('new-contact'); 
                    const o = document.createElement('option'); 
                    o.value = j.id; 
                    o.text = `${j.name} (Novo)`; 
                    o.selected = true; 
                    s.appendChild(o); 
                    s.disabled = false; 
                } 
            } catch(e) { console.error(e); } finally { toggleLoading(false); } 
        }
        async function openNewTicketModal() { 
            openModal('new-ticket-modal'); 
            const form = document.getElementById('form-create-ticket');
            if(form) form.reset(); 
            const modalBody = document.querySelector('#new-ticket-modal .overflow-y-auto');
            if(modalBody) modalBody.scrollTop = 0;
            newTicketFiles = []; 
            renderNewFilesPreview();            document.getElementById('new-contact').innerHTML='<option value="">Selecione...</option>'; 
            document.getElementById('new-contact').disabled=true; 
            if(createOptionsCache.length===0) { 
                const res = await fetch('/api/ops/create-options'); 
                createOptionsCache = await res.json(); 
                document.getElementById('new-service').innerHTML = '<option value="">Selecione...</option>' + createOptionsCache.map(o => `<option value="${o.serviceId}" data-account="${o.accountId}">${o.serviceName} (${o.accountName})</option>`).join(''); 
            } 
        }
        async function onServiceChange() { const s = document.getElementById('new-service'), acc = s.options[s.selectedIndex].dataset.account; document.getElementById('new-account-id').value = acc||''; const c=document.getElementById('new-contact'); c.innerHTML='<option>Carregando...</option>'; c.disabled=true; if(acc) { const r=await fetch(`/api/ops/account/${acc}/contacts`); const d=await r.json(); c.innerHTML='<option value="">Sem contato</option>' + d.map(ct=>`<option value="${ct.Id}">${ct.Name}</option>`).join(''); c.disabled=false; } }
        async function submitNewTicket() { 
            const btn = document.querySelector('button[onclick="submitNewTicket()"]');
            try { 
                toggleLoading(true); 
                if(btn) { btn.disabled = true; btn.innerText = "Sincronizando..."; }

                const p = { serviceId: document.getElementById('new-service').value, accountId: document.getElementById('new-account-id').value, contactId: document.getElementById('new-contact').value, subject: document.getElementById('new-subject').value, type: document.getElementById('new-type').value, priority: document.getElementById('new-priority').value, origin: document.getElementById('new-origin').value, expectationDate: document.getElementById('new-expectation').value, assignToMe: document.getElementById('new-assign').checked, desc: document.getElementById('new-desc').value }; 
                
                if(!p.serviceId || !p.contactId || !p.subject || !p.desc) {
                    alert("Preencha todos os campos obrigatórios (*)");
                    toggleLoading(false);
                    if(btn) { btn.disabled = false; btn.innerText = "Criar Chamado"; }
                    return;
                }

                const res = await fetch('/api/ops/tickets/create', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(p) }); 
                const j = await res.json(); 
                
                if(j.success) { 
                    if (newTicketFiles.length > 0) { 
                        if(btn) btn.innerText = "Enviando Anexos...";
                        const fd = new FormData(); 
                        for(let f of newTicketFiles) fd.append('files', f); 
                        await fetch(`/api/ops/tickets/${j.id}/upload`, { method: 'POST', body: fd }); 
                    } 
                    closeModal('new-ticket-modal'); 

                    if (p.assignToMe) {
                        currentFilter = 'my';
                        // Ativa visualmente a aba 'Meus'
                        ['my','queue','team','all'].forEach(t => { 
                            const b = document.getElementById(`tab-${t}`); 
                            if(b) b.className = (t === 'my') 
                                ? 'px-8 py-3 text-[10px] font-black uppercase tracking-widest rounded-[14px] transition-all bg-c3c-blue text-white shadow-lg'
                                : 'px-8 py-3 text-[10px] font-black uppercase tracking-widest rounded-[14px] text-gray-400 hover:text-gray-600 transition-all';
                        });
                        await loadTicketDetails(j.id);
                    } else {
                        await changeFilter('queue');
                    }
                } else {                    alert("Erro ao criar chamado: " + (j.message || "Erro desconhecido"));
                }
            } catch(e) { 
                console.error(e); 
                alert("Erro técnico na criação do chamado.");
            } finally { 
                toggleLoading(false); 
                if(btn) { btn.disabled = false; btn.innerText = "Criar Chamado"; }
            } 
        }
        async function uploadFiles(id) { try { toggleLoading(true); const fd = new FormData(); for(let f of document.getElementById('attach-new-file').files) fd.append('files', f); await fetch(`/api/ops/tickets/${id}/upload`, { method: 'POST', body: fd }); loadTicketDetails(id); } catch(e) { console.error(e); } finally { toggleLoading(false); } }
        let globalSeconds = 0, globalInterval = null;
        function startGlobalTimer() { 
            if(!activeTicketId || globalInterval) return; 
            document.getElementById('global-play').classList.add('hidden'); 
            document.getElementById('global-stop').classList.remove('hidden'); 
            document.getElementById('timer-container').classList.add('timer-active', 'border-teal-200', 'bg-teal-50/30'); 
            globalInterval = setInterval(() => { 
                globalSeconds++; 
                const h = Math.floor(globalSeconds / 3600).toString().padStart(2,'0'), 
                      m = Math.floor((globalSeconds % 3600) / 60).toString().padStart(2,'0'), 
                      s = (globalSeconds % 60).toString().padStart(2,'0'); 
                document.getElementById('global-timer').innerText = `${h}:${m}:${s}`; 
            }, 1000); 
        }
        function stopGlobalTimer() { 
            clearInterval(globalInterval); 
            globalInterval = null; 
            document.getElementById('global-stop').classList.add('hidden'); 
            document.getElementById('global-play').classList.remove('hidden'); 
            document.getElementById('timer-container').classList.remove('timer-active', 'border-teal-200', 'bg-teal-50/30'); 
            openLogModal(true); 
        }
        document.addEventListener('DOMContentLoaded', () => { changeFilter('my'); });
        function toggleNewActivityInput() { document.getElementById('modal-new-activity-name').classList.toggle('hidden', document.getElementById('modal-activity-select').value !== 'new'); }
    </script>
