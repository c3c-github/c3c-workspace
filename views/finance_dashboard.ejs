<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cockpit Financeiro - C3C Workspace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { 
                        c3c: { 
                            blue: '#2978FF', 
                            teal: '#1DDDBD', 
                            gray: '#F2F2F2',
                            dark: '#000000'
                        } 
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .bg-c3c-gradient { background: transparent linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%) 0% 0% no-repeat padding-box; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }

        /* DEMO MODE STYLES */
        .demo-mode-active .demo-blur { filter: blur(6px); pointer-events: none; user-select: none; transition: all 0.3s ease; }

        /* STEPPER PATH STYLES */
        .step-path { @apply relative flex items-center justify-between w-full gap-2 px-2; }
        .step-item { @apply relative flex flex-col items-center flex-1 cursor-pointer transition-all duration-300; }
        .step-node { @apply w-12 h-12 rounded-full border-4 border-white shadow-md flex items-center justify-center text-sm font-black transition-all duration-500 z-10; }
        .step-line { @apply absolute top-6 left-[50%] w-full h-1 bg-gray-100 -z-0 transition-all duration-500; }
        .step-item:last-child .step-line { @apply hidden; }
        
        .step-item.active .step-node { @apply bg-c3c-blue text-white scale-110 shadow-blue-200 shadow-xl border-blue-100; }
        .step-item.active .step-line { @apply bg-c3c-blue; }
        .step-item.active p { @apply text-c3c-blue font-black; }

        /* TOAST STYLES */
        #toast-container { position: fixed; top: 2rem; right: 2rem; z-index: 9999; display: flex; flex-direction: column; gap: 1rem; }
        .toast { 
            animation: toastIn 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
            background-color: white; border: 1px solid #F1F5F9; border-radius: 24px; padding: 1rem; display: flex; align-items: center; gap: 1rem; min-width: 320px; max-width: 400px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }
        @keyframes toastIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        .toast.hiding { animation: toastOut 0.5s ease-in forwards; }
        @keyframes toastOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#F8FAFC]">

    <!-- TOAST CONTAINER -->
    <div id="toast-container"></div>

    <%- include('partials/sidebar', { page: 'finance' }) %>

    <main class="flex-1 flex flex-col md:ml-64 relative w-full transition-all duration-300 overflow-hidden">
        
        <!-- HEADER -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-20 shrink-0">
            <div class="flex items-center gap-4 text-left">
                <button onclick="document.getElementById('sidebar').classList.toggle('-translate-x-full')" class="md:hidden p-2 text-gray-600 hover:bg-gray-100 rounded-lg">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <div>
                    <h1 class="text-lg md:text-xl font-bold text-gray-800 flex items-center gap-2 tracking-tight">Cockpit Financeiro <span class="text-c3c-blue">💎</span></h1>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest hidden sm:block">Gestão Centralizada de Pagamentos e Notas</p>
                </div>
            </div>
        </header>

        <!-- CONTEÚDO -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 fade-in custom-scrollbar text-left">
            
            <!-- TOP BAR: KPIs COMPACTOS E TITULO -->
            <div class="mb-6 flex flex-wrap items-end justify-between gap-6">
                <div>
                    <h2 class="text-xl font-black text-gray-800 tracking-tighter uppercase leading-tight">Visão Geral</h2>
                    <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mt-1">Gestão de Fluxo Financeiro</p>
                </div>
                
                <div class="flex gap-4">
                    <div class="bg-white px-5 py-3 rounded-2xl border border-gray-100 shadow-sm text-left min-w-[140px]">
                        <p class="text-[8px] font-black text-gray-400 uppercase tracking-widest mb-1">A Validar</p>
                        <p class="text-sm font-black text-gray-800 tracking-tight demo-blur" id="kpi-validar">R$ 0,00</p>
                    </div>
                    <div class="bg-white px-5 py-3 rounded-2xl border border-gray-100 shadow-sm text-left min-w-[140px]">
                        <p class="text-[8px] font-black text-gray-400 uppercase tracking-widest mb-1">Agendado</p>
                        <p class="text-sm font-black text-gray-800 tracking-tight demo-blur" id="kpi-agendado">R$ 0,00</p>
                    </div>
                    <div class="bg-c3c-gradient px-5 py-3 rounded-2xl shadow-lg shadow-blue-100 text-left min-w-[140px]">
                        <p class="text-[8px] font-black text-blue-50 uppercase tracking-widest mb-1">Divergências</p>
                        <p class="text-sm font-black text-white tracking-tight" id="kpi-divergencias">0</p>
                    </div>
                </div>
            </div>

            <!-- ACTION BAR: BUSCA + STEPPER COMPACTO -->
            <div class="mb-6 bg-white p-3 rounded-[24px] shadow-sm border border-gray-100 flex flex-wrap items-center gap-6">
                
                <!-- BUSCA -->
                <div class="relative flex-1 min-w-[300px] group">
                    <i data-lucide="search" class="w-4 h-4 text-gray-300 absolute left-4 top-1/2 -translate-y-1/2 group-focus-within:text-c3c-blue transition-colors"></i>
                    <input type="text" id="search-input" oninput="filterLocalData()" placeholder="Buscar colaborador, empresa ou ciclo..." class="w-full pl-11 pr-4 py-2.5 bg-gray-50/50 border border-gray-100 rounded-xl text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all placeholder:text-gray-300">
                </div>

                <!-- STEPPER COMPACTO -->
                <div id="funnel-container" class="flex items-center gap-2 h-10 px-2 bg-gray-50/50 rounded-xl border border-gray-100">
                    <!-- Gerado via JS -->
                </div>

                <button onclick="resetFilters()" class="p-2.5 bg-white border border-gray-100 rounded-xl text-gray-400 hover:text-c3c-blue transition-all shadow-sm"><i data-lucide="refresh-cw" class="w-4 h-4"></i></button>

                <!-- ACTIONS -->
                <div id="bulk-actions" class="hidden items-center gap-2 pr-2 border-l border-gray-100 pl-4">
                    <span class="text-[9px] font-black text-c3c-blue uppercase tracking-widest mr-2"><span id="selected-count" class="text-xs">0</span> itens:</span>
                    <button id="btn-bulk-reprove" onclick="openMassReproveModal()" class="bg-white text-red-500 border border-red-100 px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-sm hover:bg-red-50 transition-all">Reprovar Nota</button>
                    <button id="btn-bulk-ready" onclick="updateBulkStatus('Pronto para Pagamento')" class="bg-white text-teal-600 border border-teal-100 px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-sm hover:bg-teal-50 transition-all">Aprovar Nota</button>
                    <button id="btn-bulk-schedule" onclick="updateBulkStatus('Pagamento Agendado')" class="bg-white text-c3c-blue border border-blue-100 px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-sm hover:bg-blue-50 transition-all">Agendar</button>
                    <button id="btn-bulk-pay" onclick="updateBulkStatus('Finalizado/Pago')" class="bg-c3c-gradient text-white px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-lg shadow-blue-100 hover:opacity-90 transition-all">Pago</button>
                </div>
            </div>

            <!-- TABELA -->
            <div class="bg-white rounded-[40px] shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto custom-scrollbar">
                    <table class="w-full text-center table-fixed min-w-[1250px]">
                        <thead class="bg-gray-50/50 border-b border-gray-100">
                            <tr class="text-[10px] font-black text-gray-400 uppercase tracking-widest">
                                <th class="px-4 py-6 w-16 text-center">
                                    <input type="checkbox" id="select-all" onclick="toggleSelectAll(this)" class="w-4 h-4 rounded border-gray-200 text-c3c-blue focus:ring-blue-100 transition-all">
                                </th>
                                <th class="px-4 py-6 w-20 text-center">Perfil</th>
                                <th class="px-6 py-6 w-64">Colaborador / Ciclo</th>
                                <th class="px-6 py-6 w-80">Dados da Nota</th>
                                <th class="px-6 py-6 w-48 text-center">Status e Auditoria</th>
                                <th class="px-6 py-6 w-56 text-center">Valores (NF vs Sist)</th>
                                <th class="px-8 py-6 w-48 text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody id="finance-table-body" class="divide-y divide-gray-50">
                            <tr><td colspan="7" class="text-center py-32 text-gray-300 font-black uppercase text-[10px] tracking-widest animate-pulse"><i data-lucide="loader-2" class="w-8 h-8 animate-spin mx-auto mb-4 opacity-20"></i>Sincronizando cockpit...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- MODAL REPROVAÇÃO -->
    <div id="modal-reprove" class="fixed inset-0 bg-black/60 backdrop-blur-md z-[100] hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-[40px] shadow-2xl w-full max-w-md p-10 text-center transform scale-95 transition-all flex flex-col items-center">
            <div class="w-20 h-20 bg-red-50 text-red-500 rounded-full flex items-center justify-center mb-6 shadow-inner"><i data-lucide="x-octagon" class="w-10 h-10"></i></div>
            <h3 class="text-2xl font-black text-gray-800 tracking-tighter uppercase mb-2">Reprovar Nota</h3>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-8 leading-relaxed">Informe o motivo da divergência para o colaborador</p>
            
            <input type="hidden" id="reprove-period-id">
            <input type="hidden" id="reprove-nf-id">
            
            <textarea id="reprove-motivo" rows="4" class="w-full bg-gray-50 border-2 border-gray-100 rounded-[32px] p-6 text-sm font-medium focus:ring-4 focus:ring-red-50 outline-none mb-8 resize-none placeholder:text-gray-300" placeholder="Ex: Valor da nota não condiz com o aprovado..."></textarea>

            <div class="flex gap-4 w-full">
                <button onclick="closeReproveModal()" class="flex-1 py-4 text-gray-400 font-black uppercase text-[10px] tracking-widest hover:text-gray-600 transition-all">Cancelar</button>
                <button onclick="confirmReprove()" class="flex-[2] py-4 bg-red-600 text-white font-black uppercase text-xs tracking-widest rounded-2xl shadow-xl shadow-red-100 hover:bg-red-700 active:scale-95 transition-all">Confirmar Reprovação</button>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
        let allPeriods = [];
        let currentStatusFilter = 'Nota em Validação'; // Default inicial

        document.addEventListener('DOMContentLoaded', loadFinancePeriods);

        function showToast(title, message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = 'toast';
            const icon = type === 'success' ? 'check-circle' : (type === 'error' ? 'alert-triangle' : 'info');
            const iconColor = type === 'success' ? 'text-teal-500 bg-teal-50' : (type === 'error' ? 'text-red-500 bg-red-50' : 'text-blue-500 bg-blue-50');
            toast.innerHTML = `<div class="p-3 rounded-2xl ${iconColor}"><i data-lucide="${icon}" class="w-6 h-6"></i></div><div class="flex-1"><h4 class="text-xs font-black text-gray-800 uppercase tracking-widest">${title}</h4><p class="text-[10px] font-bold text-gray-400 uppercase mt-0.5 tracking-tight">${message}</p></div>`;
            container.appendChild(toast);
            lucide.createIcons();
            setTimeout(() => { toast.classList.add('hiding'); setTimeout(() => toast.remove(), 500); }, 4000);
        }

        async function loadFinancePeriods() {
            // Carrega todos os períodos para alimentar o stepper e KPIs
            const url = `/api/finance/periods?status=`; 
            try {
                const res = await fetch(url);
                allPeriods = await res.json();
                
                // Cálculo de KPIs
                let aValidar = 0, agendado = 0, divergencias = 0;
                allPeriods.forEach(p => {
                    const vHoras = p.valueHoras || 0, vNF = p.nf ? (p.nf.valor || 0) : 0;
                    if (p.status === 'Nota em Validação') aValidar += vNF;
                    if (p.status === 'Pagamento Agendado') agendado += vNF;
                    if (p.status === 'Nota em Validação' && Math.abs(vHoras - vNF) > 0.05) divergencias++;
                });
                document.getElementById('kpi-validar').innerText = aValidar.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                document.getElementById('kpi-agendado').innerText = agendado.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                document.getElementById('kpi-divergencias').innerText = divergencias;

                renderFunnel();
                filterLocalData();
            } catch(e) { console.error(e); showToast('Erro de Conexão', 'Não foi possível carregar os dados financeiros.', 'error'); }
        }

        function renderFunnel() {
            const container = document.getElementById('funnel-container');
            container.innerHTML = '';

            const steps = [
                { id: 'Nota em Validação', label: '1. Validação', icon: 'shield-check', color: 'text-orange-500' },
                { id: 'Reprovados', label: '2. Reprovados', icon: 'x-circle', color: 'text-red-500' },
                { id: 'Pronto para Pagamento', label: '3. Pronto', icon: 'check-circle', color: 'text-teal-500' },
                { id: 'Pagamento Agendado', label: '4. Agendado', icon: 'calendar-clock', color: 'text-purple-500' },
                { id: 'Finalizado/Pago', label: '5. Pago', icon: 'wallet', color: 'text-c3c-blue' }
            ];

            steps.forEach((step, idx) => {
                let count = 0;
                if (step.id === 'Reprovados') {
                    count = allPeriods.filter(p => p.status === 'Liberado para Nota Fiscal' && p.nf && p.nf.status === 'Reprovada').length;
                } else {
                    count = allPeriods.filter(p => p.status === step.id).length;
                }

                const isActive = currentStatusFilter === step.id;
                
                const stepEl = document.createElement('div');
                stepEl.className = `flex items-center gap-2 px-3 h-8 rounded-lg cursor-pointer transition-all duration-300 ${isActive ? 'bg-c3c-blue text-white shadow-md scale-105' : 'hover:bg-white text-gray-400'}`;
                stepEl.onclick = () => { currentStatusFilter = (currentStatusFilter === step.id) ? '' : step.id; renderFunnel(); filterLocalData(); };
                
                stepEl.innerHTML = `
                    <i data-lucide="${step.icon}" class="w-3.5 h-3.5 ${isActive ? 'text-white' : step.color}"></i>
                    <span class="text-[10px] font-black uppercase tracking-widest">${step.label}</span>
                    <span class="text-[10px] font-black ${isActive ? 'bg-white/20' : 'bg-gray-100 text-gray-600'} px-1.5 py-0.5 rounded-md">${count}</span>
                `;
                container.appendChild(stepEl);
            });
            lucide.createIcons();
        }

        function filterLocalData() {
            const term = document.getElementById('search-input').value.toLowerCase();
            const tbody = document.getElementById('finance-table-body');
            
            // Se for uma busca local rápida, não precisa de loading pesado, 
            // mas como loadFinancePeriods é chamado ao mudar status, vamos garantir feedback.
            
            const filtered = allPeriods.filter(p => {
                let matchesStatus = true;
                if (currentStatusFilter === 'Reprovados') {
                    matchesStatus = p.status === 'Liberado para Nota Fiscal' && p.nf && p.nf.status === 'Reprovada';
                } else if (currentStatusFilter) {
                    matchesStatus = p.status === currentStatusFilter;
                }
                
                const matchesTerm = !term || (p.employeeName.toLowerCase().includes(term) || p.name.toLowerCase().includes(term) || (p.nf && p.nf.nomeEmitente && p.nf.nomeEmitente.toLowerCase().includes(term)));
                return matchesStatus && matchesTerm;
            });
            renderTable(filtered);
        }

        async function loadFinancePeriods() {
            const tbody = document.getElementById('finance-table-body');
            tbody.innerHTML = `<tr><td colspan="7" class="py-32 px-6 text-center text-gray-300 font-black uppercase text-[10px] tracking-widest animate-pulse italic">
                <i data-lucide="loader-2" class="w-10 h-10 animate-spin mx-auto mb-4 opacity-40 text-c3c-blue"></i>
                Processando dados do Salesforce...
            </td></tr>`;
            lucide.createIcons();

            const url = '/api/finance/periods?status='; 
            try {
                const res = await fetch(url);
                allPeriods = await res.json();
                
                // Cálculo de KPIs
                let aValidar = 0, agendado = 0, divergencias = 0;
                allPeriods.forEach(p => {
                    const vHoras = p.valueHoras || 0, vNF = p.nf ? (p.nf.valor || 0) : 0;
                    if (p.status === 'Nota em Validação') aValidar += vNF;
                    if (p.status === 'Pagamento Agendado') agendado += vNF;
                    if (p.status === 'Nota em Validação' && Math.abs(vHoras - vNF) > 0.05) divergencias++;
                });
                document.getElementById('kpi-validar').innerText = aValidar.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                document.getElementById('kpi-agendado').innerText = agendado.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                document.getElementById('kpi-divergencias').innerText = divergencias;

                renderFunnel();
                filterLocalData();
            } catch(e) { console.error(e); showToast('Erro de Conexão', 'Não foi possível carregar os dados financeiros.', 'error'); }
        }

        function renderTable(periods) {
            const tbody = document.getElementById('finance-table-body'); tbody.innerHTML = '';
            
            if (periods.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="py-32 px-6">
                    <div class="flex flex-col items-center justify-center text-center fade-in">
                        <div class="w-20 h-20 bg-gray-50 text-gray-200 rounded-full flex items-center justify-center mb-6 border border-gray-100 shadow-inner"><i data-lucide="search-x" class="w-10 h-10"></i></div>
                        <h3 class="text-lg font-black text-gray-800 uppercase tracking-tighter mb-2">Nenhum registro encontrado</h3>
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] max-w-xs mx-auto">Tente ajustar seus filtros ou busca.</p>
                    </div></td></tr>`;
                lucide.createIcons();
                return;
            }

            periods.forEach(p => {
                const vHoras = p.valueHoras || 0, vNF = p.nf ? (p.nf.valor || 0) : 0, diff = Math.abs(vHoras - vNF), hasDiscrepancy = diff > 0.05; 
                const c3cCNPJ = "34268618000159", nfReceptorRaw = p.nf && p.nf.cnpjReceptor ? p.nf.cnpjReceptor.replace(/\D/g, '') : '', isC3C = nfReceptorRaw === c3cCNPJ;
                const statusColors = { 'Nota em Validação': 'bg-orange-50 text-orange-600 border-orange-100', 'Pronto para Pagamento': 'bg-blue-50 text-c3c-blue border-blue-100', 'Pagamento Agendado': 'bg-purple-50 text-purple-600 border-purple-100', 'Finalizado/Pago': 'bg-teal-50 text-teal-600 border-teal-100', 'Liberado para Nota Fiscal': 'bg-gray-50 text-gray-400 border-gray-100' };
                let stLabel = p.status, stColor = statusColors[p.status] || 'bg-gray-50';
                
                if(p.status === 'Liberado para Nota Fiscal') { 
                    if(p.nf && p.nf.status === 'Reprovada') { stLabel = 'Nota Reprovada'; stColor = 'bg-red-50 text-red-600 border-red-100'; } 
                    else { stLabel = 'Aguardando Nota'; } 
                }

                let nfDown = p.nf && p.nf.docId ? `<a href="/api/billing/download/${p.nf.docId}" class="p-2 text-c3c-blue bg-blue-50 hover:bg-c3c-blue hover:text-white rounded-xl transition-all shadow-sm" title="Baixar Nota"><i data-lucide="download-cloud" class="w-4 h-4"></i></a>` : '';
                
                let actions = '';
                if (p.status === 'Nota em Validação') {
                    const nfId = p.nf ? p.nf.id : '';
                    actions = `<div class="flex items-center justify-center gap-2">
                        <button onclick="openReproveModal('${p.id}', '${nfId}')" class="p-2 text-red-500 bg-red-50 hover:bg-red-500 hover:text-white rounded-xl transition-all shadow-sm" title="Reprovar Nota"><i data-lucide="x-circle" class="w-4 h-4"></i></button>
                        <button onclick="updateStatus('${p.id}', 'Pronto para Pagamento')" class="bg-teal-600 text-white px-4 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest shadow-lg shadow-teal-100 hover:bg-teal-700 transition-all active:scale-95">Validar</button>
                    </div>`;
                }

                const alertIcon = hasDiscrepancy && p.status === 'Nota em Validação' ? `<i data-lucide="alert-triangle" class="w-4 h-4 text-red-500 animate-pulse" title="Divergência de Valor!"></i>` : '';
                const receptorBadge = p.nf ? (isC3C ? `<span class="bg-teal-50 text-teal-600 text-[7px] px-2 py-0.5 rounded-full border border-teal-100 font-black uppercase tracking-widest">Receptor OK</span>` : `<span class="bg-red-50 text-red-600 text-[7px] px-2 py-0.5 rounded-full border border-red-100 font-black uppercase">Receptor Inválido</span>`) : '';
                const iaBadge = p.nf ? (p.nf.preenchimento === 'Automático' ? `<span class="bg-blue-50 text-c3c-blue text-[7px] px-2 py-0.5 rounded-full border border-blue-100 font-black uppercase flex items-center justify-center gap-1 mx-auto"><i data-lucide="sparkles" class="w-2.5 h-2.5"></i> IA</span>` : `<span class="bg-gray-50 text-gray-400 text-[7px] px-2 py-0.5 rounded-full border border-gray-100 font-black uppercase flex items-center justify-center gap-1 mx-auto"><i data-lucide="user" class="w-2.5 h-2.5"></i> Manual</span>`) : '';
                
                const invoiceBlock = p.nf ? `
                    <div class="flex flex-col items-center gap-1">
                        <p class="font-black text-gray-800 text-[11px] uppercase tracking-tighter truncate max-w-[280px]">${p.nf.nomeEmitente || 'N/A'}</p>
                        <div class="flex items-center gap-3 text-[9px] font-bold text-gray-400 uppercase tracking-widest">
                            <span>CNPJ: ${p.nf.cnpjEmissor || 'N/A'}</span>
                            <span class="text-gray-200">|</span>
                            <span>NF: ${p.nf.numeroNota || 'N/A'}</span>
                        </div>
                        <p class="text-[8px] font-bold text-gray-300 uppercase tracking-[0.2em] mt-0.5">Emissão: ${p.nf.dataEmissao ? new Date(p.nf.dataEmissao + 'T12:00:00').toLocaleDateString('pt-BR') : '-'}</p>
                    </div>` : '<span class="text-gray-300 italic text-[10px] font-black uppercase tracking-widest">Sem nota enviada</span>';
                
                tbody.innerHTML += `
                    <tr class="hover:bg-gray-50/50 transition-colors h-28 group">
                        <td class="px-4 py-4 text-center"><input type="checkbox" value="${p.id}" onchange="updateSelection()" class="period-checkbox w-4 h-4 rounded border-gray-200 text-c3c-blue focus:ring-blue-100 transition-all"></td>
                        <td class="px-4 py-4 text-center">
                            <div class="flex justify-center">
                                ${p.employeePhoto 
                                    ? `<div class="w-12 h-12 rounded-full overflow-hidden border-2 border-white shadow-md bg-gray-100">
                                         <img src="${p.employeePhoto}" class="w-full h-full object-cover">
                                       </div>`
                                    : `<div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-c3c-blue font-black uppercase shadow-md border border-blue-100 text-sm">${p.employeeName.charAt(0)}</div>`
                                }
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-center leading-tight">
                                <p class="font-black text-gray-800 text-xs uppercase tracking-tighter">${p.employeeName}</p>
                                <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mt-1">${p.name}</p>
                            </div>
                        </td>
                        <td class="px-6 py-4">${invoiceBlock}</td>
                        <td class="px-6 py-4 text-center">
                            <div class="flex flex-col items-center gap-2">
                                <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase border tracking-widest ${stColor}">${stLabel}</span>
                                <div class="flex gap-1.5">${receptorBadge}${iaBadge}</div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <div class="flex flex-col items-center gap-1">
                                <div class="flex items-center gap-2 font-black ${hasDiscrepancy && p.status === 'Nota em Validação' ? 'text-red-500' : 'text-gray-800'} text-base tracking-tighter justify-center demo-blur">
                                    ${alertIcon} ${vNF.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                                </div>
                                <p class="text-[9px] font-bold text-gray-300 uppercase tracking-widest demo-blur">Sistema: ${vHoras.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}</p>
                            </div>
                        </td>
                        <td class="px-8 py-4 text-center">
                            <div class="flex flex-col items-center gap-3">
                                ${actions}
                                ${nfDown ? `<div class="flex items-center gap-2 justify-center">${nfDown}</div>` : ''}
                            </div>
                        </td>
                    </tr>`;
            });
            lucide.createIcons(); updateSelection();
        }

        function toggleSelectAll(master) { document.querySelectorAll('.period-checkbox').forEach(cb => cb.checked = master.checked); updateSelection(); }
        function updateSelection() { 
            const sel = document.querySelectorAll('.period-checkbox:checked'), bar = document.getElementById('bulk-actions'), lbl = document.getElementById('selected-count'); 
            if(sel.length > 0) { 
                bar.classList.remove('hidden'); 
                bar.classList.add('flex'); 
                lbl.innerText = sel.length; 
                
                // Controle de visibilidade dos botões baseado no filtro
                const isValidation = currentStatusFilter === 'Nota em Validação';
                document.getElementById('btn-bulk-reprove').classList.toggle('hidden', !isValidation);
                document.getElementById('btn-bulk-ready').classList.toggle('hidden', !isValidation);
                
                document.getElementById('btn-bulk-schedule').classList.toggle('hidden', currentStatusFilter !== 'Pronto para Pagamento');
                document.getElementById('btn-bulk-pay').classList.toggle('hidden', currentStatusFilter !== 'Pagamento Agendado');
            } else { 
                bar.classList.add('hidden'); 
                bar.classList.remove('flex'); 
                document.getElementById('select-all').checked = false; 
            } 
        }
        async function updateStatus(id, s) { if(!confirm(`Mudar status para "${s}"?`)) return; await callUpdateStatus([id], s); }
        async function updateBulkStatus(s) { const ids = Array.from(document.querySelectorAll('.period-checkbox:checked')).map(cb => cb.value); if(!confirm(`Mudar ${ids.length} períodos para "${s}"?`)) return; await callUpdateStatus(ids, s); }
        async function callUpdateStatus(ids, s) { try { const res = await fetch('/api/finance/update-status', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ periodIds: ids, newStatus: s }) }); const r = await res.json(); if(r.success) { showToast('Status Atualizado', 'Registros movidos para ' + s); loadFinancePeriods(); } } catch(e) { console.error(e); } }
        function openReproveModal(pId, nfId) { document.getElementById('reprove-period-id').value = pId; document.getElementById('reprove-nf-id').value = nfId; document.getElementById('reprove-motivo').value = ''; document.getElementById('modal-reprove').classList.remove('hidden'); setTimeout(() => document.getElementById('modal-reprove').querySelector('div').classList.remove('scale-95'), 10); }
        function openMassReproveModal() { document.getElementById('reprove-period-id').value = 'MASS'; document.getElementById('reprove-nf-id').value = ''; document.getElementById('reprove-motivo').value = ''; document.getElementById('modal-reprove').classList.remove('hidden'); setTimeout(() => document.getElementById('modal-reprove').querySelector('div').classList.remove('scale-95'), 10); }
        function closeReproveModal() { document.getElementById('modal-reprove').classList.add('hidden'); }
        async function confirmReprove() { 
            const pId = document.getElementById('reprove-period-id').value, m = document.getElementById('reprove-motivo').value; 
            if(!m) return showToast('Atenção', 'O motivo é obrigatório', 'error'); 
            
            try { 
                let ids = [];
                if(pId === 'MASS') {
                    ids = Array.from(document.querySelectorAll('.period-checkbox:checked')).map(cb => cb.value);
                } else {
                    ids = [pId];
                }

                const res = await fetch('/api/finance/reprove-nf', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ periodIds: ids, motivo: m }) }); 
                const r = await res.json(); 
                if(r.success) { 
                    showToast('Operação Concluída', ids.length + ' nota(s) reprovada(s).'); 
                    closeReproveModal(); 
                    // Limpa seleção
                    document.querySelectorAll('.period-checkbox').forEach(cb => cb.checked = false);
                    document.getElementById('select-all').checked = false;
                    updateSelection();
                    loadFinancePeriods(); 
                } 
            } catch(e) { console.error(e); } 
        }
    </script>
</body>
</html>
