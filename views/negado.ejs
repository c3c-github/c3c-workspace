<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Acesso Restrito - C3C Software</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .bg-c3c-gradient { background: transparent linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%) 0% 0% no-repeat padding-box; }
        .fade-in { animation: fadeIn 0.5s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="h-screen w-full flex items-center justify-center p-4">

    <div class="bg-white rounded-[40px] shadow-2xl w-full max-w-lg overflow-hidden fade-in relative border border-gray-100">
        
        <div class="bg-red-500 h-2 w-full"></div>

        <div class="p-10 md:p-16 text-center">
            
            <div class="mb-10 flex justify-center items-center gap-4">
                <img src="/assets/signatures/assinaturaLogo.png" alt="C3C" class="h-8 w-auto">
                <div class="h-6 w-px bg-gray-200"></div>
                <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-white shadow-md">
                    <img src="/assets/signatures/assinaturaCapivorce.png" alt="Capivorce" class="w-full h-full object-cover">
                </div>
            </div>

            <div class="relative w-24 h-24 mx-auto mb-8">
                <div class="absolute inset-0 bg-red-100 rounded-full animate-ping opacity-20"></div>
                <div class="relative w-24 h-24 bg-red-50 rounded-full flex items-center justify-center text-red-500 border border-red-100">
                    <i data-lucide="shield-alert" class="w-12 h-12"></i>
                </div>
            </div>

            <h1 class="text-3xl font-black text-gray-800 mb-2 tracking-tighter uppercase leading-tight">Acesso Restrito</h1>
            <p class="text-gray-400 text-xs font-bold uppercase tracking-widest mb-10">Gateway de Segurança C3C Workspace</p>

            <div class="bg-red-50/50 border border-red-100 rounded-[32px] p-6 mb-10 text-left">
                <div class="flex items-start gap-4">
                    <div class="p-2 bg-white rounded-xl text-red-500 shadow-sm"><i data-lucide="info" class="w-5 h-5"></i></div>
                    <div>
                        <p class="text-[10px] font-black text-red-800 uppercase tracking-widest mb-1">Motivo do Bloqueio</p>
                        <p class="text-sm text-red-600 font-medium leading-relaxed">
                            <%= mensagem %>
                        </p>
                    </div>
                </div>
            </div>

            <div class="space-y-4">
                <button onclick="window.location.href='/logout'" class="w-full bg-c3c-gradient text-white font-black uppercase text-xs tracking-widest py-5 rounded-2xl shadow-xl shadow-blue-100 hover:opacity-90 transition-all active:scale-95">
                    Tentar Novamente
                </button>
                
                <a href="mailto:suporte@c3csoftware.com.br" class="block text-[10px] font-black text-gray-400 uppercase tracking-widest hover:text-c3c-blue transition-colors py-2">
                    Contatar Suporte Técnico
                </a>
            </div>
        </div>

        <div class="bg-gray-50/50 p-6 text-center border-t border-gray-100">
            <p class="text-[9px] text-gray-300 uppercase tracking-[0.3em] font-black italic">
                Protecting our ecosystem
            </p>
        </div>
    </div>

    <script>lucide.createIcons();</script>
</body>
</html>
