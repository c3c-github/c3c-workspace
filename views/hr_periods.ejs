<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ciclo Mensal - C3C Workplace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { 
                        c3c: { 
                            blue: '#2978FF', 
                            teal: '#1DDDBD', 
                            gray: '#F2F2F2',
                            dark: '#000000'
                        } 
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .bg-c3c-gradient { background: transparent linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%) 0% 0% no-repeat padding-box; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
        .status-badge { @apply px-3 py-1 rounded-full text-[9px] font-black uppercase border tracking-widest text-center; }
    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#F8FAFC]">

    <%- include('partials/sidebar', { page: 'hr' }) %>

    <main class="flex-1 flex flex-col md:ml-64 relative w-full transition-all duration-300 overflow-hidden">
        
        <!-- HEADER -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-20 shrink-0">
            <div class="flex items-center gap-4 text-left">
                <button onclick="document.getElementById('sidebar').classList.toggle('-translate-x-full')" class="md:hidden p-2 text-gray-600 hover:bg-gray-100 rounded-lg">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <div>
                    <h1 class="text-lg md:text-xl font-bold text-gray-800 flex items-center gap-2 tracking-tight">Gestão de Ciclos <span class="text-c3c-blue">📅</span></h1>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest hidden sm:block">Painel Administrativo de Períodos</p>
                </div>
            </div>
            
            <div class="flex items-center bg-gray-50 border border-gray-200 rounded-xl px-3 py-1.5 gap-2 shadow-sm focus-within:ring-2 focus-within:ring-c3c-blue transition-all">
                <i data-lucide="filter" class="w-4 h-4 text-c3c-blue"></i>
                <select id="cycle-selector" onchange="loadFunnelAndList()" class="bg-transparent text-sm font-bold text-gray-700 outline-none cursor-pointer min-w-[200px]">
                    <option value="">Carregando ciclos...</option>
                </select>
            </div>
        </header>

        <!-- CONTEÚDO -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 fade-in custom-scrollbar text-left">
            
            <!-- FUNIL DE STATUS -->
            <div class="mb-10 overflow-x-auto pb-4 no-scrollbar">
                <div class="flex gap-4 min-w-max" id="funnel-container">
                    <!-- Injetado via JS -->
                </div>
            </div>

            <!-- TOOLBAR DE AÇÕES -->
            <div class="mb-8 flex flex-col lg:flex-row lg:items-center justify-between gap-6 bg-white p-6 rounded-[32px] border border-gray-100 shadow-sm">
                <div class="flex flex-wrap items-center gap-4">
                    <div class="relative w-72 group">
                        <i data-lucide="search" class="w-4 h-4 text-gray-300 absolute left-4 top-1/2 -translate-y-1/2 group-focus-within:text-c3c-blue transition-colors"></i>
                        <input type="text" id="period-search" onkeyup="filterLocalList()" placeholder="Buscar colaborador..." class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-100 rounded-2xl text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all">
                    </div>
                    <select id="status-filter" onchange="loadFunnelAndList()" class="bg-gray-50 border border-gray-100 rounded-2xl px-5 py-3 text-xs font-black text-gray-500 uppercase tracking-widest outline-none focus:ring-4 focus:ring-blue-50 transition-all cursor-pointer">
                        <option value="">Todos os Status</option>
                        <option value="Aberto">Aberto</option>
                        <option value="Aguardando Aprovação Líder">Aguardando Líder</option>
                        <option value="Aguardando Aprovação RH">Aguardando RH</option>
                        <option value="Liberado para Nota Fiscal">Liberado p/ NF</option>
                        <option value="Nota em Validação">Nota em Validação</option>
                        <option value="Pronto para Pagamento">Pronto p/ Pagamento</option>
                    </select>
                </div>

                <div id="bulk-actions" class="hidden items-center gap-3 bg-blue-50 p-2 rounded-2xl border border-blue-100 fade-in">
                    <span class="text-[9px] font-black text-c3c-blue uppercase tracking-widest px-3" id="selected-count">0 selecionados</span>
                    <button onclick="handleBulkStatus('Aberto')" class="bg-white text-gray-600 border border-gray-200 px-4 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest hover:bg-red-50 hover:text-red-600 transition-all flex items-center gap-2"><i data-lucide="rotate-ccw" class="w-3.5 h-3.5"></i> Reabrir</button>
                    <button onclick="handleBulkStatus('Liberado para Nota Fiscal')" class="bg-c3c-gradient text-white px-6 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest shadow-lg shadow-blue-100 hover:opacity-90 transition-all flex items-center gap-2"><i data-lucide="check-circle" class="w-3.5 h-3.5"></i> Aprovar Tudo</button>
                </div>
            </div>

            <!-- TABELA -->
            <div class="bg-white rounded-[40px] shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-gray-50/50 border-b border-gray-100">
                            <tr class="text-[9px] font-black text-gray-400 uppercase tracking-widest">
                                <th class="px-8 py-5 w-10"><input type="checkbox" id="select-all" onchange="toggleSelectAll()" class="w-4 h-4 rounded border-gray-200 text-c3c-blue focus:ring-blue-100 transition-all"></th>
                                <th class="px-6 py-5">Colaborador</th>
                                <th class="px-6 py-5 text-center">Compliance</th>
                                <th class="px-6 py-5 text-center">Status do Período</th>
                                <th class="px-8 py-5 text-right">Ações Rápidas</th>
                            </tr>
                        </thead>
                        <tbody id="period-table-body" class="divide-y divide-gray-50">
                            <tr><td colspan="5" class="text-center py-20 text-gray-300 font-black uppercase text-[10px] tracking-widest animate-pulse">Carregando lista...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <script>
        lucide.createIcons();
        let allPeriods = [];
        const statusColors = { 
            'Aberto': 'bg-gray-100 text-gray-500 border-gray-200', 
            'Aguardando Aprovação Líder': 'bg-blue-50 text-c3c-blue border-blue-100', 
            'Aguardando Aprovação RH': 'bg-orange-50 text-orange-600 border-orange-100', 
            'Liberado para Nota Fiscal': 'bg-teal-50 text-teal-600 border-teal-100', 
            'Nota em Validação': 'bg-purple-50 text-purple-600 border-purple-100', 
            'Pronto para Pagamento': 'bg-green-50 text-green-600 border-green-100', 
            'Finalizado/Pago': 'bg-indigo-50 text-indigo-600 border-indigo-100' 
        };

        async function loadAvailableCycles() {
            try {
                const res = await fetch('/api/periods');
                const cycles = await res.json();
                const selector = document.getElementById('cycle-selector');
                selector.innerHTML = '';
                if (cycles.length === 0) { selector.innerHTML = '<option value="">Sem ciclos</option>'; return; }
                cycles.forEach(c => { selector.innerHTML += `<option value="${c.DataInicio__c}|${c.DataFim__c}">${c.Name}</option>`; });
                loadFunnelAndList();
            } catch (e) { console.error(e); }
        }

        async function loadFunnelAndList() {
            const cycleVal = document.getElementById('cycle-selector').value; if (!cycleVal) return;
            const [startDate, endDate] = cycleVal.split('|'), status = document.getElementById('status-filter').value;
            try {
                const resFunnel = await fetch(`/api/hr/periods/funnel?startDate=${startDate}&endDate=${endDate}`);
                renderFunnel(await resFunnel.json());
                const resList = await fetch(`/api/hr/periods/list?startDate=${startDate}&endDate=${endDate}&status=${status}`);
                allPeriods = await resList.json(); renderTable();
            } catch (e) { console.error(e); }
        }

        function renderFunnel(data) {
            const container = document.getElementById('funnel-container'); container.innerHTML = '';
            const possibleStatus = ['Aberto', 'Aguardando Aprovação Líder', 'Aguardando Aprovação RH', 'Liberado para Nota Fiscal', 'Nota em Validação', 'Pronto para Pagamento', 'Finalizado/Pago'];
            possibleStatus.forEach(st => {
                const item = data.find(d => d.Status__c === st) || { total: 0 };
                container.innerHTML += `<div class="bg-white p-5 rounded-3xl border border-gray-100 text-center hover:border-c3c-blue hover:shadow-lg transition-all cursor-pointer min-w-[130px] group" onclick="filterByStatus('${st}')"><p class="text-[8px] font-black text-gray-400 uppercase truncate mb-1 group-hover:text-c3c-blue transition-colors">${st}</p><p class="text-xl font-black text-gray-800">${item.total}</p></div>`;
            });
        }

        function renderTable() {
            const tbody = document.getElementById('period-table-body'), search = document.getElementById('period-search').value.toLowerCase();
            tbody.innerHTML = ''; const filtered = allPeriods.filter(p => p.employeeName.toLowerCase().includes(search));
            if (filtered.length === 0) { tbody.innerHTML = '<tr><td colspan="5" class="py-20 text-center text-gray-300 font-black uppercase text-[10px] tracking-widest italic">Nenhum registro</td></tr>'; return; }
            filtered.forEach(p => {
                const colorClass = statusColors[p.status] || 'bg-gray-50';
                const complianceColor = p.incompleteDays === 0 ? 'text-teal-600' : 'text-red-500';
                tbody.innerHTML += `
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="px-8 py-6 text-center"><input type="checkbox" name="period-check" value="${p.id}" onchange="updateBulkActions()" class="w-4 h-4 rounded border-gray-200 text-c3c-blue focus:ring-blue-100 transition-all"></td>
                        <td class="px-6 py-6 font-black text-gray-800 text-xs uppercase tracking-tighter">${p.employeeName}</td>
                        <td class="px-6 py-6 text-center"><span class="text-[10px] font-black ${complianceColor} uppercase tracking-widest">${p.incompleteDays === 0 ? '✓ Completo' : p.incompleteDays + ' pend.'}</span></td>
                        <td class="px-6 py-6 text-center"><span class="status-badge ${colorClass}">${p.status}</span></td>
                        <td class="px-8 py-6 text-right"><div class="flex justify-end gap-2"><button onclick="changeStatus(['${p.id}'], 'Aberto')" class="p-2.5 bg-gray-50 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all shadow-sm"><i data-lucide="rotate-ccw" class="w-4 h-4"></i></button><button onclick="changeStatus(['${p.id}'], 'Liberado para Nota Fiscal')" class="p-2.5 bg-gray-50 text-gray-400 hover:text-teal-600 hover:bg-teal-50 rounded-xl transition-all shadow-sm"><i data-lucide="check-circle" class="w-4 h-4"></i></button></div></td>
                    </tr>`;
            });
            lucide.createIcons();
        }

        function filterByStatus(st) { document.getElementById('status-filter').value = st; loadFunnelAndList(); }
        function filterLocalList() { renderTable(); }
        function toggleSelectAll() { const all = document.getElementById('select-all').checked; document.querySelectorAll('input[name="period-check"]').forEach(c => c.checked = all); updateBulkActions(); }
        function updateBulkActions() { const sel = document.querySelectorAll('input[name="period-check"]:checked'), bar = document.getElementById('bulk-actions'), lbl = document.getElementById('selected-count'); lbl.innerText = sel.length; if (sel.length > 0) bar.classList.replace('hidden', 'flex'); else bar.classList.replace('flex', 'hidden'); }
        async function handleBulkStatus(st) { const ids = Array.from(document.querySelectorAll('input[name="period-check"]:checked')).map(c => c.value); if (ids.length === 0) return; if (confirm(`Alterar ${ids.length} períodos para "${st}"?`)) await changeStatus(ids, st); }
        async function changeStatus(ids, st) { try { const res = await fetch('/api/hr/periods/status', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ periodIds: ids, newStatus: st }) }); if (res.ok) { loadFunnelAndList(); document.getElementById('select-all').checked = false; updateBulkActions(); } } catch (e) { console.error(e); } }
        
        loadAvailableCycles();
    </script>
</body>
</html>
