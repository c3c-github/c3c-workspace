        function validateCaClientSelection() {
            const input = document.getElementById('input-ca-client');
            const status = document.getElementById('ca-client-status');
            const list = document.getElementById('ca-clients-list');
            const val = input.value;
            
            const match = Array.from(list.options).find(opt => opt.value === val);
            if (match) {
                status.classList.remove('hidden');
                input.classList.add('border-teal-500', 'bg-teal-50/10');
