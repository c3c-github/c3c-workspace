            const reqReport = document.getElementById('input-req-report');
            const solReport = document.getElementById('input-sol-report');
            const labelSol = document.getElementById('label-sol-report');

            if (reqReport.checked) {
                solReport.checked = true;
                solReport.disabled = true;
                labelSol.classList.add('opacity-50', 'pointer-events-none');
            } else {
                solReport.disabled = false;
                labelSol.classList.remove('opacity-50', 'pointer-events-none');
            }
