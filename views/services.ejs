        function renderPersonPerformance(logs) {
            const body = document.getElementById('performance-consultant-body');
            const foot = document.getElementById('performance-consultant-foot');
            if (!body) return;
            body.innerHTML = '';
            if (foot) foot.innerHTML = '';

            if (!logs || logs.length === 0) {
                body.innerHTML = '<tr><td colspan="5" class="p-10 text-center text-gray-400 italic">Nenhum lançamento encontrado para este serviço.</td></tr>';
                return;
            }

            let totals = { hours: 0, revenue: 0, cost: 0 };

            logs.forEach(l => {
                const margin = l.margin || 0;
                totals.hours += (l.hours || 0);
                totals.revenue += (l.revenue || 0);
                totals.cost += (l.cost || 0);

                body.insertAdjacentHTML('beforeend', `
                    <tr class="divide-x divide-gray-50 hover:bg-gray-50/50 transition-all text-[11px]">
                        <td class="px-8 py-4 font-black text-gray-800 uppercase tracking-widest">${l.person}</td>
                        <td class="px-8 py-4 text-right font-bold text-gray-500">${l.hours.toFixed(1)}h</td>
                        <td class="px-8 py-4 text-right font-black text-teal-700 bg-teal-50/30">${money.format(l.revenue || 0)}</td>
                        <td class="px-8 py-4 text-right font-bold text-red-700 bg-red-50/30">${money.format(l.cost || 0)}</td>
                        <td class="px-8 py-4 text-center border-l border-gray-50">
                            <span class="px-3 py-1 rounded-full font-black ${margin >= 30 ? 'bg-teal-50 text-teal-600' : (margin < 0 ? 'bg-red-50 text-red-600' : 'bg-amber-50 text-amber-600')}">
                                ${margin.toFixed(1)}%
                            </span>
                        </td>
                    </tr>
                `);
            });

            // Totais no Rodapé
            const totalMarginPct = totals.revenue > 0 ? ((totals.revenue - totals.cost) / totals.revenue) * 100 : (totals.cost > 0 ? -100 : 0);

            if(foot) {
                foot.innerHTML = `
                    <tr class="divide-x divide-gray-100 bg-gray-100/30">
                        <td class="px-8 py-5 uppercase tracking-widest text-[9px]">Totais por Consultor</td>
                        <td class="px-8 py-5 text-right text-gray-800">${totals.hours.toFixed(1)}h</td>
                        <td class="px-8 text-right text-teal-700">${money.format(totals.revenue)}</td>
                        <td class="px-8 text-right text-red-500">${money.format(totals.cost)}</td>
                        <td class="px-8 text-center font-black text-teal-700 border-l border-gray-100">${totalMarginPct.toFixed(1)}%</td>
                    </tr>
                `;
            }
        }
        function renderFinancialGrid(consolidated) {
            const gridBody = document.getElementById('realized-monthly-body');
            const gridFoot = document.getElementById('realized-monthly-foot');
            if (!gridBody) return;

            gridBody.innerHTML = '';
            let totals = { realRev: 0, realCost: 0, realHrs: 0 };

            consolidated.forEach(m => {
                const dateLabel = m.month.split('-').reverse().slice(1).join('/'); // MM/YYYY
                const realMarginValue = (m.realized.revenue || 0) - (m.realized.cost || 0);
                const realMarginPct = m.realized.revenue > 0 ? (realMarginValue / m.realized.revenue) * 100 : (m.realized.cost > 0 ? -100 : 0);

                totals.realRev += (m.realized.revenue || 0);
                totals.realCost += (m.realized.cost || 0);
                totals.realHrs += (m.realized.hours || 0);

                gridBody.insertAdjacentHTML('beforeend', `
                    <tr class="divide-x divide-gray-50 hover:bg-gray-50/50 transition-all text-[11px]">
                        <td class="px-8 py-4 font-black text-gray-800">${dateLabel}</td>
                        <td class="px-8 text-right font-black text-teal-700 bg-teal-50/30">${money.format(m.realized.revenue || 0)}</td>
                        <td class="px-8 text-right font-bold text-red-700 bg-red-50/30">${money.format(m.realized.cost || 0)}</td>
                        <td class="px-8 text-right font-bold text-gray-600">${m.realized.hours.toFixed(1)}h</td>
                        <td class="px-8 text-center border-l border-gray-50">
                            <span class="px-3 py-1 rounded-full font-black ${realMarginPct >= 30 ? 'bg-teal-50 text-teal-600' : 'bg-amber-50 text-amber-600'}">
                                ${realMarginPct.toFixed(1)}%
                            </span>
                        </td>
                    </tr>
                `);
            });

            // --- ATUALIZAR KPIs GLOBAIS ---
            const avgRate = totals.realHrs > 0 ? (totals.realRev / totals.realHrs) : 0;
            const costEff = totals.realHrs > 0 ? (totals.realCost / totals.realHrs) : 0;
            const totalMarginPct = totals.realRev > 0 ? ((totals.realRev - totals.realCost) / totals.realRev) * 100 : (totals.realCost > 0 ? -100 : 0);

            document.getElementById('kpi-avg-rate').innerText = money.format(avgRate) + '/h';
            document.getElementById('kpi-cost-efficiency').innerText = money.format(costEff) + '/h';
            document.getElementById('kpi-total-hours').innerText = totals.realHrs.toFixed(1) + 'h';
            document.getElementById('kpi-realized-margin').innerText = totalMarginPct.toFixed(1) + '%';

            if(gridFoot) {
                gridFoot.innerHTML = `
                    <tr class="divide-x divide-gray-100 bg-gray-100/30">
                        <td class="px-8 py-5 uppercase tracking-widest text-[9px]">Totais Consolidados</td>
                        <td class="px-8 text-right text-teal-700 bg-teal-100/10">${money.format(totals.realRev)}</td>
                        <td class="px-8 text-right text-red-500 bg-red-100/10">${money.format(totals.realCost)}</td>
                        <td class="px-8 text-right text-gray-800">${totals.realHrs.toFixed(1)}h</td>
                        <td class="px-8 text-center font-black text-teal-700 border-l border-gray-100">${totalMarginPct.toFixed(1)}%</td>
                    </tr>
                `;
            }

            updateSummaryCards(currentServiceData.prop?.rev, currentServiceData.prop?.margin, currentServiceData.fcst?.rev, currentServiceData.fcst?.margin, totals.realRev, totalMarginPct, totals.realCost);
        }

