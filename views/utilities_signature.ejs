<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Assinatura - C3C Workplace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { 
                        c3c: { 
                            blue: '#2978FF', 
                            teal: '#1DDDBD', 
                            gray: '#F2F2F2',
                            dark: '#000000'
                        } 
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .bg-c3c-gradient { background: transparent linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%) 0% 0% no-repeat padding-box; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#F8FAFC]">

    <div id="mobile-overlay" onclick="toggleMenu()" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden transition-opacity opacity-0 backdrop-blur-sm"></div>

    <%- include('partials/sidebar', { page: 'utilities_signature' }) %>

    <main class="flex-1 flex flex-col md:ml-64 relative w-full transition-all duration-300 overflow-hidden">
        
        <!-- HEADER -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-20 shrink-0">
            <div class="flex items-center gap-4 text-left">
                <button onclick="toggleMenu()" class="md:hidden p-2 text-gray-600 hover:bg-gray-100 rounded-lg">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <div>
                    <h1 class="text-lg md:text-xl font-bold text-gray-800 flex items-center gap-2 tracking-tight">Assinatura Corporativa <span class="text-c3c-blue">🎨</span></h1>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest hidden sm:block">Padronize sua identidade oficial C3C</p>
                </div>
            </div>
        </header>

        <!-- CONTEÚDO -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 fade-in custom-scrollbar">
            
            <div class="grid grid-cols-1 xl:grid-cols-12 gap-8 items-start">
                
                <!-- FORMULÁRIO -->
                <div class="xl:col-span-4 bg-white p-8 rounded-[32px] shadow-sm border border-gray-100 text-left">
                    <h2 class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-8 flex items-center gap-2">
                        <i data-lucide="user-plus" class="w-4 h-4 text-c3c-blue"></i> Configurações
                    </h2>
                    
                    <div class="space-y-6">
                        <div>
                            <label class="block text-[10px] font-black text-gray-400 uppercase mb-2 tracking-widest px-2">Seu Nome</label>
                            <input type="text" id="input-name" value="<%= user.nome %>" class="w-full px-5 py-3 text-sm font-bold border border-gray-100 rounded-2xl outline-none focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue bg-gray-50/50 transition-all">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-gray-400 uppercase mb-2 tracking-widest px-2">Cargo Oficial</label>
                            <input type="text" id="input-role" placeholder="Ex: Arquiteto de Soluções" class="w-full px-5 py-3 text-sm font-bold border border-gray-100 rounded-2xl outline-none focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue bg-gray-50/50 transition-all">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-gray-400 uppercase mb-2 tracking-widest px-2">WhatsApp</label>
                            <input type="text" id="input-phone" maxlength="15" placeholder="(00) 00000-0000" class="w-full px-5 py-3 text-sm font-bold border border-gray-100 rounded-2xl outline-none focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue bg-gray-50/50 transition-all">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-gray-400 uppercase mb-2 tracking-widest px-2">E-mail</label>
                            <input type="email" id="input-email" value="<%= user.email %>" class="w-full px-5 py-3 text-sm font-bold border border-gray-100 rounded-2xl outline-none focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue bg-gray-50/50 transition-all">
                        </div>
                        
                        <div class="pt-6 border-t border-gray-50">
                            <label class="block text-[10px] font-black text-gray-400 uppercase mb-3 tracking-widest px-2 flex justify-between items-center">
                                Foto de Perfil
                                <span id="upload-status" class="text-[8px] lowercase font-bold text-teal-600 bg-teal-50 px-2 py-0.5 rounded-full hidden"></span>
                            </label>
                            
                            <div class="relative group">
                                <input type="file" id="input-file" accept="image/*" class="hidden">
                                <label for="input-file" class="w-full flex items-center gap-4 px-5 py-4 border-2 border-dashed border-gray-100 rounded-[24px] cursor-pointer hover:border-c3c-blue hover:bg-blue-50/30 transition-all group">
                                    <div class="w-12 h-12 bg-gray-50 rounded-2xl flex items-center justify-center text-gray-300 group-hover:bg-white group-hover:text-c3c-blue transition-all shadow-sm">
                                        <i data-lucide="camera" class="w-6 h-6"></i>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-xs font-black text-gray-600 uppercase tracking-tighter truncate">Alterar Imagem</p>
                                        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">JPG/PNG até 2MB</p>
                                    </div>
                                </label>
                            </div>

                            <div id="progress-container" class="mt-4 hidden">
                                <div class="w-full bg-gray-100 rounded-full h-1.5 overflow-hidden">
                                    <div id="progress-bar" class="bg-c3c-blue h-full transition-all duration-300" style="width: 0%"></div>
                                </div>
                            </div>
                            
                            <input type="hidden" id="input-photo" value="<%= user.foto || '' %>">
                            
                            <div class="mt-6 bg-blue-50/50 p-5 rounded-3xl border border-blue-100">
                                <label class="block text-[9px] font-black text-c3c-blue uppercase mb-3 tracking-[0.2em] px-1">Escolha seu Mascote:</label>
                                <div class="grid grid-cols-3 gap-3">
                                    <button onclick="setMascot('capivorce')" class="mascot-btn p-2 bg-white rounded-2xl border border-blue-100 hover:shadow-md transition-all active:scale-95 group" id="btn-mascot-capivorce">
                                        <img src="/assets/signatures/assinaturaCapivorce.png" class="w-10 h-10 rounded-full mx-auto group-hover:scale-110 transition-transform">
                                    </button>
                                    <button onclick="setMascot('mestrecoala')" class="mascot-btn p-2 bg-white rounded-2xl border border-transparent hover:shadow-md transition-all active:scale-95 group opacity-40" id="btn-mascot-mestrecoala">
                                        <img src="/assets/signatures/assinaturaMestreCoala.png" class="w-10 h-10 rounded-full mx-auto group-hover:scale-110 transition-transform">
                                    </button>
                                    <button onclick="setMascot('salesmelo')" class="mascot-btn p-2 bg-white rounded-2xl border border-transparent hover:shadow-md transition-all active:scale-95 group opacity-40" id="btn-mascot-salesmelo">
                                        <img src="/assets/signatures/assinaturaSalesmelo.png" class="w-10 h-10 rounded-full mx-auto group-hover:scale-110 transition-transform">
                                    </button>
                                </div>
                                <input type="hidden" id="select-mascot" value="capivorce">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- PREVIEW -->
                <div class="xl:col-span-8 flex flex-col items-center">
                    <h2 class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-8 flex items-center gap-2 self-start px-2">
                        <i data-lucide="monitor" class="w-4 h-4"></i> Preview da Assinatura
                    </h2>
                    
                    <div class="w-full bg-white p-12 md:p-20 rounded-[48px] shadow-sm border border-gray-100 overflow-x-auto flex flex-col items-center">
                        <div id="signature-container" class="bg-white p-1">
                            <!-- TABELA DE ASSINATURA -->
                            <table id="signature-table" border="0" cellpadding="0" cellspacing="0" style="width: 560px; min-width: 560px; border-collapse: collapse; font-family: 'Montserrat', Helvetica, Arial, sans-serif; background-color: #ffffff;">
                                <tr>
                                    <td style="padding-bottom: 12px;">
                                        <table border="0" cellpadding="0" cellspacing="0" width="100%">
                                            <tr>
                                                <!-- Foto de Perfil -->
                                                <td width="80" valign="middle" style="padding-right: 20px;">
                                                    <img id="view-photo" src="" alt="Perfil" width="80" height="80" style="width: 80px; height: 80px; min-width: 80px; min-height: 80px; border-radius: 40px; object-fit: cover; display: block; background-color: #f8fafc;">
                                                </td>
                                                
                                                <!-- Divisor Azul -->
                                                <td width="2" style="background-color: #2978FF; font-size: 1px; line-height: 1px;">&nbsp;</td>
                                                
                                                <!-- Dados -->
                                                <td valign="middle" style="padding: 0 25px;">
                                                    <h3 id="view-name" style="margin: 0; font-size: 20px; font-weight: 800; color: #0f172a; line-height: 1.1; letter-spacing: -0.02em;">Nome do Colaborador</h3>
                                                    <p id="view-role" style="margin: 4px 0 12px 0; font-size: 10px; font-weight: 700; color: #2978FF; text-transform: uppercase; letter-spacing: 0.1em; display: block;">Cargo na Empresa</p>
                                                    
                                                    <table border="0" cellpadding="0" cellspacing="0">
                                                        <tr id="view-phone-row">
                                                            <td width="16" valign="middle"><img src="https://img.icons8.com/ios-filled/32/2978FF/whatsapp.png" width="12" alt="WA"></td>
                                                            <td style="font-size: 11px; color: #64748b; font-weight: 600; padding-left: 6px;" valign="middle">
                                                                <a id="view-wa-link" href="#" style="color: #64748b; text-decoration: none;"><span id="view-phone-text"></span></a>
                                                            </td>
                                                        </tr>
                                                        <tr id="view-email-row">
                                                            <td width="16" style="padding-top: 6px;" valign="middle"><img src="https://img.icons8.com/ios-filled/32/2978FF/mail.png" width="12" alt="MAIL"></td>
                                                            <td style="font-size: 11px; color: #64748b; font-weight: 600; padding-left: 6px; padding-top: 6px;" valign="middle">
                                                                <a id="view-email-link" href="#" style="color: #64748b; text-decoration: none;"><span id="view-email-text"></span></a>
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td width="16" style="padding-top: 6px;" valign="middle"><img src="https://img.icons8.com/ios-filled/32/2978FF/globe.png" width="12" alt="W"></td>
                                                            <td style="font-size: 11px; color: #64748b; font-weight: 600; padding-left: 6px; padding-top: 6px;" valign="middle">
                                                                <a href="https://c3csoftware.com.br" style="color: #64748b; text-decoration: none;">c3csoftware.com.br</a>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </td>
        
                                                <!-- Mascote -->
                                                <td width="65" valign="middle" align="right" style="padding-right: 15px;">
                                                    <img id="view-mascot-img" src="" alt="Mascote" width="65" height="65" style="width: 65px; height: 65px; min-width: 65px; min-height: 65px; border-radius: 33px; object-fit: cover; display: block; background-color: #f8fafc;">
                                                </td>
        
                                                <!-- Salesforce Partner -->
                                                <td width="65" valign="middle" align="right">
                                                    <a href="https://appexchange.salesforce.com/appxConsultingListingDetail?listingId=a0N3u00000MRhO8EAL&legacy=true" target="_blank" style="text-decoration: none; display: block;">
                                                        <img src="https://www.simantel.com/wp-content/uploads/2020/02/Salesforce-Partner-Logo.png" alt="Salesforce Partner" width="65" height="65" style="width: 65px; height: 65px; min-width: 65px; min-height: 65px; border-radius: 33px; object-fit: contain; display: block; background-color: #ffffff;">
                                                    </a>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                
                                <tr>
                                    <td height="2" style="border-bottom: 2px solid #2978FF; font-size: 1px; line-height: 1px;"></td>
                                </tr>
        
                                <tr>
                                    <td style="padding-top: 18px;">
                                        <table width="100%" border="0" cellpadding="0" cellspacing="0">
                                            <tr>
                                                <td valign="middle">
                                                    <table border="0" cellpadding="0" cellspacing="0">
                                                        <tr>
                                                            <td id="footer-logo-td" valign="middle">
                                                                <img src="<%= baseUrl %>/assets/signatures/assinaturaLogo.png" alt="C3C" height="22" style="height: 22px; display: block;">
                                                            </td>                                                            
                                                            <td id="footer-text-td" valign="middle" style="padding-left: 8px; font-size: 14px; font-weight: 800; color: #0f172a; font-family: 'Montserrat', sans-serif; line-height: 22px; text-transform: uppercase; letter-spacing: 0.05em;">
                                                                C3C<span style="color: #1DDDBD;">.</span>Software
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </td>
                                                <td align="right" valign="middle">
                                                    <table border="0" cellpadding="0" cellspacing="0">
                                                        <tr>
                                                            <td style="padding-left: 15px;">
                                                                <a href="https://www.linkedin.com/company/c3c-software" target="_blank">
                                                                    <img src="https://img.icons8.com/ios-filled/50/2978FF/linkedin-circled--v1.png" width="22" alt="LinkedIn">
                                                                </a>
                                                            </td>
                                                            <td style="padding-left: 15px;">
                                                                <a href="https://www.instagram.com/c3csoftware/" target="_blank">
                                                                    <img src="https://img.icons8.com/ios-filled/50/2978FF/instagram-new.png" width="22" alt="Instagram">
                                                                </a>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- AÇÕES -->
                        <div class="mt-12 w-full max-w-2xl flex flex-col sm:flex-row gap-4 justify-center items-center">
                            <button id="btn-copy" class="w-full sm:w-64 bg-c3c-gradient text-white font-black uppercase text-xs tracking-widest py-5 rounded-2xl shadow-xl shadow-blue-100 hover:opacity-90 active:scale-95 transition-all flex items-center justify-center gap-3">
                                <i data-lucide="copy" class="w-5 h-5"></i> Copiar Assinatura
                            </button>
                            <button id="btn-download" class="w-full sm:w-48 bg-white border-2 border-gray-100 text-gray-400 font-black uppercase text-xs tracking-widest py-5 rounded-2xl hover:bg-gray-50 transition-all flex items-center justify-center gap-2">
                                <i data-lucide="download" class="w-5 h-5"></i> Baixar HTML
                            </button>
                        </div>
                        <p id="copy-message" class="hidden text-[10px] font-black text-teal-600 uppercase tracking-widest mt-4 animate-bounce">✓ Pronta para colar no Outlook!</p>
                    </div>

                    <!-- GUIA OUTLOOK -->
                    <div class="mt-12 w-full max-w-4xl bg-blue-600 rounded-[40px] p-10 text-white shadow-2xl shadow-blue-200 relative overflow-hidden text-left">
                        <div class="absolute -right-20 -top-20 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
                        <div class="relative z-10">
                            <h3 class="text-2xl font-black mb-8 flex items-center gap-4 tracking-tighter uppercase">
                                <i data-lucide="help-circle" class="w-8 h-8 text-blue-200"></i> Como configurar no Outlook?
                            </h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                <div class="flex gap-5 items-start bg-white/10 p-6 rounded-3xl backdrop-blur-sm border border-white/10">
                                    <div class="w-10 h-10 rounded-2xl bg-white text-blue-600 flex items-center justify-center text-lg font-black shrink-0 shadow-sm">1</div>
                                    <p class="text-sm font-bold leading-relaxed uppercase tracking-tight">No Outlook, vá em <b>Configurações</b> (ícone da engrenagem no topo à direita).</p>
                                </div>
                                <div class="flex gap-5 items-start bg-white/10 p-6 rounded-3xl backdrop-blur-sm border border-white/10">
                                    <div class="w-10 h-10 rounded-2xl bg-white text-blue-600 flex items-center justify-center text-lg font-black shrink-0 shadow-sm">2</div>
                                    <p class="text-sm font-bold leading-relaxed uppercase tracking-tight">Busque por <b>"Assinatura"</b> e selecione <b>Assinatura de e-mail</b>.</p>
                                </div>
                                <div class="flex gap-5 items-start bg-white/10 p-6 rounded-3xl backdrop-blur-sm border border-white/10">
                                    <div class="w-10 h-10 rounded-2xl bg-white text-blue-600 flex items-center justify-center text-lg font-black shrink-0 shadow-sm">3</div>
                                    <p class="text-sm font-bold leading-relaxed uppercase tracking-tight">Clique em <b>+ Nova</b> e no campo de edição dê um <b>Ctrl + V</b>.</p>
                                </div>
                                <div class="flex gap-5 items-start bg-white/10 p-6 rounded-3xl backdrop-blur-sm border border-white/10">
                                    <div class="w-10 h-10 rounded-2xl bg-white text-blue-600 flex items-center justify-center text-lg font-black shrink-0 shadow-sm">4</div>
                                    <p class="text-sm font-bold leading-relaxed uppercase tracking-tight">Marque as opções <b>"Padrão para Novas Mensagens"</b> e clique em <b>Salvar</b>. 🚀</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <script>
        lucide.createIcons();

        function toggleMenu() {
            const s=document.getElementById('sidebar'), o=document.getElementById('mobile-overlay');
            s.classList.toggle('-translate-x-full'); o.classList.toggle('hidden');
            setTimeout(() => o.classList.toggle('opacity-0'), 10);
        }

        const logoUrl = "<%= baseUrl %>/assets/signatures/assinaturaLogo.png";
        const officialMascots = {
            capivorce: '<%= baseUrl %>/assets/signatures/assinaturaCapivorce.png',
            mestrecoala: '<%= baseUrl %>/assets/signatures/assinaturaMestreCoala.png',
            salesmelo: '<%= baseUrl %>/assets/signatures/assinaturaSalesmelo.png'
        };

        const inputs = {
            name: document.getElementById('input-name'),
            role: document.getElementById('input-role'),
            phone: document.getElementById('input-phone'),
            email: document.getElementById('input-email'),
            photo: document.getElementById('input-photo'),
            mascot: document.getElementById('select-mascot')
        };

        const view = {
            name: document.getElementById('view-name'),
            role: document.getElementById('view-role'),
            phoneRow: document.getElementById('view-phone-row'),
            phoneText: document.getElementById('view-phone-text'),
            waLink: document.getElementById('view-wa-link'),
            emailRow: document.getElementById('view-email-row'),
            emailText: document.getElementById('view-email-text'),
            emailLink: document.getElementById('view-email-link'),
            photo: document.getElementById('view-photo'),
            mascotImg: document.getElementById('view-mascot-img'),
            footerLogoTd: document.getElementById('footer-logo-td'),
            footerTextTd: document.getElementById('footer-text-td')
        };

        function setMascot(slug) {
            inputs.mascot.value = slug;
            document.querySelectorAll('.mascot-btn').forEach(btn => {
                btn.classList.add('opacity-40', 'border-transparent');
                btn.classList.remove('border-blue-100');
            });
            const activeBtn = document.getElementById(`btn-mascot-${slug}`);
            activeBtn.classList.remove('opacity-40', 'border-transparent');
            activeBtn.classList.add('border-blue-100');
            updatePreview();
        }

        function phoneMask(v) {
            v = v.replace(/\D/g, "");
            v = v.replace(/^(\d{2})(\d)/g, "($1) $2");
            v = v.replace(/(\d)(\d{4})$/, "$1-$2");
            return v;
        }

        function updatePreview() {
            view.name.innerText = inputs.name.value || 'Seu Nome';
            const r = inputs.role.value.trim();
            view.role.innerText = r || 'Seu Cargo';
            view.role.style.display = r ? 'block' : 'block';
            
            const p = inputs.phone.value.trim();
            if (p === "") view.phoneRow.style.display = 'none';
            else { view.phoneRow.style.display = 'table-row'; view.phoneText.innerText = p; view.waLink.href = `https://wa.me/55${p.replace(/\D/g, '')}`; }

            const e = inputs.email.value.trim();
            if (e === "") view.emailRow.style.display = 'none';
            else { view.emailRow.style.display = 'table-row'; view.emailText.innerText = e; view.emailLink.href = `mailto:${e}`; }

            const ph = inputs.photo.value.trim();
            if (ph === "") { view.photo.src = logoUrl; view.photo.style.objectFit = "contain"; view.footerLogoTd.style.display = 'none'; view.footerTextTd.style.paddingLeft = '0px'; }
            else { view.photo.src = ph; view.photo.style.objectFit = "cover"; view.footerLogoTd.style.display = 'table-cell'; view.footerTextTd.style.paddingLeft = '8px'; }

            view.mascotImg.src = officialMascots[inputs.mascot.value];
        }

        inputs.phone.addEventListener('input', (e) => { e.target.value = phoneMask(e.target.value); updatePreview(); });
        ['name', 'role', 'email'].forEach(k => inputs[k].addEventListener('input', updatePreview));

        document.getElementById('input-file').addEventListener('change', async (e) => {
            const f = e.target.files[0]; if (!f) return;
            if (f.size > 2 * 1024 * 1024) return alert('Máximo 2MB.');
            const fd = new FormData(); fd.append('file', f);
            const pc = document.getElementById('progress-container'), pb = document.getElementById('progress-bar'), us = document.getElementById('upload-status');
            pc.classList.remove('hidden'); pb.style.width = '0%'; us.innerText = 'subindo...'; us.classList.remove('hidden');
            const xhr = new XMLHttpRequest(); xhr.open('POST', '/api/utility/upload-photo', true);
            xhr.upload.onprogress = (ev) => { if (ev.lengthComputable) pb.style.width = Math.round((ev.loaded / ev.total) * 100) + '%'; };
            xhr.onload = function() {
                if (xhr.status === 200) { inputs.photo.value = JSON.parse(xhr.responseText).url; updatePreview(); us.innerText = '✓ sucesso'; setTimeout(() => { pc.classList.add('hidden'); us.classList.add('hidden'); }, 2000); }
                else { alert('Erro no upload.'); pc.classList.add('hidden'); }
            };
            xhr.send(fd);
        });

        document.getElementById('btn-copy').addEventListener('click', function() {
            const t = document.getElementById('signature-table'), r = document.createRange();
            r.selectNode(t); window.getSelection().removeAllRanges(); window.getSelection().addRange(r);
            try {
                document.execCommand('copy');
                const b = document.getElementById('btn-copy'), old = b.innerHTML;
                b.innerHTML = '<i data-lucide="check" class="w-5 h-5"></i> Copiado!';
                b.classList.replace('bg-c3c-gradient', 'bg-teal-600'); lucide.createIcons();
                document.getElementById('copy-message').classList.remove('hidden');
                setTimeout(() => { b.innerHTML = old; b.classList.replace('bg-teal-600', 'bg-c3c-gradient'); document.getElementById('copy-message').classList.add('hidden'); lucide.createIcons(); }, 3000);
            } catch (err) {}
            window.getSelection().removeAllRanges();
        });

        document.getElementById('btn-download').addEventListener('click', function() {
            const h = document.getElementById('signature-container').innerHTML, b = new Blob([h], { type: 'text/html' }), u = window.URL.createObjectURL(b), a = document.createElement('a');
            a.href = u; a.download = `assinatura_c3c.html`; document.body.appendChild(a); a.click(); window.URL.revokeObjectURL(u); document.body.removeChild(a);
        });

        updatePreview();
    </script>
</body>
</html>
