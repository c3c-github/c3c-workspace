                <!-- 5. EXTRATO REAL -->
                <div id="view-realized" class="hidden fade-in space-y-8 text-left">
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                        <div class="lg:col-span-2 space-y-8">
                            <h4 class="text-xs font-black text-gray-800 uppercase tracking-[0.3em] flex items-center gap-2"><i data-lucide="activity" class="w-4 h-4 text-teal-500"></i> Execução Real (Timesheet YTD)</h4>
                            <div class="bg-white rounded-[32px] border border-gray-100 shadow-xl overflow-hidden">
                                <table class="w-full text-left table-dense">
                                    <thead class="bg-gray-50/80 border-b border-gray-100">
                                        <tr>
                                            <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest py-5 px-6">Consultor</th>
                                            <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Hrs Lançadas</th>
                                            <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Custo Incorrido</th>
                                            <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Preço Venda</th>
                                            <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Rec. Medida</th>
                                            <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center px-6">Margem</th>
