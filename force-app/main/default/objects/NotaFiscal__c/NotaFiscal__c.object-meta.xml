<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Gestão de Notas Fiscais vinculadas aos ciclos de faturamento.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableBulkApi>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableHistory>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSearch>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <label>Nota Fiscal</label>
    <nameField>
        <displayFormat>NF-{000000}</displayFormat>
        <label>Número NF</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Notas Fiscais</label>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
