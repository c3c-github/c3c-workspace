        function addBillingRow(d={}) { 
            const t=document.getElementById('svc-billing-list'); const r=t.children.length+1; 
            const tr = document.createElement('tr');
            tr.className = "billing-row group hover:bg-gray-50";
            tr.dataset.originSaleId = d.originSaleId || '';
            tr.dataset.status = d.status || 'Pendente';
