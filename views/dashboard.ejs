<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minha Eficiência - C3C</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { 
                        c3c: { 
                            blue: '#2978FF', 
                            teal: '#1DDDBD', 
                            gray: '#F2F2F2'
                        } 
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .bg-c3c-gradient { background: transparent linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%) 0% 0% no-repeat padding-box; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#F8FAFC]">

    <div id="mobile-overlay" onclick="toggleMenu()" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden transition-opacity opacity-0"></div>

    <%- include('partials/sidebar', { page: 'dashboard' }) %>

    <main class="flex-1 flex flex-col md:ml-64 relative w-full transition-all duration-300">
        
        <!-- HEADER -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-20">
            <div class="flex items-center gap-4">
                <button onclick="toggleMenu()" class="md:hidden p-2 text-gray-600 hover:bg-gray-100 rounded-lg">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <div>
                    <h1 class="text-lg md:text-xl font-bold text-gray-800">Minha Eficiência <span class="text-c3c-blue">🚀</span></h1>
                    <p class="text-xs text-gray-400 hidden sm:block">Acompanhe seu desempenho e banco de horas</p>
                </div>
            </div>
            
            <div class="flex items-center gap-3">
                <div class="flex items-center bg-gray-50 rounded-lg border border-gray-200 px-3 py-1.5 gap-2 shadow-sm focus-within:ring-2 focus-within:ring-c3c-blue">
                    <i data-lucide="calendar" class="w-4 h-4 text-c3c-blue"></i>
                    <select id="period-selector" onchange="triggerDataLoad(this.value)" class="bg-transparent text-sm font-bold text-gray-700 outline-none cursor-pointer min-w-[150px]">
                        <option>Carregando...</option>
                    </select>
                </div>
            </div>
        </header>

        <!-- CONTEÚDO -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 fade-in">
            
            <!-- STEPPER: MEU CICLO FINANCEIRO -->
            <div class="mb-8 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm relative overflow-hidden">
                <div class="absolute top-0 left-0 w-1 h-full bg-c3c-blue"></div>
                
                <!-- CARD DE AÇÃO NF (DENTRO DO CICLO) -->
                <div id="nf-action-card" class="hidden mb-6 p-4 rounded-xl border flex flex-col md:flex-row items-center justify-between gap-4 animate-bounce">
                    <div class="flex items-center gap-3 text-left">
                        <div id="nf-action-icon-bg" class="p-2 rounded-lg">
                            <i id="nf-action-icon" data-lucide="info" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <p id="nf-action-title" class="text-sm font-bold text-gray-800"></p>
                            <p id="nf-action-desc" class="text-xs text-gray-500"></p>
                        </div>
                    </div>
                    <a href="/billing-portal" class="bg-c3c-blue hover:bg-blue-700 text-white text-xs font-bold px-4 py-2 rounded-lg shadow-md transition-all whitespace-nowrap">
                        Portal de Notas
                    </a>
                </div>

                <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                    <div class="text-left">
                        <h2 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-1">Meu Ciclo Financeiro</h2>
                        <p id="ciclo-status-desc" class="text-lg font-bold text-gray-800">Carregando jornada...</p>
                    </div>
                    <div id="ciclo-compliance-badge" class="hidden px-4 py-2 bg-blue-50 text-c3c-blue rounded-xl border border-blue-100 text-xs font-bold items-center gap-2">
                        <i data-lucide="check-circle" class="w-4 h-4"></i>
                        <span id="ciclo-compliance-text">0/0 dias úteis</span>
                    </div>
                </div>

                <!-- Stepper UI -->
                <div class="mt-8 flex items-center w-full">
                    <div id="step-1" class="relative flex-1 group">
                        <div class="flex items-center">
                            <div id="step-1-circle" class="w-10 h-10 rounded-full border-2 border-gray-200 bg-white flex items-center justify-center transition-all z-10 text-gray-300">
                                <i data-lucide="edit-3" class="w-5 h-5"></i>
                            </div>
                            <div class="flex-1 h-1 bg-gray-100 -ml-1 -mr-1"><div id="step-1-line" class="h-full bg-c3c-blue w-0 transition-all duration-500"></div></div>
                        </div>
                        <div class="mt-2 text-[10px] font-bold text-gray-400 uppercase">Apontamento</div>
                    </div>
                    <div id="step-2" class="relative flex-1 group">
                        <div class="flex items-center">
                            <div id="step-2-circle" class="w-10 h-10 rounded-full border-2 border-gray-200 bg-white flex items-center justify-center transition-all z-10 text-gray-300">
                                <i data-lucide="check-square" class="w-5 h-5"></i>
                            </div>
                            <div class="flex-1 h-1 bg-gray-100 -ml-1 -mr-1"><div id="step-2-line" class="h-full bg-c3c-blue w-0 transition-all duration-500"></div></div>
                        </div>
                        <div class="mt-2 text-[10px] font-bold text-gray-400 uppercase">Aprovação</div>
                    </div>
                    <div id="step-3" class="relative flex-1 group">
                        <div class="flex items-center">
                            <div id="step-3-circle" class="w-10 h-10 rounded-full border-2 border-gray-200 bg-white flex items-center justify-center transition-all z-10 text-gray-300">
                                <i data-lucide="file-text" class="w-5 h-5"></i>
                            </div>
                            <div class="flex-1 h-1 bg-gray-100 -ml-1 -mr-1"><div id="step-3-line" class="h-full bg-c3c-blue w-0 transition-all duration-500"></div></div>
                        </div>
                        <div class="mt-2 text-[10px] font-bold text-gray-400 uppercase">Nota Fiscal</div>
                    </div>
                    <div id="step-4" class="relative group">
                        <div class="flex items-center">
                            <div id="step-4-circle" class="w-10 h-10 rounded-full border-2 border-gray-200 bg-white flex items-center justify-center transition-all z-10 text-gray-300">
                                <i data-lucide="banknote" class="w-5 h-5"></i>
                            </div>
                        </div>
                        <div class="mt-2 text-[10px] font-bold text-gray-400 uppercase">Pagamento</div>
                    </div>
                </div>
            </div>
            
            <!-- KPIs -->
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
                
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-shadow">
                    <div class="absolute right-0 top-0 w-24 h-24 bg-blue-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
                    <div class="relative z-10 text-left">
                        <div class="flex items-center gap-2 mb-2">
                            <div class="p-2 bg-blue-100 rounded-lg text-c3c-blue"><i data-lucide="activity" class="w-5 h-5"></i></div>
                            <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Eficiência</span>
                        </div>
                        <div class="flex items-baseline gap-1 mt-4">
                            <span id="kpi-eficiencia" class="text-4xl font-extrabold text-gray-800 demo-blur">--</span>
                            <span class="text-sm text-gray-400 font-medium">%</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-shadow">
                    <div class="absolute right-0 top-0 w-24 h-24 bg-teal-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
                    <div class="relative z-10 text-left">
                        <div class="flex items-center gap-2 mb-2">
                            <div class="p-2 bg-teal-100 rounded-lg text-c3c-teal"><i data-lucide="clock" class="w-5 h-5"></i></div>
                            <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Banco de Horas</span>
                        </div>
                        <div class="flex items-baseline gap-1 mt-4">
                            <span id="kpi-banco" class="text-4xl font-extrabold text-gray-800 demo-blur">--</span>
                            <span class="text-sm text-gray-400 font-medium">h</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-shadow">
                    <div class="absolute right-0 top-0 w-24 h-24 bg-red-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
                    <div class="relative z-10 text-left">
                        <div class="flex items-center gap-2 mb-2">
                            <div class="p-2 bg-red-100 rounded-lg text-red-600"><i data-lucide="alert-circle" class="w-5 h-5"></i></div>
                            <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Pendências</span>
                        </div>
                        <div class="flex items-baseline gap-1 mt-4">
                            <span id="kpi-pendentes" class="text-4xl font-extrabold text-gray-800 demo-blur">--</span>
                            <span class="text-sm text-gray-400 font-medium">h</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-shadow">
                    <div class="absolute right-0 top-0 w-24 h-24 bg-purple-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
                    <div class="relative z-10 text-left">
                        <div class="flex items-center gap-2 mb-2">
                            <div class="p-2 bg-purple-100 rounded-lg text-purple-600"><i data-lucide="target" class="w-5 h-5"></i></div>
                            <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Meta do Período</span>
                        </div>
                        <div class="flex items-baseline gap-1 mt-4">
                            <span id="kpi-alocadas" class="text-4xl font-extrabold text-gray-800 demo-blur">--</span>
                            <span class="text-sm text-gray-400 font-medium">h</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- CARD DE AÇÃO -->
            <div id="action-card" class="bg-c3c-gradient rounded-2xl p-6 md:p-8 text-white shadow-xl shadow-blue-200 hidden border-none">
                <div class="flex flex-col md:flex-row items-center justify-between gap-6">
                    <div class="flex items-center gap-6 text-left">
                        <div class="w-20 h-20 rounded-full overflow-hidden border-2 border-white/20 shadow-lg bg-white flex items-center justify-center shrink-0 hidden md:flex">
                            <img src="/assets/signatures/assinaturaCapivorce.png" alt="Capivorce" class="w-full h-full object-cover">
                        </div>
                        <div>
                            <h3 class="text-2xl font-bold mb-2 flex items-center gap-2">
                                <i data-lucide="zap" class="w-6 h-6 text-yellow-300"></i>
                                Atenção às Pendências!
                            </h3>
                            <p class="text-blue-50 max-w-lg text-sm md:text-base font-medium">
                                Você possui horas em "Rascunho" ou "Reprovadas". Regularize seus apontamentos para garantir o fechamento do ponto.
                            </p>
                        </div>
                    </div>
                    <a href="/timesheet" class="w-full md:w-auto text-center bg-white text-c3c-blue font-bold px-6 py-3 rounded-xl hover:bg-blue-50 transition-colors shadow-md transform hover:-translate-y-1">
                        Ir para Timesheet
                    </a>
                </div>
            </div>

            <!-- LISTA DE PROJETOS -->
            <div class="mt-8">
                <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2 text-left">
                    <i data-lucide="folder-kanban" class="w-5 h-5 text-gray-400"></i>
                    Meus Projetos Ativos
                </h3>
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-gray-50 border-b border-gray-100">
                            <tr>
                                <th class="p-4 text-xs font-bold text-gray-500 uppercase">Projeto / Serviço</th>
                                <th class="p-4 text-xs font-bold text-gray-500 uppercase">Cliente</th>
                                <th class="p-4 text-xs font-bold text-gray-500 uppercase text-right">Alocação</th>
                            </tr>
                        </thead>
                        <tbody id="projects-list" class="divide-y divide-gray-50 text-sm text-gray-600">
                            <tr><td colspan="3" class="p-8 text-center text-gray-400">Carregando projetos...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <script>
        lucide.createIcons();
        const API_URL = '/api';

        // --- MENU MOBILE ---
        function toggleMenu() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobile-overlay');
            if (sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        // --- DADOS ---
        document.addEventListener('DOMContentLoaded', () => { loadPeriods(); });

        async function loadPeriods() {
            try {
                const res = await fetch('/api/periods?type=user');
                const data = await res.json();
                const selector = document.getElementById('period-selector');
                selector.innerHTML = '';
                
                if(!data || data.length === 0) { 
                    selector.innerHTML = '<option value="">Sem contratos ativos</option>'; 
                    return; 
                }
                
                const nonFinalized = data.filter(p => p.Status__c !== 'Finalizado/Pago');
                let suggestedId = nonFinalized.length > 0 ? nonFinalized[nonFinalized.length - 1].Id : (data.length > 0 ? data[0].Id : null);

                data.forEach(p => {
                    const opt = document.createElement('option');
                    opt.value = JSON.stringify({id: p.Id, start: p.DataInicio__c, end: p.DataFim__c});
                    opt.text = p.Name;
                    if (p.Id === suggestedId) opt.selected = true;
                    selector.appendChild(opt);
                });
                
                if(data.length > 0) triggerDataLoad(selector.value);
            } catch(e) { console.error(e); }
        }

        function triggerDataLoad(jsonDates) {
            if(!jsonDates) return;
            const dates = JSON.parse(jsonDates);
            loadDashboardKPIs(dates.start, dates.end);
            loadMyProjects(dates.start, dates.end);
        }

        async function loadDashboardKPIs(start, end) {
            const ids = ['kpi-alocadas', 'kpi-eficiencia', 'kpi-pendentes', 'kpi-banco'];
            const els = ids.map(id => document.getElementById(id));
            els.forEach(el => el.classList.add('animate-pulse'));

            try {
                const res = await fetch(`${API_URL}/dashboard/metrics?inicio=${start}&fim=${end}&scope=personal`);
                if (res.ok) {
                    const data = await res.json();
                    
                    document.getElementById('kpi-alocadas').innerText = Math.round(data.totalAlocadas);
                    document.getElementById('kpi-pendentes').innerText = data.totalPendentes.toFixed(1);
                    document.getElementById('kpi-eficiencia').innerText = data.eficiencia;
                    document.getElementById('kpi-banco').innerText = data.saldoBanco.toFixed(2);

                    // --- STEPPER ---
                    updateCicloStepper(data.statusPeriodo, data.compliance, data.nf, data.totalReprovadas, data.isPJ);

                    // Cores dinâmicas para Eficiência
                    const elEfic = document.getElementById('kpi-eficiencia');
                    if(data.eficiencia > 110) elEfic.className = "text-4xl font-extrabold text-red-500";
                    else if(data.eficiencia >= 90) elEfic.className = "text-4xl font-extrabold text-teal-500";
                    else elEfic.className = "text-4xl font-extrabold text-c3c-blue";

                    // Cores dinâmicas para Banco
                    const elBanco = document.getElementById('kpi-banco');
                    if(data.saldoBanco < 0) elBanco.className = "text-4xl font-extrabold text-red-500";
                    else elBanco.className = "text-4xl font-extrabold text-teal-500";

                    document.getElementById('action-card').classList.toggle('hidden', data.totalPendentes <= 0);

                    // Card de Alerta NF
                    const nfCard = document.getElementById('nf-action-card');
                    if (data.nf && data.nf.status === 'Reprovada') {
                        nfCard.className = "mb-6 p-4 rounded-xl border border-red-100 bg-red-50 flex flex-col md:flex-row items-center justify-between gap-4 text-left";
                        document.getElementById('nf-action-icon-bg').className = "p-2 rounded-lg bg-red-100 text-red-600";
                        document.getElementById('nf-action-icon').setAttribute('data-lucide', 'x-circle');
                        document.getElementById('nf-action-title').innerText = "Nota Fiscal Reprovada";
                        document.getElementById('nf-action-desc').innerText = `Motivo: ${data.nf.motivo || 'Ver no portal'}`;
                        nfCard.classList.remove('hidden');
                    } else if (data.statusPeriodo === 'Liberado para Nota Fiscal') {
                        nfCard.className = "mb-6 p-4 rounded-xl border border-blue-100 bg-blue-50 flex flex-col md:flex-row items-center justify-between gap-4 animate-pulse text-left";
                        document.getElementById('nf-action-icon-bg').className = "p-2 rounded-lg bg-blue-100 text-c3c-blue";
                        document.getElementById('nf-action-icon').setAttribute('data-lucide', 'upload-cloud');
                        document.getElementById('nf-action-title').innerText = "Emita sua Nota Fiscal!";
                        document.getElementById('nf-action-desc').innerText = "Ciclo aprovado. Envie sua NF agora para pagamento.";
                        nfCard.classList.remove('hidden');
                    } else {
                        nfCard.classList.add('hidden');
                    }
                    lucide.createIcons();
                } else { els.forEach(el => el.innerText = "-"); }
            } catch (err) { console.error(err); } 
            finally { els.forEach(el => el.classList.remove('animate-pulse')); }
        }

        function updateCicloStepper(status, compliance, nf, totalReprovadas = 0, isPJ = true) {
            const desc = document.getElementById('ciclo-status-desc');
            const compBadge = document.getElementById('ciclo-compliance-badge');
            const compText = document.getElementById('ciclo-compliance-text');

            // Mostrar/Ocultar etapa de Nota Fiscal baseada no perfil PJ
            const step3 = document.getElementById('step-3');
            if (step3) step3.classList.toggle('hidden', !isPJ);

            for(let i=1; i<=4; i++) {
                const circle = document.getElementById(`step-${i}-circle`);
                if (!circle) continue;
                circle.className = "w-10 h-10 rounded-full border-2 border-gray-200 bg-white flex items-center justify-center transition-all z-10 text-gray-300";
                const defaultIcons = { 1: 'edit-3', 2: 'check-square', 3: 'file-text', 4: 'banknote' };
                circle.innerHTML = `<i data-lucide="${defaultIcons[i]}" class="w-5 h-5"></i>`;
                const title = document.querySelector(`#step-${i} div.mt-2`);
                if(title) title.className = "mt-2 text-[10px] font-bold text-gray-400 uppercase";
                if(i<4) { const line = document.getElementById(`step-${i}-line`); if(line) line.style.width = "0%"; }
            }
            let activeStep = 1, statusText = "Você está na fase de apontamento de horas.";
            if (status === 'Aberto') {
                activeStep = 1; statusText = totalReprovadas > 0 ? `Atenção: Você possui ${totalReprovadas.toFixed(1)}h reprovadas.` : "Período aberto. Complete seus lançamentos.";
                if(compBadge) { compBadge.classList.remove('hidden'); compBadge.classList.add('flex'); }
                if(compText) compText.innerText = `${compliance.completed}/${compliance.total} preenchidos`;
            } else if (status === 'Em aprovação do serviço' || status === 'Aguardando Aprovação Líder' || status === 'Aguardando Aprovação RH') {
                activeStep = 2; statusText = "Aguardando aprovação do Líder/RH."; if(compBadge) compBadge.classList.add('hidden');
            } else if (status === 'Liberado para Nota Fiscal') {
                activeStep = 3; statusText = "Tudo aprovado! Já pode enviar sua Nota Fiscal."; if(compBadge) compBadge.classList.add('hidden');
            } else if (status === 'Nota em Validação' || status === 'Pronto para Pagamento' || status === 'Pagamento Agendado' || status === 'Finalizado/Pago') {
                activeStep = 4; statusText = status === 'Finalizado/Pago' ? "Ciclo concluído com sucesso!" : "Pagamento em processamento."; if(compBadge) compBadge.classList.add('hidden');
            }
            if(desc) desc.innerText = statusText;
            for(let i=1; i<=activeStep; i++) {
                const circle = document.getElementById(`step-${i}-circle`);
                const title = document.querySelector(`#step-${i} div.mt-2`);
                if(!circle) continue;
                const isFinalStepCompleted = (i === 4 && status === 'Finalizado/Pago');
                if (i < activeStep || isFinalStepCompleted) {
                    circle.className = "w-10 h-10 rounded-full bg-c3c-blue border-2 border-c3c-blue flex items-center justify-center transition-all z-10 text-white shadow-sm";
                    if(title) title.className = "mt-2 text-[10px] font-bold text-c3c-blue uppercase";
                    const line = document.getElementById(`step-${i}-line`); if(i < 4 && line) line.style.width = "100%";
                } else {
                    circle.className = "w-10 h-10 rounded-full border-2 border-c3c-blue bg-white flex items-center justify-center transition-all z-10 text-c3c-blue ring-4 ring-blue-50";
                    if(title) title.className = "mt-2 text-[10px] font-bold text-c3c-blue uppercase";
                }
            }
            if (totalReprovadas > 0) {
                const s1Circle = document.getElementById('step-1-circle');
                if (s1Circle) {
                    s1Circle.className = "w-10 h-10 rounded-full bg-red-100 border-2 border-red-500 flex items-center justify-center transition-all z-10 text-red-600 shadow-sm animate-pulse";
                    s1Circle.innerHTML = `<i data-lucide="alert-circle" class="w-5 h-5"></i>`;
                }
            }
            if (nf) {
                const s3Circle = document.getElementById('step-3-circle');
                if (s3Circle) {
                    if (nf.status === 'Reprovada') {
                        s3Circle.className = "w-10 h-10 rounded-full bg-red-100 border-2 border-red-500 flex items-center justify-center transition-all z-10 text-red-600 shadow-sm animate-pulse";
                        s3Circle.innerHTML = `<i data-lucide="alert-circle" class="w-5 h-5"></i>`;
                    } else if (nf.status === 'Aprovada' || status === 'Pronto para Pagamento' || status === 'Pagamento Agendado' || status === 'Finalizado/Pago') {
                        s3Circle.className = "w-10 h-10 rounded-full bg-teal-600 border-2 border-teal-600 flex items-center justify-center transition-all z-10 text-white shadow-sm";
                        s3Circle.innerHTML = `<i data-lucide="check" class="w-5 h-5"></i>`;
                    }
                }
            }
            lucide.createIcons();
        }

        async function loadMyProjects(start, end) {
             const tbody = document.getElementById('projects-list');
             try {
                const res = await fetch(`${API_URL}/dashboard/allocations?inicio=${start}&fim=${end}`);
                if (!res.ok) throw new Error(`Erro API: ${res.status}`);
                const data = await res.json();
                if(!data || data.length === 0) { tbody.innerHTML = '<tr><td colspan="3" class="p-8 text-center text-gray-400">Nenhuma alocação encontrada.</td></tr>'; return; }
                tbody.innerHTML = '';
                data.forEach(p => {
                    const tr = document.createElement('tr');
                    tr.className = "hover:bg-gray-50 transition-colors";
                    tr.innerHTML = `<td class="p-4 font-bold text-gray-800 text-xs uppercase tracking-tighter">${p.serviceName}</td><td class="p-4 text-gray-400 text-[10px] font-bold uppercase tracking-widest">${p.accountName}</td><td class="p-4 text-right"><span class="bg-blue-50 text-c3c-blue py-1 px-3 rounded-full text-[10px] font-black border border-blue-100">${p.percent}%</span></td>`;
                    tbody.appendChild(tr);
                });
             } catch(e) { console.error(e); }
        }
    </script>
</body>
</html>
