                        <div class="p-4 bg-gray-50/30 border-t border-gray-50"><button onclick="addBillingRow()" class="w-full py-4 bg-white border border-gray-100 hover:border-teal-100 hover:bg-teal-50 text-[10px] font-black text-teal-600 uppercase tracking-[0.2em] rounded-2xl transition-all flex items-center justify-center gap-2 active:scale-[0.99] shadow-sm"><i data-lucide="plus" class="w-4 h-4"></i> Adicionar Parcela de Faturamento</button></div>
                    </div>
