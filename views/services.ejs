        async function deleteDocument(docId) {
            if (!confirm('Tem certeza que deseja excluir este anexo permanentemente?')) return;

            document.getElementById('modal-loader').classList.remove('hidden');
            try {
                const res = await fetch(`/api/services/doc/${docId}`, { method: 'DELETE' });
                const data = await res.json();
                if (data.success) {
                    showToast('Documento excluído com sucesso!');
                    document.getElementById(`doc-${docId}`)?.remove();
                } else {
                    throw new Error(data.error || 'Falha ao excluir');
                }
            } catch (e) {
                showToast(e.message, 'error');
            } finally {
                document.getElementById('modal-loader').classList.add('hidden');
            }
        }

        async function uploadFile() {
            const fileInput = document.getElementById('file-input');
            const file = fileInput.files[0];
            const docType = document.getElementById('doc-type-select').value;
            const serviceId = currentServiceData?.id;

            if (!file || !serviceId) {
                return showToast('Selecione um arquivo e um serviço primeiro.', 'error');
            }
            
            // UX Melhorada: Fecha o modal de upload e mostra o loader principal
            closeModal('upload-modal');
            document.getElementById('modal-loader').classList.remove('hidden');
            
            const formData = new FormData();
            formData.append('files', file);
            formData.append('type', docType);
            formData.append('serviceId', serviceId);

            try {
                const res = await fetch('/api/services/doc', { method: 'POST', body: formData });
                const data = await res.json();

                if (data.success) {
                    showToast('Arquivo anexado com sucesso!');
                    // Recarrega os dados do serviço no modal para exibir o novo anexo
                    openServiceModal(serviceId); 
                } else {
                    throw new Error(data.message || 'Falha no servidor');
                }
            } catch (e) {
                showToast(`Erro no upload: ${e.message}`, 'error');
            } finally {
                // A openServiceModal já esconde o loader quando os dados chegam.
                // Mas garantimos que ele seja escondido em caso de erro na rede.
                setTimeout(() => document.getElementById('modal-loader').classList.add('hidden'), 500);
            }
        }

