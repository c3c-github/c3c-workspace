<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minha Eficiência - C3C</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { c3c: { blue: '#2978FF', teal: '#1DDDBD', gray: '#F2F2F2' } }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .bg-c3c-gradient { background: linear-gradient(135deg, #2978FF 0%, #1DDDBD 100%); }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#F8FAFC]">

    <div id="mobile-overlay" onclick="toggleMenu()" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden transition-opacity opacity-0"></div>

    <%- include('partials/sidebar', { page: 'dashboard' }) %>

    <main class="flex-1 flex flex-col md:ml-64 relative w-full transition-all duration-300">
        
        <!-- HEADER -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-20">
            <div class="flex items-center gap-4">
                <button onclick="toggleMenu()" class="md:hidden p-2 text-gray-600 hover:bg-gray-100 rounded-lg">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <div>
                    <h1 class="text-lg md:text-xl font-bold text-gray-800">Minha Eficiência 🚀</h1>
                    <p class="text-xs text-gray-400 hidden sm:block">Acompanhe seu desempenho e banco de horas</p>
                </div>
            </div>
            
            <div class="flex items-center gap-3">
                <% if (user.grupos && user.grupos.includes('LOGIN_AS')) { %>
                <button onclick="document.getElementById('impersonate-modal').classList.remove('hidden')" class="bg-purple-600 hover:bg-purple-700 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-2 shadow-sm transition-transform active:scale-95">
                    <i data-lucide="venetian-mask" class="w-4 h-4"></i> Simular Acesso
                </button>
                <% } %>
                
                <div class="flex items-center bg-gray-50 rounded-lg border border-gray-200 px-3 py-1.5 gap-2 shadow-sm">
                    <i data-lucide="calendar" class="w-4 h-4 text-blue-500"></i>
                    <select id="period-selector" onchange="triggerDataLoad(this.value)" class="bg-transparent text-sm font-bold text-gray-700 outline-none cursor-pointer min-w-[150px]">
                        <option>Carregando...</option>
                    </select>
                </div>
            </div>
        </header>

        <!-- CONTEÚDO -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 fade-in">
            
            <!-- STEPPER: MEU CICLO FINANCEIRO -->
            <div class="mb-8 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm relative overflow-hidden">
                <div class="absolute top-0 left-0 w-1 h-full bg-blue-600"></div>
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                    <div>
                        <h2 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-1">Meu Ciclo Financeiro</h2>
                        <p id="ciclo-status-desc" class="text-lg font-bold text-gray-800">Carregando jornada...</p>
                    </div>
                    <div id="ciclo-compliance-badge" class="hidden px-4 py-2 bg-blue-50 text-blue-700 rounded-xl border border-blue-100 text-xs font-bold items-center gap-2">
                        <i data-lucide="check-circle" class="w-4 h-4"></i>
                        <span id="ciclo-compliance-text">0/0 dias úteis</span>
                    </div>
                </div>

                <!-- Stepper UI -->
                <div class="mt-8 flex items-center w-full">
                    <div id="step-1" class="relative flex-1 group">
                        <div class="flex items-center">
                            <div id="step-1-circle" class="w-10 h-10 rounded-full border-2 border-gray-200 bg-white flex items-center justify-center transition-all z-10">
                                <i data-lucide="edit-3" class="w-5 h-5"></i>
                            </div>
                            <div class="flex-1 h-1 bg-gray-100 -ml-1 -mr-1"><div id="step-1-line" class="h-full bg-blue-600 w-0 transition-all duration-500"></div></div>
                        </div>
                        <div class="mt-2 text-[10px] font-bold text-gray-400 uppercase">Apontamento</div>
                    </div>
                    <div id="step-2" class="relative flex-1 group">
                        <div class="flex items-center">
                            <div id="step-2-circle" class="w-10 h-10 rounded-full border-2 border-gray-200 bg-white flex items-center justify-center transition-all z-10">
                                <i data-lucide="check-square" class="w-5 h-5"></i>
                            </div>
                            <div class="flex-1 h-1 bg-gray-100 -ml-1 -mr-1"><div id="step-2-line" class="h-full bg-blue-600 w-0 transition-all duration-500"></div></div>
                        </div>
                        <div class="mt-2 text-[10px] font-bold text-gray-400 uppercase">Aprovação</div>
                    </div>
                    <div id="step-3" class="relative flex-1 group">
                        <div class="flex items-center">
                            <div id="step-3-circle" class="w-10 h-10 rounded-full border-2 border-gray-200 bg-white flex items-center justify-center transition-all z-10">
                                <i data-lucide="file-text" class="w-5 h-5"></i>
                            </div>
                            <div class="flex-1 h-1 bg-gray-100 -ml-1 -mr-1"><div id="step-3-line" class="h-full bg-blue-600 w-0 transition-all duration-500"></div></div>
                        </div>
                        <div class="mt-2 text-[10px] font-bold text-gray-400 uppercase">Nota Fiscal</div>
                    </div>
                    <div id="step-4" class="relative group">
                        <div class="flex items-center">
                            <div id="step-4-circle" class="w-10 h-10 rounded-full border-2 border-gray-200 bg-white flex items-center justify-center transition-all z-10">
                                <i data-lucide="banknote" class="w-5 h-5"></i>
                            </div>
                        </div>
                        <div class="mt-2 text-[10px] font-bold text-gray-400 uppercase">Pagamento</div>
                    </div>
                </div>
            </div>
            
            <!-- KPIs -->
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
                
                <!-- KPI 1: EFICIÊNCIA -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-shadow">
                    <div class="absolute right-0 top-0 w-24 h-24 bg-blue-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
                    <div class="relative z-10">
                        <div class="flex items-center gap-2 mb-2">
                            <div class="p-2 bg-blue-100 rounded-lg text-blue-600"><i data-lucide="activity" class="w-5 h-5"></i></div>
                            <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Adesão / Eficiência</span>
                        </div>
                        <div class="flex items-baseline gap-1 mt-4">
                            <span id="kpi-eficiencia" class="text-4xl font-extrabold text-gray-800">--</span>
                            <span class="text-sm text-gray-400 font-medium">%</span>
                        </div>
                        <p class="text-xs text-gray-400 mt-2">Horas Realizadas vs. Previstas</p>
                    </div>
                </div>

                <!-- KPI 2: BANCO DE HORAS -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-shadow">
                    <div class="absolute right-0 top-0 w-24 h-24 bg-teal-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
                    <div class="relative z-10">
                        <div class="flex items-center gap-2 mb-2">
                            <div class="p-2 bg-teal-100 rounded-lg text-teal-600"><i data-lucide="clock" class="w-5 h-5"></i></div>
                            <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Banco de Horas</span>
                        </div>
                        <div class="flex items-baseline gap-1 mt-4">
                            <span id="kpi-banco" class="text-4xl font-extrabold text-gray-800">--</span>
                            <span class="text-sm text-gray-400 font-medium">h</span>
                        </div>
                        <p class="text-xs text-gray-400 mt-2">Saldo acumulado geral</p>
                    </div>
                </div>

                <!-- KPI 3: PENDÊNCIAS -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-shadow">
                    <div class="absolute right-0 top-0 w-24 h-24 bg-red-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
                    <div class="relative z-10">
                        <div class="flex items-center gap-2 mb-2">
                            <div class="p-2 bg-red-100 rounded-lg text-red-600"><i data-lucide="alert-circle" class="w-5 h-5"></i></div>
                            <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Rascunhos</span>
                        </div>
                        <div class="flex items-baseline gap-1 mt-4">
                            <span id="kpi-pendentes" class="text-4xl font-extrabold text-gray-800">--</span>
                            <span class="text-sm text-gray-400 font-medium">h</span>
                        </div>
                        <p class="text-xs text-gray-400 mt-2">Necessitam envio/correção</p>
                    </div>
                </div>

                <!-- KPI 4: PREVISTO -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-md transition-shadow">
                    <div class="absolute right-0 top-0 w-24 h-24 bg-purple-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
                    <div class="relative z-10">
                        <div class="flex items-center gap-2 mb-2">
                            <div class="p-2 bg-purple-100 rounded-lg text-purple-600"><i data-lucide="target" class="w-5 h-5"></i></div>
                            <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Meta do Período</span>
                        </div>
                        <div class="flex items-baseline gap-1 mt-4">
                            <span id="kpi-alocadas" class="text-4xl font-extrabold text-gray-800">--</span>
                            <span class="text-sm text-gray-400 font-medium">h</span>
                        </div>
                        <p class="text-xs text-gray-400 mt-2">Baseado nas alocações ativas</p>
                    </div>
                </div>

            </div>

            <!-- CARD DE AÇÃO -->
            <div id="action-card" class="bg-gradient-to-r from-blue-600 to-blue-500 rounded-2xl p-6 md:p-8 text-white shadow-xl shadow-blue-200 hidden">
                <div class="flex flex-col md:flex-row items-center justify-between gap-6">
                    <div>
                        <h3 class="text-2xl font-bold mb-2 flex items-center gap-2">
                            <i data-lucide="zap" class="w-6 h-6 text-yellow-300"></i>
                            Atenção às Pendências!
                        </h3>
                        <p class="text-blue-100 max-w-lg text-sm md:text-base">
                            Você possui horas em "Rascunho" ou "Reprovadas". Regularize seus apontamentos para garantir o fechamento do ponto.
                        </p>
                    </div>
                    <a href="/timesheet" class="w-full md:w-auto text-center bg-white text-blue-600 font-bold px-6 py-3 rounded-xl hover:bg-blue-50 transition-colors shadow-md transform hover:-translate-y-1">
                        Ir para Timesheet
                    </a>
                </div>
            </div>

            <!-- LISTA DE PROJETOS -->
            <div class="mt-8">
                <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                    <i data-lucide="folder-kanban" class="w-5 h-5 text-gray-400"></i>
                    Meus Projetos Ativos
                </h3>
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-gray-50 border-b border-gray-100">
                            <tr>
                                <th class="p-4 text-xs font-bold text-gray-500 uppercase">Projeto / Serviço</th>
                                <th class="p-4 text-xs font-bold text-gray-500 uppercase">Cliente</th>
                                <th class="p-4 text-xs font-bold text-gray-500 uppercase text-right">Alocação</th>
                            </tr>
                        </thead>
                        <tbody id="projects-list" class="divide-y divide-gray-50 text-sm text-gray-600">
                            <tr><td colspan="3" class="p-8 text-center text-gray-400">Carregando projetos...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <script>
        lucide.createIcons();
        const API_URL = '/api';

        // --- MENU MOBILE ---
        function toggleMenu() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobile-overlay');
            if (sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        // --- DADOS ---
        document.addEventListener('DOMContentLoaded', () => { loadPeriods(); });

        async function loadPeriods() {
            try {
                const res = await fetch(`${API_URL}/periods?type=user`);
                if(res.status === 401) window.location.href = '/';
                const periods = await res.json();
                const selector = document.getElementById('period-selector');
                selector.innerHTML = '';
                
                if(!periods || periods.length === 0) { 
                    selector.innerHTML = '<option value="">Sem contratos ativos</option>'; 
                    return; 
                }
                
                let defaultIndex = 0;
                const unpaidIndex = [...periods].reverse().findIndex(p => p.Status__c !== 'Finalizado/Pago');
                if (unpaidIndex !== -1) defaultIndex = (periods.length - 1) - unpaidIndex;

                periods.forEach((p, i) => {
                    const opt = document.createElement('option');
                    opt.value = JSON.stringify({start: p.DataInicio__c, end: p.DataFim__c});
                    opt.text = p.Name;
                    if (i === defaultIndex) opt.selected = true;
                    selector.appendChild(opt);
                });
                
                triggerDataLoad(selector.value);
            } catch (err) { 
                console.error(err);
                document.getElementById('period-selector').innerHTML = '<option value="">Erro ao carregar</option>';
            }
        }

        function triggerDataLoad(jsonDates) {
            if(!jsonDates) return;
            const dates = JSON.parse(jsonDates);
            loadDashboardKPIs(dates.start, dates.end);
            loadMyProjects(dates.start, dates.end);
        }

        async function loadDashboardKPIs(start, end) {
            const ids = ['kpi-alocadas', 'kpi-eficiencia', 'kpi-pendentes', 'kpi-banco'];
            const els = ids.map(id => document.getElementById(id));
            els.forEach(el => el.classList.add('animate-pulse'));

            try {
                const res = await fetch(`${API_URL}/dashboard/metrics?inicio=${start}&fim=${end}&scope=personal`);
                if (res.ok) {
                    const data = await res.json();
                    
                    document.getElementById('kpi-alocadas').innerText = Math.round(data.totalAlocadas);
                    document.getElementById('kpi-pendentes').innerText = data.totalPendentes.toFixed(1);
                    document.getElementById('kpi-eficiencia').innerText = data.eficiencia;
                    document.getElementById('kpi-banco').innerText = data.saldoBanco.toFixed(2);

                    // --- STEPPER ---
                    updateCicloStepper(data.statusPeriodo, data.compliance);

                    // Cores dinâmicas para Eficiência
                    const elEfic = document.getElementById('kpi-eficiencia');
                    if(data.eficiencia > 110) elEfic.className = "text-4xl font-extrabold text-red-500";
                    else if(data.eficiencia >= 90) elEfic.className = "text-4xl font-extrabold text-teal-500";
                    else elEfic.className = "text-4xl font-extrabold text-blue-500";

                    // Cores dinâmicas para Banco
                    const elBanco = document.getElementById('kpi-banco');
                    if(data.saldoBanco < 0) elBanco.className = "text-4xl font-extrabold text-red-500";
                    else elBanco.className = "text-4xl font-extrabold text-teal-500";

                    // Card de Alerta
                    const actionCard = document.getElementById('action-card');
                    if(data.totalPendentes > 0) {
                        actionCard.classList.remove('hidden');
                        actionCard.classList.add('fade-in');
                    } else {
                        actionCard.classList.add('hidden');
                    }

                } else {
                    els.forEach(el => el.innerText = "-");
                }
            } catch (err) { console.error(err); } 
            finally { els.forEach(el => el.classList.remove('animate-pulse')); }
        }

        function updateCicloStepper(status, compliance) {
            const desc = document.getElementById('ciclo-status-desc');
            const compBadge = document.getElementById('ciclo-compliance-badge');
            const compText = document.getElementById('ciclo-compliance-text');
            
            // Reset
            for(let i=1; i<=4; i++) {
                const circle = document.getElementById(`step-${i}-circle`);
                circle.className = "w-10 h-10 rounded-full border-2 border-gray-200 bg-white flex items-center justify-center transition-all z-10 text-gray-300";
                const title = document.querySelector(`#step-${i} div.mt-2`);
                if(title) title.className = "mt-2 text-[10px] font-bold text-gray-400 uppercase";
                if(i<4) document.getElementById(`step-${i}-line`).style.width = "0%";
            }

            let activeStep = 1;
            let statusText = "Você está na fase de apontamento de horas.";

            if (status === 'Aberto') {
                activeStep = 1;
                statusText = "Período aberto. Complete seus lançamentos diários.";
                compBadge.classList.remove('hidden');
                compBadge.classList.add('flex');
                compText.innerText = `${compliance.completed}/${compliance.total} dias úteis preenchidos`;
            } else if (status === 'Aguardando Aprovação Líder' || status === 'Aguardando Aprovação RH') {
                activeStep = 2;
                statusText = "Lançamentos concluídos! Aguardando aprovação do Líder/RH.";
                compBadge.classList.add('hidden');
            } else if (status === 'Liberado para Nota Fiscal') {
                activeStep = 3;
                statusText = "Tudo aprovado! Já pode emitir e subir sua Nota Fiscal.";
                compBadge.classList.add('hidden');
            } else if (status === 'Nota em Validação' || status === 'Pronto para Pagamento' || status === 'Pagamento Agendado' || status === 'Finalizado/Pago') {
                activeStep = 4;
                statusText = status === 'Finalizado/Pago' ? "Pagamento confirmado! Ciclo concluído com sucesso." : "Nota recebida. Seu pagamento está sendo processado.";
                compBadge.classList.add('hidden');
            }

            desc.innerText = statusText;

            // Apply styles to steps
            for(let i=1; i<=activeStep; i++) {
                const circle = document.getElementById(`step-${i}-circle`);
                const title = document.querySelector(`#step-${i} div.mt-2`);
                if (i < activeStep) {
                    circle.className = "w-10 h-10 rounded-full bg-blue-600 border-2 border-blue-600 flex items-center justify-center transition-all z-10 text-white shadow-sm";
                    if(title) title.className = "mt-2 text-[10px] font-bold text-blue-600 uppercase";
                    if(i < 4) document.getElementById(`step-${i}-line`).style.width = "100%";
                } else {
                    circle.className = "w-10 h-10 rounded-full border-2 border-blue-600 bg-white flex items-center justify-center transition-all z-10 text-blue-600 ring-4 ring-blue-50";
                    if(title) title.className = "mt-2 text-[10px] font-bold text-blue-600 uppercase";
                }
            }
            lucide.createIcons();
        }

        async function loadMyProjects(start, end) {
             const tbody = document.getElementById('projects-list');
             try {
                // Nova rota dedicada com percentual
                const res = await fetch(`${API_URL}/dashboard/allocations?inicio=${start}&fim=${end}`);
                
                if (!res.ok) throw new Error(`Erro na API: ${res.status}`);
                
                const data = await res.json();
                
                if(!data || data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="3" class="p-8 text-center text-gray-400">Nenhuma alocação encontrada neste período.</td></tr>';
                    return;
                }

                tbody.innerHTML = '';
                data.forEach(p => {
                    const tr = document.createElement('tr');
                    tr.className = "hover:bg-gray-50 transition-colors";
                    tr.innerHTML = `
                        <td class="p-4 font-medium text-gray-800">${p.serviceName}</td>
                        <td class="p-4 text-gray-500">${p.accountName}</td>
                        <td class="p-4 text-right">
                            <span class="bg-blue-100 text-blue-700 py-1 px-3 rounded-full text-xs font-bold">
                                ${p.percent}%
                            </span>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });

             } catch(e) {
                 console.error("Erro ao carregar projetos:", e);
                 tbody.innerHTML = `<tr><td colspan="3" class="p-4 text-center text-red-400">Erro: ${e.message}</td></tr>`;
             }
        }
    </script>
    <!-- MODAL IMPERSONATE -->
    <div id="impersonate-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md transform transition-all p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="font-bold text-gray-800 flex items-center gap-2"><i data-lucide="venetian-mask" class="w-5 h-5 text-purple-600"></i> Simular Usuário</h3>
                <button onclick="document.getElementById('impersonate-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            
            <div class="mb-4">
                <input type="text" id="imp-search" placeholder="Digite nome ou email (min 3 chars)..." class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-purple-500 outline-none">
            </div>
            
            <div id="imp-results" class="max-h-60 overflow-y-auto space-y-2 mb-2">
                <p class="text-xs text-gray-400 text-center py-2">Digite para buscar...</p>
            </div>
        </div>
    </div>

    <script>
        // --- IMPERSONATION LOGIC ---
        const impInput = document.getElementById('imp-search');
        if(impInput) {
            let debounceTimer;
            impInput.addEventListener('input', (e) => {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(() => searchUsers(e.target.value), 300);
            });
        }

        async function searchUsers(term) {
            const list = document.getElementById('imp-results');
            if(term.length < 3) { list.innerHTML = '<p class="text-xs text-gray-400 text-center">Digite mais...</p>'; return; }
            
            list.innerHTML = '<p class="text-xs text-gray-400 text-center animate-pulse">Buscando...</p>';
            try {
                const res = await fetch(`/api/admin/users?term=${encodeURIComponent(term)}`);
                const data = await res.json();
                
                list.innerHTML = '';
                if(data.length === 0) return list.innerHTML = '<p class="text-xs text-gray-400 text-center">Ninguém encontrado.</p>';
                
                data.forEach(u => {
                    const item = document.createElement('div');
                    item.className = "flex justify-between items-center p-3 bg-gray-50 hover:bg-purple-50 border border-gray-100 rounded-lg cursor-pointer transition-colors";
                    item.innerHTML = `<div><p class="text-sm font-bold text-gray-800">${u.name}</p><p class="text-[10px] text-gray-500">${u.email}</p></div><i data-lucide="arrow-right" class="w-4 h-4 text-purple-400"></i>`;
                    item.onclick = () => confirmImpersonate(u.id, u.name);
                    list.appendChild(item);
                });
                lucide.createIcons();
            } catch(e) { console.error(e); }
        }

        async function confirmImpersonate(id, name) {
            if(!confirm(`Deseja entrar como: ${name}?`)) return;
            try {
                const res = await fetch('/auth/impersonate', { 
                    method: 'POST', 
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ targetId: id })
                });
                if(res.ok) window.location.reload();
                else alert('Erro ao simular.');
            } catch(e) { alert('Erro de conexão.'); }
        }
    </script>
</body>
</html>