    <!-- TOAST NOTIFICATION -->
    <div id="toast-container" class="fixed bottom-8 right-8 z-[200] flex flex-col gap-3"></div>

    <script>
        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            const colorClass = type === 'success' ? 'bg-teal-500' : 'bg-red-500';
            const icon = type === 'success' ? 'check-circle' : 'alert-circle';
            
            toast.className = `flex items-center gap-4 ${colorClass} text-white px-6 py-4 rounded-[20px] shadow-2xl transform translate-y-20 opacity-0 transition-all duration-500 ease-out min-w-[300px] border border-white/10 backdrop-blur-sm`;
            toast.innerHTML = `
                <div class="bg-white/20 p-2 rounded-xl"><i data-lucide="${icon}" class="w-5 h-5"></i></div>
                <div class="flex-1">
                    <p class="text-[10px] font-black uppercase tracking-widest leading-none mb-1">${type === 'success' ? 'Sucesso' : 'Erro'}</p>
                    <p class="text-xs font-bold opacity-90">${message}</p>
                </div>
            `;
            
            container.appendChild(toast);
            lucide.createIcons();
            
            // Animation In
            setTimeout(() => { toast.classList.remove('translate-y-20', 'opacity-0'); }, 10);
            
            // Auto Remove
            setTimeout(() => {
                toast.classList.add('translate-y-[-20px]', 'opacity-0');
                setTimeout(() => toast.remove(), 500);
            }, 4000);
        }

        lucide.createIcons();
        let services = <%- JSON.stringify(services) %>;
        let currentServiceData = null; let metadata = {}; 
        let attachedDocIds = [];
        let availableSales = []; // Vendas disponíveis para vincular
        let linkedSales = [];    // Vendas já vinculadas ao serviço atual

        // Variáveis de controle de carregamento das abas
        let isCommercialTabLoaded = false;
        let isExecutionTabLoaded = false;
        let isBillingTabLoaded = false;
        let isRealizedTabLoaded = false;


        const money = new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' });
        const moneyValue = (val) => `<span class="demo-blur">${money.format(val || 0)}</span>`;
        const holidays = ["01/01", "21/04", "01/05", "07/09", "12/10", "02/11", "15/11", "25/12"];

        // --- GLOBAL HELPERS & CALCS ---
        function countBusinessDays(startDate, endDate) {
            if(!startDate || !endDate) return 0;
            const s = startDate.split('-'); const e = endDate.split('-');
            const start = new Date(s[0], s[1]-1, s[2]); const end = new Date(e[0], e[1]-1, e[2]);
            if(start > end) return 0;
            let days = 0; let cur = new Date(start);
            while(cur <= end) {
                const d = cur.getDay();
                const dStr = String(cur.getDate()).padStart(2,'0') + '/' + String(cur.getMonth()+1).padStart(2,'0');
                if(d !== 0 && d !== 6 && !holidays.includes(dStr)) days++;
                cur.setDate(cur.getDate() + 1);
            }
            return days;
        }

        function updateSummaryCards(cRev, cMargin, fRev, fMargin, aRev, aMargin, aCost) {
            document.getElementById('card-prop-rev').innerHTML = moneyValue(cRev); document.getElementById('card-prop-margin').innerText = (cMargin||0).toFixed(1) + '% MG';
            document.getElementById('card-fcst-rev').innerHTML = moneyValue(fRev); document.getElementById('card-fcst-margin').innerText = (fMargin||0).toFixed(1) + '% MG';
            document.getElementById('card-act-rev').innerHTML = moneyValue(aRev); document.getElementById('card-act-margin').innerText = (aMargin||0).toFixed(1) + '% MG';
            
            // Atualizações no Extrato Real
            const actRevSummary = document.getElementById('act-rev-summary');
            const actCostSummary = document.getElementById('act-cost-summary');
            if(actRevSummary) actRevSummary.innerHTML = moneyValue(aRev);
            if(actCostSummary) {
                // Se aCost foi passado, usa ele. Senão tenta inferir (legado)
                const realCost = (aCost !== undefined) ? aCost : (aRev * (1 - ((aMargin||0)/100)));
                actCostSummary.innerHTML = moneyValue(realCost);
            }
        }

        function calculateAllTotals() {
            let cRev=0, cCost=0, cHours=0;
            document.querySelectorAll('.comm-row').forEach(tr => {
                cRev += parseFloat(tr.querySelector('.cell-rev').innerText.replace(/[^0-9,-]+/g,"").replace(",",".")||0);
                cCost += parseFloat(tr.querySelector('.cell-cost').innerText.replace(/[^0-9,-]+/g,"").replace(",",".")||0);
                cHours += parseFloat(tr.querySelector('.cell-hours').innerText.replace('h','')||0);
            });
            document.getElementById('comm-total-hours').innerText = cHours.toFixed(1) + 'h';
            document.getElementById('comm-total-rev').innerHTML = moneyValue(cRev);
            document.getElementById('comm-total-rev-foot').innerHTML = moneyValue(cRev);
            document.getElementById('comm-total-cost').innerHTML = moneyValue(cCost);
            document.getElementById('comm-total-margin').innerText = cRev > 0 ? Math.round(((cRev-cCost)/cRev)*100) + '%' : (cCost > 0 ? '-100%' : '0%');

            let eRev=0, eCost=0, eHours=0;
            document.querySelectorAll('.exec-row').forEach(tr => {
                const cellRev = tr.querySelector('.cell-rev');
                const cellCost = tr.querySelector('.cell-cost');
                const cellHours = tr.querySelector('.cell-hours');
                
                if(cellRev) eRev += parseFloat(cellRev.innerText.replace(/[^0-9,-]+/g,"").replace(",",".")||0);
                if(cellCost) eCost += parseFloat(cellCost.innerText.replace(/[^0-9,-]+/g,"").replace(",",".")||0);
                if(cellHours) eHours += parseFloat(cellHours.innerText.replace('h','')||0);
            });
            document.getElementById('exec-total-hours').innerText = eHours.toFixed(1) + 'h';
            document.getElementById('exec-total-rev').innerHTML = moneyValue(eRev);
            document.getElementById('exec-total-rev-foot').innerHTML = moneyValue(eRev);
            document.getElementById('exec-total-cost').innerHTML = moneyValue(eCost);
            const eMargin = eRev > 0 ? ((eRev-eCost)/eRev)*100 : (eCost > 0 ? -100 : 0);
            document.getElementById('exec-total-margin').innerText = Math.round(eMargin) + '%';

            refreshAllForecasts();
        }

        function recalcDistribution() {
            const distributionMap = {};
            document.querySelectorAll('.exec-row').forEach(tr => {
                const commId = tr.cells[0].querySelector('select').value;
                const costRate = parseFloat(tr.cells[3].querySelector('input').value) || 0;
                const start = tr.cells[4].querySelector('input').value;
                const end = tr.cells[5].querySelector('input').value;
                const alloc = parseFloat(tr.cells[6].querySelector('input').value) || 0;
                const days = countBusinessDays(start, end);
                const totalHours = days * 8 * (alloc / 100); 
                const totalCost = totalHours * costRate;
                tr.dataset.tempCost = totalCost; tr.dataset.tempHours = totalHours; 
                
                const cellDays = tr.querySelector('.cell-days');
                const cellHours = tr.querySelector('.cell-hours');
                const cellCost = tr.querySelector('.cell-cost');
                
                if(cellDays) cellDays.innerText = days; 
                if(cellHours) cellHours.innerText = totalHours.toFixed(1) + 'h';
                if(cellCost) cellCost.innerHTML = moneyValue(totalCost);

                if(commId) {
                    if(!distributionMap[commId]) distributionMap[commId] = { totalCostIncurred: 0, rows: [] };
                    distributionMap[commId].totalCostIncurred += totalCost; distributionMap[commId].rows.push(tr);
                } else {
                    tr.cells[2].querySelector('input').value = '0.00';
                    const cellRev = tr.querySelector('.cell-rev');
                    const cellMargin = tr.querySelector('.cell-margin');
                    if(cellRev) cellRev.innerHTML = moneyValue(0);
                    if(cellMargin) cellMargin.innerText = '-100%';
                }
            });
            Object.keys(distributionMap).forEach(commId => {
                const group = distributionMap[commId];
                const commRow = document.querySelector(`.comm-row[data-id="${commId}"]`);
                const commRevStr = commRow ? commRow.querySelector('.cell-rev').innerText.replace(/[^0-9,-]+/g,"").replace(",",".") : "0";
                const commRev = parseFloat(commRevStr || 0);
                group.rows.forEach(tr => {
                    const myCost = parseFloat(tr.dataset.tempCost); const myHours = parseFloat(tr.dataset.tempHours);
                    let myShareRev = (group.totalCostIncurred > 0) ? (commRev * myCost) / group.totalCostIncurred : 0;
                    tr.cells[2].querySelector('input').value = myHours > 0 ? (myShareRev / myHours).toFixed(2) : '0.00';
                    const cellRev = tr.querySelector('.cell-rev');
                    const cellMargin = tr.querySelector('.cell-margin');
                    if(cellRev) cellRev.innerHTML = moneyValue(myShareRev);
                    if(cellMargin) cellMargin.innerText = myShareRev > 0 ? Math.round(((myShareRev - myCost) / myShareRev) * 100) + '%' : (myCost > 0 ? '-100%' : '0%');
                });
            });
            calculateAllTotals();
            refreshAllForecasts();
        }

        function refreshAllForecasts() {
            const yrCommSelect = document.getElementById('forecast-year-comm');
            const yrAllocSelect = document.getElementById('forecast-year-alloc');
            
            if (yrCommSelect) {
                const yrComm = parseInt(yrCommSelect.value);
                const cMonths = generatePreciseForecast('comm-row', yrComm); 
                renderMonthlyTable(cMonths, 'monthly-forecast-header', 'monthly-forecast-body', yrComm);
            }
            
            if (yrAllocSelect) {
                const yrAlloc = parseInt(yrAllocSelect.value);
