                                    <div class="flex items-center gap-3"><div class="w-2 h-2 rounded-full bg-red-400"></div><p class="text-[10px] font-bold text-gray-500 uppercase">Custo YTD: <span class="text-gray-800 font-black" id="act-cost-summary">R$ 0,00</span></p></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
