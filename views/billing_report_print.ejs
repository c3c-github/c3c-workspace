<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relatório Técnico de Medição - <%= svc.Name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Montserrat', sans-serif; background: #f3f4f6; padding: 2rem 0; }
        .report-page { background: white; width: 210mm; min-height: 297mm; padding: 20mm; margin: 0 auto; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); position: relative; }
        
        @media print {
            body { padding: 0; background: white; }
            .report-page { box-shadow: none; margin: 0; width: 100%; min-height: auto; padding: 10mm; }
            .no-print { display: none !important; }
            .resource-block { break-inside: avoid; }
            table { page-break-inside: auto; }
            tr { page-break-inside: avoid; page-break-after: auto; }
            thead { display: table-header-group; }
            tfoot { display: table-footer-group; }
        }

        .c3c-gradient { background: linear-gradient(135deg, #2978FF 0%, #1DDDBD 100%); }
    </style>
</head>
<body>

    <!-- Floating Print Button -->
    <div class="fixed top-6 right-6 no-print flex gap-3">
        <button onclick="window.close()" class="bg-white border border-gray-300 text-gray-700 px-6 py-2 rounded-xl font-bold text-sm shadow-sm hover:bg-gray-50 transition-all">Fechar</button>
        <button onclick="window.print()" class="c3c-gradient text-white px-8 py-2 rounded-xl font-bold text-sm shadow-md hover:opacity-90 transition-all flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7"></path><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
            Imprimir Relatório
        </button>
    </div>

    <div class="report-page">
        <!-- Header -->
        <div class="flex justify-between items-center border-b-2 border-gray-100 pb-8 mb-8">
            <div class="flex items-center gap-4">
                <img src="https://c3c.my.site.com/resource/1752735833000/logo" alt="C3C Logo" class="h-12 w-auto">
                <div class="h-10 w-[1px] bg-gray-200"></div>
                <div>
                    <h1 class="text-xs font-black text-gray-400 uppercase tracking-tighter">Relatório de Medição Técnica</h1>
                    <p class="text-lg font-bold text-gray-800 leading-tight"><%= svc.Name %></p>
                </div>
            </div>
            <div class="text-right">
                <p class="text-[10px] font-bold text-gray-400 uppercase">Período de Referência</p>
                <p class="text-sm font-black text-blue-600">
                    <% 
                        const dStart = new Date(period.start + 'T12:00:00');
                        const label = dStart.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });
                        echo(label.charAt(0).toUpperCase() + label.slice(1));
                    %>
                </p>
            </div>
        </div>

        <!-- Project Info -->
        <div class="grid grid-cols-3 gap-8 mb-10 bg-gray-50 p-6 rounded-2xl border border-gray-100">
            <div>
                <p class="text-[9px] font-bold text-gray-400 uppercase mb-1">Cliente</p>
                <p class="text-sm font-bold text-gray-800"><%= svc.Conta__r?.Name %></p>
            </div>
            <div>
                <p class="text-[9px] font-bold text-gray-400 uppercase mb-1">Tipo de Serviço</p>
                <p class="text-sm font-bold text-gray-800"><%= svc.Tipo__c %></p>
            </div>
            <div class="text-right">
                <p class="text-[9px] font-bold text-gray-400 uppercase mb-1">Gerado em</p>
                <p class="text-sm font-bold text-gray-800"><%= new Date().toLocaleDateString('pt-BR') %></p>
            </div>
        </div>

        <!-- Content Logic -->
        <% 
            let totalBillable = 0;
            let totalValue = 0;
            const isSupport = svc.Tipo__c === 'Suporte';
            const franchise = svc.Contrato__r?.HorasContratadas__c || 0;
            const contractVal = svc.Contrato__r?.Valor__c || 0;
            const avgRateSupport = franchise > 0 ? contractVal / franchise : 0;

            if (isSupport) { 
                // MODO SUPORTE: CONSOLIDADO
                logs.forEach(l => { totalBillable += l.billable; });
                totalValue = avgRateSupport * Math.max(totalBillable, franchise);
        %>
            <div class="resource-block mb-10">
                <div class="flex justify-between items-end border-b border-gray-200 pb-2 mb-4">
                    <h3 class="text-xs font-black text-gray-800 uppercase flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full c3c-gradient"></span>
                        Extrato Consolidado de Atividades
                    </h3>
                    <% if (showValues) { %>
                        <p class="text-[10px] text-gray-400 font-bold">Taxa Contrato: R$ <%= avgRateSupport.toFixed(2) %>/h</p>
                    <% } %>
                </div>

                <% if (logs.length === 0) { %>
                    <div class="p-8 text-center bg-gray-50 rounded-xl border border-gray-100">
                        <p class="text-sm font-bold text-gray-400 uppercase italic">Nenhuma atividade registrada no período.</p>
                        <p class="text-[10px] text-gray-400 mt-1">Faturamento baseado na disponibilidade da franquia contratada.</p>
                    </div>
                <% } else { %>
                    <table class="w-full text-left text-[11px]">
                        <thead>
                            <tr class="bg-gray-50 text-gray-500 uppercase text-[9px] font-bold border-y border-gray-200">
                                <th class="px-4 py-2 w-28">Data</th>
                                <th class="px-4 py-2">Atividade Realizada</th>
                                <th class="px-4 py-2 text-center w-24">Horas</th>
                                <% if (showValues) { %>
                                    <th class="px-4 py-2 text-right w-32">Subtotal</th>
                                <% } %>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% logs.forEach(log => { %>
                                <tr>
                                    <td class="px-4 py-2.5 font-mono text-gray-500">
                                        <% 
                                            const d = new Date(log.date + 'T12:00:00');
                                            const dow = d.toLocaleDateString('pt-BR', { weekday: 'short' }).replace('.', '');
                                            const dt = d.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
                                            echo(`${dow}, ${dt}`);
                                        %>
                                    </td>
                                    <td class="px-4 py-2.5 text-gray-700 leading-tight text-xs"><%= log.desc %></td>
                                    <td class="px-4 py-2.5 text-center font-bold"><%= log.billable.toFixed(1) %>h</td>
                                    <% if (showValues) { %>
                                        <td class="px-4 py-2.5 text-right text-gray-400">R$ <%= (log.billable * avgRateSupport).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        <% } else { 
                // MODO PROJETO: ESTRATIFICADO
                const resources = [...new Set(logs.map(l => l.resourceName))];
                resources.forEach(resName => {
                    const resLogs = logs.filter(l => l.resourceName === resName);
                    let resSum = 0;
                    let resValue = 0;
        %>
            <div class="resource-block mb-10">
                <div class="flex justify-between items-end border-b border-gray-200 pb-2 mb-4">
                    <h3 class="text-xs font-black text-gray-800 uppercase flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full c3c-gradient"></span>
                        Profissional: <%= resName %>
                    </h3>
                    <% if (showValues) { %>
                        <p class="text-[10px] text-gray-400 font-bold">Taxa: R$ <%= resLogs[0].rate.toFixed(2) %>/h</p>
                    <% } %>
                </div>

                <table class="w-full text-left text-[11px]">
                    <thead>
                        <tr class="bg-gray-50 text-gray-500 uppercase text-[9px] font-bold border-y border-gray-200">
                            <th class="px-4 py-2 w-28">Data</th>
                            <th class="px-4 py-2">Atividade Realizada</th>
                            <th class="px-4 py-2 text-center w-24">Horas</th>
                            <% if (showValues) { %>
                                <th class="px-4 py-2 text-right w-32">Subtotal</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% resLogs.forEach(log => { 
                            resSum += log.billable;
                            resValue += (log.billable * log.rate);
                        %>
                            <tr>
                                <td class="px-4 py-2.5 font-mono text-gray-500">
                                    <% 
                                        const d = new Date(log.date + 'T12:00:00');
                                        const dow = d.toLocaleDateString('pt-BR', { weekday: 'short' }).replace('.', '');
                                        const dt = d.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
                                        echo(`${dow}, ${dt}`);
                                    %>
                                </td>
                                <td class="px-4 py-2.5 text-gray-700 leading-tight text-xs"><%= log.desc %></td>
                                <td class="px-4 py-2.5 text-center font-bold"><%= log.billable.toFixed(1) %>h</td>
                                <% if (showValues) { %>
                                    <td class="px-4 py-2.5 text-right text-gray-400">R$ <%= (log.billable * log.rate).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                                <% } %>
                            </tr>
                        <% }) %>
                    </tbody>
                    <tfoot>
                        <tr class="bg-gray-50/50 font-bold text-gray-800 border-t border-gray-200">
                            <td colspan="2" class="px-4 py-2 text-right uppercase text-[9px] tracking-widest">Total <%= resName.split(' ')[0] %>:</td>
                            <td class="px-4 py-2 text-center text-blue-600 text-sm"><%= resSum.toFixed(1) %>h</td>
                            <% if (showValues) { %>
                                <td class="px-4 py-2 text-right">R$ <%= resValue.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                            <% } %>
                        </tr>
                    </tfoot>
                </table>
            </div>
        <% 
                totalBillable += resSum;
                totalValue += resValue;
                }) 
            } 
        %>

        <!-- Summary Footer -->
        <div class="mt-16 border-t-4 border-gray-900 pt-8">
            <div class="flex justify-between items-start">
                <div>
                    <h4 class="text-sm font-black text-gray-900 uppercase mb-4">Resumo da Medição</h4>
                    <div class="space-y-2">
                        <div class="flex gap-4 text-xs text-gray-500">
                            <span class="w-32 font-bold uppercase">Total de Horas:</span>
                            <span class="font-black text-gray-900"><%= totalBillable.toFixed(1) %> Horas</span>
                        </div>
                        <div class="flex gap-4 text-xs text-gray-500">
                            <span class="w-32 font-bold uppercase">Franquia Contratada:</span>
                            <span class="font-black text-gray-900"><%= franchise.toFixed(1) %> Horas</span>
                        </div>
                        <% if (showValues) { %>
                            <div class="flex gap-4 text-xs text-gray-500">
                                <span class="w-32 font-bold uppercase">Valor Total:</span>
                                <span class="font-black text-green-600">R$ <%= totalValue.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></span>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Info -->
        <div class="absolute bottom-8 left-20 right-20 border-t border-gray-100 pt-4 flex justify-between items-center text-[8px] font-bold text-gray-300 uppercase tracking-widest">
            <span>C3C Software - Relatório Gerado via Workspace</span>
            <span>Página 1 de 1</span>
        </div>
    </div>

    <% function echo(str) { %><%- str %><% } %>

</body>
</html>
