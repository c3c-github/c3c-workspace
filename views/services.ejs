        function switchTab(t) { 
            ['general','attachments','billing','commercial','execution','realized'].forEach(x => { 
                const view = document.getElementById(`view-${x}`);
                const tab = document.getElementById(`tab-${x}`);
                if(view) view.classList.add('hidden'); 
                if(tab) tab.className = 'modal-tab-inactive py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all'; 
            }); 
            
            const targetView = document.getElementById(`view-${t}`);
