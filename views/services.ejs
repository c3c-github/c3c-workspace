        async function removeRow(btn) { 
            const tr = btn.closest('tr');
            const id = tr.dataset.id;
            
            // Se for uma linha de execução (alocação) e tiver ID no SF, precisamos validar exclusão
            if (tr.classList.contains('exec-row') && id && !id.startsWith('new')) {
                if(!confirm("Deseja excluir esta alocação permanentemente? O sistema verificará se existem lançamentos vinculados.")) return;
                
                document.getElementById('modal-loader').classList.remove('hidden');
                try {
                    const res = await fetch(`/api/services/allocations/${id}`, { method: 'DELETE' });
                    const data = await res.json();
                    
                    if (data.success) {
                        showToast('Alocação excluída com sucesso!');
                        tr.remove();
                    } else {
                        throw new Error(data.error || 'Falha ao excluir alocação');
                    }
                } catch(e) {
                    showToast(e.message, 'error');
                } finally {
                    document.getElementById('modal-loader').classList.add('hidden');
                }
            } else {
                // Remoção local para novas linhas ou itens comerciais (que são validados no save geral)
                tr.remove(); 
            }
            
            calculateAllTotals(); 
            recalcDistribution(); 
        }
