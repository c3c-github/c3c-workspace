        async function saveService() {
            if (!currentServiceData) return;
            
            const getDatalistId = (inputId, listId) => {
                const input = document.getElementById(inputId);
                if (!input) return '';
                const val = input.value;
                if (!val) return '';
                
                const list = document.getElementById(listId);
                if (!list) return val;
                
                const options = Array.from(list.options);
                const match = options.find(opt => opt.value === val);
                
                console.log(`Mapping ${inputId} ('${val}') using ${listId}. Match found:`, match ? match.dataset.id : 'None');
                return match ? match.dataset.id : val;
            };
            
            try {
                const payload = {
                    id: currentServiceData.id,
                    name: document.getElementById('input-svc-name')?.value || '',
                    sf_account_id: getDatalistId('input-sf-account', 'sf-accounts-list'),
                    ca_client_id: getDatalistId('input-ca-client', 'ca-clients-list'),
                    type: document.getElementById('input-svc-type')?.value || 'Projeto',
                    lead_project: getDatalistId('input-lead-project', 'people-list'),
                    coordinator: getDatalistId('input-coordinator', 'people-list'),
                    tech_lead: getDatalistId('input-tech-lead', 'people-list'),
                    start: document.getElementById('input-svc-start')?.value || '',
                    end_original: document.getElementById('input-svc-end-orig')?.value || '',
                    end_real: document.getElementById('input-svc-end-real')?.value || '',
                    reqReport: document.getElementById('input-req-report').checked,
                    solReport: document.getElementById('input-sol-report').checked,
                    docIds: attachedDocIds,
                    commercial: Array.from(document.querySelectorAll('.comm-row')).map(tr => {
                        const cellRevEl = tr.querySelector('.cell-rev');
                        const cellCostEl = tr.querySelector('.cell-cost');
                        const cellHoursEl = tr.querySelector('.cell-hours');
                        
                        return {
                            id: tr.dataset.id, 
                            productName: tr.cells[0].querySelector('select')?.value || '', 
                            saleRate: parseFloat(tr.cells[1].querySelector('input')?.value)||0, 
                            costEst: parseFloat(tr.cells[2].querySelector('input')?.value)||0, 
                            start: tr.cells[3].querySelector('input')?.value || '', 
                            end: tr.cells[4].querySelector('input')?.value || '', 
                            alloc: parseFloat(tr.cells[6].querySelector('input')?.value)||0, 
                            totalRev: parseFloat(cellRevEl?.innerText.replace(/[^0-9,-]+/g,"").replace(",",".") || 0), 
                            totalCost: parseFloat(cellCostEl?.innerText.replace(/[^0-9,-]+/g,"").replace(",",".") || 0), 
                            totalHours: parseFloat(cellHoursEl?.innerText.replace('h','') || 0), 
                            monthlyData: getItemMonthlyData(tr)
                        };
                    }),
                    execution: Array.from(document.querySelectorAll('.exec-row')).map(tr => ({
                        id: tr.dataset.id, 
                        personId: tr.cells[1].querySelector('select')?.selectedOptions[0]?.dataset.id, 
                        commercialLinkId: tr.cells[0].querySelector('select')?.value || '', 
                        start: tr.cells[4].querySelector('input')?.value || '', 
                        end: tr.cells[5].querySelector('input')?.value || '', 
                        alloc: parseFloat(tr.cells[6].querySelector('input')?.value)||0, 
                        monthlyData: getItemMonthlyData(tr)
                    }))
                };
                
                if (!payload.name || !payload.sf_account_id || !payload.start) return showToast('Campos obrigatórios ausentes (Nome, Cliente SF e Início).', 'error');
                document.getElementById('modal-loader').classList.remove('hidden');
                
                const resSvc = await fetch('/api/services', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                const dataSvc = await resSvc.json();
                
                if (!dataSvc.success) throw new Error(dataSvc.message);
                
                const serviceId = dataSvc.id;

                const billingPayload = {
                    serviceId: serviceId,
                    sales: linkedSales.map(s => ({
                        id: s.id_ca || s.id,
                        number: s.number,
                        emissionDate: s.date,
                        total: s.total,
                        status: s.status
                    })),
                    installments: Array.from(document.querySelectorAll('.billing-row')).map(tr => ({
                        desc: tr.cells[1].querySelector('input')?.value || '',
                        month: tr.cells[2].querySelector('input')?.value || '',
                        date: tr.cells[3].querySelector('input')?.value || '',
                        value: parseFloat(tr.dataset.value || 0),
                        status: tr.dataset.status || 'Pendente',
                        originSaleId: tr.dataset.originSaleId
                    }))
                };

                const resBill = await fetch('/api/services/sales', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(billingPayload) });
                const dataBill = await resBill.json();

                if (dataBill.success) {
                    document.getElementById('modal-loader').classList.add('hidden');
                    closeModal('service-modal');
                    filterServices();
                    showToast('Serviço e faturamento salvos com sucesso!');
                } else {
                    showToast("Serviço salvo, mas houve erro no faturamento: " + dataBill.error, 'error');
                }

            } catch(e) {
                document.getElementById('modal-loader').classList.add('hidden');
                console.error("Erro completo ao salvar:", e);
                showToast("Erro ao salvar: " + e.message, 'error');
            }
        }

        // --- DOM HELPERS ---
        function getProductOptions(selectedName) { const pbId = document.getElementById('select-pricebook').value; const pb = (metadata.pricebooks || []).find(p => p.id === pbId); if (!pb) return '<option value="">Tabela...</option>'; return '<option value="">Selecione...</option>' + (pb.products || []).map(p => `<option value="${p.name}" data-price="${p.price}" data-cost="${p.cost}" ${p.name === selectedName ? 'selected' : ''}>${p.name}</option>`).join(''); }
        function getCommLinkOptions(selectedId) { let opts = '<option value="">Vínculo...</option>'; document.querySelectorAll('.comm-row').forEach((tr, index) => { opts += `<option value="${tr.dataset.id}" ${tr.dataset.id === selectedId ? 'selected' : ''}>#${index + 1} - ${tr.cells[0].querySelector('select').value}</option>`; }); return opts; }
        function getPeopleOptions(selectedName) { return '<option value="">Selecione...</option>' + (metadata.people || []).map(p => `<option value="${p.name}" data-id="${p.id}" data-cost="${p.costRate}" ${p.name === selectedName ? 'selected' : ''}>${p.name}</option>`).join(''); }
        function populateDatalist(id, list) { document.getElementById(id).innerHTML = (list||[]).map(item => `<option value="${item.name}" data-id="${item.id}">`).join(''); }
        function getMetadataName(list, id) { return (list || []).find(i => i.id === id)?.name || null; }

        renderServices();
    </script>
</body>
</html>
