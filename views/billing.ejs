<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Medição p/ Faturar - C3C Workplace</title>
    
    <!-- Bibliotecas e Fontes -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { 
                        c3c: { 
                            blue: '#2978FF', 
                            teal: '#1DDDBD', 
                            gray: '#F2F2F2',
                            bg: '#F8FAFC'
                        } 
                    }
                }
            }
        }
    </script>

    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .input-log-billable {
            width: 70px; text-align: center; font-weight: 700; border: 1px solid #E2E8F0;
            border-radius: 6px; padding: 4px; color: #2978FF; transition: all 0.2s;
        }
        .input-log-billable:focus { border-color: #2978FF; outline: none; background-color: #F0F7FF; }
        .input-log-billable.glosa { border-color: #EF4444; background-color: #FEF2F2; color: #B91C1C; }
        .input-log-billable:disabled { background-color: transparent; color: #1e293b; border-color: transparent; cursor: default; padding: 0; width: auto; }
        
        .fade-in { animation: fadeIn 0.3s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

        @media print {
            @page { margin: 1cm; size: portrait; }
            .no-print { display: none !important; }
            .print-only { display: block !important; }
            body { background: white !important; height: auto !important; overflow: visible !important; }
            .modal-backdrop { position: static !important; background: none !important; backdrop-filter: none !important; }
            #extract-modal { display: block !important; opacity: 1 !important; position: static !important; }
            .rounded-2xl { border-radius: 0 !important; border: none !important; box-shadow: none !important; }
            .h-\[85vh\] { height: auto !important; }
            .overflow-y-auto { overflow: visible !important; }
            .page-break { page-break-after: always; }
            .resource-block { break-inside: avoid; margin-bottom: 2rem; }
            table { border-collapse: collapse !important; width: 100% !important; }
            th, td { border: 1px solid #e2e8f0 !important; }
        }
    </style>
</head>
<body class="bg-c3c-bg h-screen flex overflow-hidden">

    <%- include('partials/sidebar') %>

    <main class="flex-1 flex flex-col relative w-full overflow-hidden transition-all duration-300 md:ml-64">
        
        <!-- Header -->
        <header class="h-20 bg-white border-b border-gray-200 flex items-center justify-between px-8 shrink-0 z-10 no-print">
            <div class="flex items-center gap-6">
                <h1 class="text-xl font-bold text-gray-800">Fechamento de Medição</h1>
                
                <div class="flex items-center bg-gray-50 border border-gray-200 rounded-lg px-3 py-1.5 gap-2 shadow-sm">
                    <i data-lucide="calendar" class="w-4 h-4 text-indigo-500"></i>
                    <select id="period-selector" onchange="loadBillingGrid()" class="bg-transparent text-sm font-bold text-gray-700 outline-none cursor-pointer">
                        <% 
                           const today = new Date();
                           for(let i=0; i<6; i++) {
                               const d = new Date(today.getFullYear(), today.getMonth() - i, 1);
                               const label = d.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });
                               const valueStart = new Date(d.getFullYear(), d.getMonth(), 1).toISOString().split('T')[0];
                               const valueEnd = new Date(d.getFullYear(), d.getMonth() + 1, 0).toISOString().split('T')[0];
                        %>
                            <option value="<%= valueStart %>|<%= valueEnd %>"><%= label.charAt(0).toUpperCase() + label.slice(1) %></option>
                        <% } %>
                    </select>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <div class="text-right hidden sm:block">
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Perfil</p>
                    <p class="text-sm font-bold text-blue-600"><%= (user.grupos && user.grupos.includes('DIRETOR')) ? 'Direção Operacional' : 'Gestão de Contratos' %></p>
                </div>
            </div>
        </header>

        <!-- Conteúdo -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 fade-in no-print">
            
            <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
                <div>
                    <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                        <i data-lucide="layers" class="w-5 h-5 text-blue-600"></i> Grade de Projetos p/ Faturar
                    </h2>
                    <p class="text-xs text-gray-500 mt-1">Serviços de suporte e projetos que requerem medição detalhada de horas.</p>
                </div>
                
                <div class="flex flex-col md:flex-row items-center gap-4 w-full md:w-auto">
                    <div class="flex items-center gap-4 bg-white border border-gray-200 px-4 py-2 rounded-xl shadow-sm">
                        <label class="flex items-center gap-2 cursor-pointer group">
                            <input type="checkbox" id="filter-required" onchange="renderTable()" class="w-4 h-4 rounded text-indigo-600 border-gray-300 focus:ring-indigo-500">
                            <span class="text-[10px] font-bold text-gray-500 group-hover:text-indigo-600 transition-colors uppercase">Auditoria</span>
                        </label>
                        <div class="w-[1px] h-4 bg-gray-200"></div>
                        <label class="flex items-center gap-2 cursor-pointer group">
                            <input type="checkbox" id="filter-requested" onchange="renderTable()" class="w-4 h-4 rounded text-blue-600 border-gray-300 focus:ring-blue-500">
                            <span class="text-[10px] font-bold text-gray-500 group-hover:text-blue-600 transition-colors uppercase">Relatório</span>
                        </label>
                    </div>

                    <div class="relative w-full md:w-80">
                        <i data-lucide="search" class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2"></i>
                        <input type="text" id="billing-search" onkeyup="renderTable()" placeholder="Buscar cliente ou projeto..." 
                               class="w-full pl-10 pr-4 py-2 bg-white border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none shadow-sm transition-all">
                    </div>
                </div>
            </div>

            <!-- Tabela Principal -->
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden overflow-x-auto">
                <table class="w-full text-sm text-left border-collapse">
                    <thead class="bg-gray-50 text-gray-400 uppercase text-[10px] font-bold border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-4">Projeto / Cliente</th>
                            <th class="px-6 py-4 text-center">Franquia (Prev)</th>
                            <th class="px-6 py-4 text-center">Lançado Eq.</th>
                            <th class="px-6 py-4 text-center">A Faturar</th>
                            <th class="px-6 py-4 text-center">Adesão</th>
                            <th class="px-6 py-4 text-center">Configs</th>
                            <th class="px-6 py-4 text-center">Valor/h Médio</th>
                            <th class="px-6 py-4 text-center">Total Faturável</th>
                            <th class="px-6 py-4 text-center">Status</th>
                            <th class="px-6 py-4 text-right">Ações</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100" id="billing-table-body">
                        <!-- JS Populates -->
                    </tbody>
                </table>
            </div>

            <!-- Rodapé Informativo -->
            <div class="mt-8 bg-blue-50 border border-blue-100 rounded-xl p-5 flex items-center gap-4">
                <div class="bg-blue-600 p-2 rounded-lg text-white shadow-sm shrink-0"><i data-lucide="info" class="w-5 h-5"></i></div>
                <div class="text-sm">
                    <p class="font-bold text-blue-900">Regra de Faturamento (Suporte)</p>
                    <p class="text-blue-700">Para suporte, o faturamento considera o maior entre <strong>A Faturar</strong> e <strong>Franquia</strong>. Relatório consolidado e anônimo para o cliente.</p>
                </div>
            </div>
        </div>
    </main>

    <!-- MODAL: AUDITORIA E AJUSTES -->
    <div id="extract-modal" class="fixed inset-0 modal-backdrop hidden flex items-center justify-center z-50 p-4 bg-black/50 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-5xl h-[85vh] flex flex-col border border-gray-100 overflow-hidden">
            <div class="p-6 border-b border-gray-100 flex justify-between items-start bg-gray-50 no-print">
                <div>
                    <h3 class="text-xl font-bold text-gray-900" id="ext-project-name">Projeto</h3>
                    <p class="text-sm text-gray-500" id="ext-client-name">Cliente</p>
                </div>
                <div class="flex gap-2">
                    <button onclick="printTechnicalReport()" class="bg-white border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-gray-100 flex items-center gap-2 transition-colors">
                        <i data-lucide="printer" class="w-4 h-4"></i> Imprimir Relatório
                    </button>
                    <button onclick="closeModal('extract-modal')" class="text-gray-400 hover:text-gray-600 p-2 transition-colors"><i data-lucide="x" class="w-6 h-6"></i></button>
                </div>
            </div>

            <div class="flex-1 overflow-y-auto p-6 bg-white" id="modal-content">
                <!-- Conteúdo por Recurso injetado via JS -->
            </div>

            <!-- TOTALIZADORES NO MODAL -->
            <div class="px-8 py-4 bg-gray-50 border-t border-gray-100 grid grid-cols-2 md:grid-cols-5 gap-4 shrink-0">
                <div class="text-center md:border-r border-gray-200">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Franquia</p>
                    <p class="text-lg font-bold text-gray-700" id="modal-val-franchise">0.0h</p>
                </div>
                <div class="text-center md:border-r border-gray-200 no-print">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Total Lançado</p>
                    <p class="text-lg font-bold text-gray-600" id="modal-val-logged">0.0h</p>
                </div>
                <div class="text-center md:border-r border-gray-200">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">A Faturar</p>
                    <p class="text-lg font-black text-blue-600" id="modal-subtotal-billable">0.0h</p>
                </div>
                <div class="text-center md:border-r border-gray-200">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Adesão</p>
                    <div class="flex justify-center mt-1">
                        <span id="modal-indicator-badge" class="px-3 py-1 rounded-full text-[10px] font-black border uppercase">0%</span>
                    </div>
                </div>
                <div class="text-center">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Total Faturável</p>
                    <p class="text-lg font-black text-green-600" id="modal-subtotal-value">R$ 0,00</p>
                </div>
            </div>

            <div class="p-6 border-t border-gray-100 bg-white flex justify-between items-center shrink-0 no-print">
                <div class="flex items-center gap-3 bg-gray-50 px-4 py-2 rounded-xl border border-gray-200">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" id="show-values-print" class="sr-only peer">
                        <div class="w-9 h-5 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                    </label>
                    <span class="text-[10px] font-bold text-gray-500 uppercase">Exibir valores no relatório</span>
                </div>
                <div class="flex gap-3">
                    <button onclick="closeModal('extract-modal')" class="px-6 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg font-bold text-sm hover:bg-gray-50 transition-colors">Voltar</button>
                    <button onclick="saveAdjustments()" id="btn-save-adjusts" class="px-6 py-2 bg-blue-600 text-white rounded-lg font-bold text-sm hover:bg-blue-700 shadow-md transition-all flex items-center gap-2">
                        <i data-lucide="save" class="w-4 h-4"></i> Salvar Medição
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL: FINALIZAR (COM COMPROVANTE OPCIONAL) -->
    <div id="finalize-modal" class="fixed inset-0 modal-backdrop hidden flex items-center justify-center z-[60] p-4 bg-black/60 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8 transform transition-all border border-gray-100">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 p-3">
                    <img src="https://c3c.my.site.com/resource/1752735833000/logo" alt="Logo C3C" class="w-full h-auto">
                </div>
                <h3 class="text-xl font-bold text-gray-900">Finalizar Medição</h3>
                <p class="text-sm text-gray-500 mt-1">Deseja enviar este projeto para o financeiro faturar?</p>
            </div>

            <div class="space-y-4">
                <div class="border-2 border-dashed border-gray-200 rounded-xl p-4 text-center hover:border-blue-400 hover:bg-blue-50 transition-all cursor-pointer group relative">
                    <input type="file" class="absolute inset-0 opacity-0 cursor-pointer" id="proof-upload">
                    <i data-lucide="paperclip" class="w-6 h-6 text-gray-300 mx-auto mb-1 group-hover:text-blue-500"></i>
                    <p class="text-[10px] font-bold text-gray-400 group-hover:text-blue-600 uppercase">Comprovante de Aprovação (Opcional)</p>
                    <p id="file-name-display" class="text-[10px] text-blue-600 font-bold mt-1 hidden"></p>
                </div>
                
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Notas Internas</label>
                    <textarea id="finalize-notes" class="w-full border border-gray-200 rounded-lg p-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none resize-none h-20" placeholder="Ex: Cliente deu o ok via e-mail direto ao financeiro."></textarea>
                </div>
            </div>

            <div class="mt-8 flex gap-3">
                <button onclick="closeModal('finalize-modal')" class="flex-1 px-4 py-2 border border-gray-300 text-gray-600 rounded-lg font-bold text-sm">Voltar</button>
                <button onclick="completeFinalization()" class="flex-1 px-4 py-2 bg-indigo-600 text-white rounded-lg font-bold text-sm shadow-md hover:bg-indigo-700">Fechar e Travar</button>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
        let currentProjects = [];
        let currentLogs = [];
        let activeProject = null;

        async function loadBillingGrid() {
            const period = document.getElementById('period-selector').value;
            const [start, end] = period.split('|');
            
            try {
                const res = await fetch(`/api/billing/grid?startDate=${start}&endDate=${end}`);
                currentProjects = await res.json();
                renderTable();
            } catch (e) { console.error('Erro ao carregar grade:', e); }
        }

        function getComparisonIndicator(billable, previsto) {
            const diff = billable - previsto;
            const percent = previsto > 0 ? ((billable / previsto) * 100).toFixed(0) : 0;
            let colorClass = '';
            let label = `${percent}%`;

            if (Math.abs(diff) < 0.01) {
                colorClass = 'text-green-600 bg-green-50 border-green-200';
            } else if (billable < previsto) {
                colorClass = 'text-red-600 bg-red-50 border-red-200';
            } else {
                colorClass = 'text-purple-600 bg-purple-50 border-purple-200';
            }
            return { colorClass, label, diff };
        }

        function renderTable() {
            const tbody = document.getElementById('billing-table-body');
            const searchInput = document.getElementById('billing-search');
            const query = searchInput ? searchInput.value.toLowerCase() : '';
            
            const reqOnly = document.getElementById('filter-required').checked;
            const reqReport = document.getElementById('filter-requested').checked;

            tbody.innerHTML = '';
            
            let filtered = currentProjects.filter(p => {
                const matchesQuery = p.name.toLowerCase().includes(query) || p.client.toLowerCase().includes(query);
                const matchesRequired = !reqOnly || p.flags.required;
                const matchesRequested = !reqReport || p.flags.requested;
                return matchesQuery && matchesRequired && matchesRequested;
            });

            // Ordenação: Menor Adesão para a Maior
            filtered.sort((a, b) => {
                const adesaoA = a.franchise > 0 ? (a.billable / a.franchise) : 0;
                const adesaoB = b.franchise > 0 ? (b.billable / b.franchise) : 0;
                return adesaoA - adesaoB;
            });

            if (filtered.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" class="px-6 py-10 text-center text-gray-400 italic">Nenhum serviço encontrado.</td></tr>';
                return;
            }

            filtered.forEach(p => {
                const indicator = getComparisonIndicator(p.billable, p.franchise);
                const isModified = Math.abs(p.billable - p.logged) > 0.01;
                const isSupport = p.type === 'Suporte';
                
                tbody.innerHTML += `
                <tr class="hover:bg-gray-50/50 transition-colors">
                    <td class="px-6 py-5">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-blue-50 rounded-lg text-blue-600 no-print shrink-0"><i data-lucide="briefcase" class="w-4 h-4"></i></div>
                            <div>
                                <p class="font-bold text-gray-800 text-sm leading-tight">${p.name}</p>
                                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-tighter">
                                    ${p.client} • <span class="${isSupport ? 'text-teal-600' : 'text-indigo-400'}">${p.type}</span>
                                </p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-5 text-center font-bold text-gray-400">${p.franchise.toFixed(1)}h</td>
                    <td class="px-6 py-5 text-center font-bold text-gray-400">${p.logged.toFixed(1)}h</td>
                    <td class="px-6 py-5 text-center">
                        <span class="px-3 py-1.5 rounded-lg font-black text-sm border ${isModified ? 'bg-orange-50 text-orange-700 border-orange-200' : 'bg-blue-50 text-blue-700 border-blue-100'}">
                            ${p.billable.toFixed(1)}h
                        </span>
                    </td>
                    <td class="px-6 py-5 text-center">
                         <span class="px-2 py-0.5 rounded-full text-[10px] font-black border uppercase ${indicator.colorClass}">
                            ${indicator.label}
                         </span>
                    </td>
                    <td class="px-6 py-5">
                        <div class="flex flex-col gap-1 items-center justify-center">
                            ${p.flags.required ? '<span class="px-2 py-0.5 rounded-md bg-indigo-50 text-indigo-600 border border-indigo-100 text-[8px] font-bold uppercase whitespace-nowrap">Auditoria</span>' : ''}
                            ${p.flags.requested ? '<span class="px-2 py-0.5 rounded-md bg-blue-50 text-blue-600 border border-blue-100 text-[8px] font-bold uppercase whitespace-nowrap">Relatório</span>' : ''}
                        </div>
                    </td>
                    <td class="px-6 py-5 text-center font-bold text-gray-600">R$ ${p.avgRate.toFixed(2)}</td>
                    <td class="px-6 py-5 text-center">
                        <p class="font-black text-gray-900 text-sm">R$ ${p.totalValue.toLocaleString('pt-BR', {minimumFractionDigits: 2})}</p>
                    </td>
                    <td class="px-6 py-5 text-center">
                        <span class="bg-blue-50 text-blue-700 px-2 py-1 rounded text-[10px] font-black border border-blue-100 uppercase">Aberto</span>
                    </td>
                    <td class="px-6 py-5 text-right">
                        <div class="flex justify-end items-center gap-2">
                            <button onclick="openAuditoria('${p.id}')" class="text-blue-600 font-bold text-xs hover:underline mr-2 flex items-center gap-1">
                                <i data-lucide="list-checks" class="w-3 h-3"></i> Auditar
                            </button>
                            <button onclick="openFinalizeModal('${p.id}')" class="bg-indigo-600 text-white px-3 py-1.5 rounded-lg font-bold text-xs shadow-sm hover:bg-indigo-700 flex items-center gap-1 transition-colors">
                                <i data-lucide="check" class="w-3 h-3"></i> Fechar
                            </button>
                        </div>
                    </td>
                </tr>`;
            });
            lucide.createIcons();
        }

        function formatWithDay(dateStr) {
            if (!dateStr) return '-';
            const date = new Date(dateStr + 'T12:00:00');
            const options = { weekday: 'short', day: '2-digit', month: '2-digit' };
            return date.toLocaleDateString('pt-BR', options).replace('.', '');
        }

        async function openAuditoria(serviceId) {
            activeProject = currentProjects.find(p => p.id === serviceId);
            const periodSelect = document.getElementById('period-selector');
            const period = periodSelect.value;
            const [start, end] = period.split('|');
            
            document.getElementById('ext-project-name').innerText = activeProject.name;
            document.getElementById('ext-client-name').innerText = activeProject.client;

            try {
                const res = await fetch(`/api/billing/service-logs?serviceId=${serviceId}&startDate=${start}&endDate=${end}`);
                const data = await res.json();
                currentLogs = Array.isArray(data) ? data : [];
                
                if (currentLogs.length === 0 && activeProject.type !== 'Suporte') {
                    alert('Nenhum log encontrado no período.');
                    return;
                }
                
                renderModalLogs();
                updateModalTotals();
                openModal('extract-modal');
            } catch (e) { console.error('Erro ao buscar logs:', e); }
        }

        function printTechnicalReport() {
            const period = document.getElementById('period-selector').value;
            const [start, end] = period.split('|');
            const showValues = document.getElementById('show-values-print').checked;
            const url = `/billing/report-print?serviceId=${activeProject.id}&startDate=${start}&endDate=${end}&showValues=${showValues}`;
            window.open(url, '_blank');
        }

        function renderModalLogs() {
            const container = document.getElementById('modal-content');
            container.innerHTML = '';

            if (currentLogs.length === 0) {
                container.innerHTML = `
                    <div class="flex flex-col items-center justify-center py-20 bg-gray-50 rounded-2xl border-2 border-dashed border-gray-200">
                        <div class="p-4 bg-white rounded-full shadow-sm mb-4 text-gray-300">
                            <i data-lucide="clock-off" class="w-10 h-10"></i>
                        </div>
                        <p class="text-sm font-bold text-gray-500 uppercase tracking-widest">Nenhum consumo de horas</p>
                        <p class="text-xs text-gray-400 mt-1">Este serviço não possui lançamentos no período selecionado.</p>
                    </div>`;
                lucide.createIcons();
                return;
            }

            const resources = [...new Set(currentLogs.map(l => l.resourceName))];
            
            resources.forEach(res => {
                const logs = currentLogs.filter(l => l.resourceName === res);
                let logsHtml = '';
                let resSumLogged = 0;
                let resSumBillable = 0;
                let resSumValue = 0;
                
                logs.forEach(log => {
                    const glosaClass = log.billable < log.logged ? 'glosa' : '';
                    resSumLogged += log.logged;
                    resSumBillable += log.billable;
                    resSumValue += (log.billable * log.rate);

                    logsHtml += `
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="px-4 py-2 font-mono text-[11px] text-gray-500 border-b border-gray-100">${formatWithDay(log.date)}</td>
                        <td class="px-4 py-2 text-gray-700 border-b border-gray-100 leading-tight text-xs">${log.desc}</td>
                        <td class="px-4 py-2 text-center text-gray-400 font-bold border-b border-gray-100 no-print text-xs">${log.logged.toFixed(1)}h</td>
                        <td class="px-4 py-2 text-center border-b border-gray-100">
                            <input type="number" step="0.5" value="${log.billable}" 
                                   class="input-log-billable ${glosaClass} text-xs" 
                                   onchange="updateLocalLog('${log.id}', this.value)">
                        </td>
                        <td class="px-4 py-2 text-right text-gray-500 font-medium border-b border-gray-100 text-xs">R$ ${(log.billable * log.rate).toLocaleString('pt-BR', {minimumFractionDigits: 2})}</td>
                    </tr>`;
                });

                container.innerHTML += `
                <div class="resource-block mb-10">
                    <div class="bg-gray-100 px-4 py-2 flex justify-between items-center rounded-t-lg border border-gray-200 border-b-0 shadow-sm no-print">
                        <h4 class="text-[10px] font-black text-gray-500 uppercase flex items-center gap-2">
                            <i data-lucide="user" class="w-3 h-3"></i> Profissional: ${res}
                        </h4>
                        <span class="text-[10px] font-bold text-indigo-600 bg-white px-2 py-0.5 rounded border border-indigo-100">
                            Taxa Venda: R$ ${logs[0].rate.toFixed(2)}
                        </span>
                    </div>
                    <table class="w-full text-xs text-left border border-gray-200 rounded-b-lg overflow-hidden">
                        <thead class="bg-white text-gray-400 font-bold border-b border-gray-100 uppercase tracking-wider text-[10px]">
                            <tr>
                                <th class="px-4 py-2 w-28">Data</th>
                                <th class="px-4 py-2">Atividade</th>
                                <th class="px-4 py-2 text-center w-24 no-print">Lançado</th>
                                <th class="px-4 py-2 text-center w-24">Faturar (h)</th>
                                <th class="px-4 py-2 text-right w-32">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">${logsHtml}</tbody>
                        <tfoot class="bg-gray-50/50 font-bold text-gray-700 border-t border-gray-200">
                            <tr>
                                <td colspan="2" class="px-4 py-2 text-right uppercase text-[10px]">Total ${res.split(' ')[0]}:</td>
                                <td class="px-4 py-2 text-center no-print">${resSumLogged.toFixed(1)}h</td>
                                <td class="px-4 py-2 text-center text-blue-600">${resSumBillable.toFixed(1)}h</td>
                                <td class="px-4 py-2 text-right">R$ ${resSumValue.toLocaleString('pt-BR', {minimumFractionDigits: 2})}</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>`;
            });
            lucide.createIcons();
        }

        function updateLocalLog(logId, val) {
            const log = currentLogs.find(l => l.id === logId);
            log.billable = parseFloat(val) || 0;
            updateModalTotals();
            renderModalLogs();
        }

        function updateModalTotals() {
            let sumBillable = 0, sumLogged = 0, sumFinancial = 0;
            currentLogs.forEach(log => {
                sumBillable += log.billable;
                sumLogged += log.logged;
                sumFinancial += (log.billable * log.rate);
            });

            const indicator = getComparisonIndicator(sumBillable, activeProject.franchise);
            document.getElementById('modal-val-franchise').innerText = activeProject.franchise.toFixed(1) + 'h';
            document.getElementById('modal-val-logged').innerText = sumLogged.toFixed(1) + 'h';
            document.getElementById('modal-subtotal-billable').innerText = sumBillable.toFixed(1) + 'h';
            
            const badge = document.getElementById('modal-indicator-badge');
            badge.innerText = indicator.label;
            badge.className = `px-3 py-1 rounded-full text-[10px] font-black border uppercase transition-colors ${indicator.colorClass}`;

            let finalVal = sumFinancial;
            if (activeProject.type === 'Suporte' && sumBillable < activeProject.franchise) {
                finalVal = activeProject.franchise * activeProject.avgRate;
            }
            
            document.getElementById('modal-subtotal-value').innerText = `R$ ${finalVal.toLocaleString('pt-BR', {minimumFractionDigits: 2})}`;
        }

        async function saveAdjustments() {
            const btn = document.getElementById('btn-save-adjusts');
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="animate-spin w-4 h-4" data-lucide="loader-2"></i> Salvando...';
            lucide.createIcons();

            let sumBillable = 0, sumLogged = 0;
            currentLogs.forEach(log => {
                sumBillable += log.billable;
                sumLogged += log.logged;
            });

            const reportData = {
                clientId: activeProject.clientId,
                franchise: activeProject.franchise,
                logged: sumLogged,
                billable: sumBillable
            };

            try {
                const res = await fetch('/api/billing/save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        serviceId: activeProject.id,
                        logs: currentLogs,
                        reportData: reportData
                    })
                });

                if (res.ok) {
                    closeModal('extract-modal');
                    loadBillingGrid();
                } else {
                    const err = await res.json();
                    alert('Erro ao salvar medição: ' + (err.error || 'Erro desconhecido'));
                }
            } catch (e) { console.error('Erro na requisição.'); }
            
            btn.disabled = false;
            btn.innerHTML = originalHtml;
            lucide.createIcons();
        }

        function openFinalizeModal(id) {
            activeProject = currentProjects.find(p => p.id === id);
            openModal('finalize-modal');
        }

        async function completeFinalization() {
            await saveAdjustments();
            closeModal('finalize-modal');
            alert('Medição finalizada e enviada ao financeiro!');
        }

        function openModal(id) { 
            const m = document.getElementById(id);
            m.classList.remove('hidden'); 
            setTimeout(() => m.classList.remove('opacity-0'), 10);
        }
        
        function closeModal(id) { 
            const m = document.getElementById(id);
            m.classList.add('opacity-0'); 
            setTimeout(() => m.classList.add('hidden'), 300); 
        }

        document.getElementById('proof-upload')?.addEventListener('change', function(e) {
            const display = document.getElementById('file-name-display');
            if (this.files.length) {
                display.innerText = '✓ ' + this.files[0].name;
                display.classList.remove('hidden');
            } else {
                display.classList.add('hidden');
            }
        });
        
        loadBillingGrid();
    </script>
</body>
</html>
