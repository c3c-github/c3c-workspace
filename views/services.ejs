        async function linkSelectedSales() {
            const selectedIds = Array.from(document.querySelectorAll('input[name="sale-check"]:checked')).map(cb => cb.value);
            if(selectedIds.length === 0) return document.getElementById('sales-modal').classList.add('hidden');

            document.getElementById('sales-modal').classList.add('hidden');
            document.getElementById('modal-loader').classList.remove('hidden');

            for (const saleId of selectedIds) {
                const sale = availableSales.find(s => s.id === saleId);
                if (!sale) continue;

                linkedSales.push({ id_ca: sale.id, number: sale.number, date: sale.emissionDate, total: sale.total, status: sale.status });

                try {
                    const res = await fetch(`/api/services/sales/${saleId}/installments`);
                    const installments = await res.json();
                    installments.forEach(inst => {
                        addBillingRow({
                            desc: inst.desc,
                            month: inst.month,
                            date: inst.date,
                            value: inst.value,
                            status: inst.status,
                            originSaleId: saleId
                        });
                    });
                } catch(e) { console.error("Erro ao buscar parcelas:", e); }
            }

            renderLinkedSales();
            
            // --- SALVAMENTO IMEDIATO NO SALESFORCE ---
            try {
                const billingPayload = {
                    serviceId: currentServiceData.id,
                    sales: linkedSales.map(s => ({ id: s.id_ca || s.id, number: s.number, emissionDate: s.date, total: s.total, status: s.status }))
                };

                const resBill = await fetch('/api/services/sales', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(billingPayload) });
                const dataBill = await resBill.json();

                if (dataBill.success) {
                    showToast('Vendas e parcelas sincronizadas com sucesso!');
                } else {
                    showToast("Vínculo realizado localmente, mas houve erro na sincronização: " + dataBill.error, 'error');
                }
            } catch(e) {
                showToast("Erro ao sincronizar com Salesforce: " + e.message, 'error');
            }

            document.getElementById('modal-loader').classList.add('hidden');
        }

        function renderLinkedSales() {
            const container = document.getElementById('linked-sales-container');
            const list = document.getElementById('linked-sales-list');
            const countEl = document.getElementById('linked-sales-count');
            
            if (!linkedSales || linkedSales.length === 0) {
                container.classList.add('hidden');
                if(countEl) countEl.innerText = '0';
                return;
            }

            container.classList.remove('hidden');
            if(countEl) countEl.innerText = linkedSales.length;
            list.innerHTML = '';

            linkedSales.forEach(s => {
                const date = s.date ? (s.date.includes('T') ? s.date.split('T')[0] : s.date).split('-').reverse().join('/') : '-';
                list.insertAdjacentHTML('beforeend', `
                    <div class="bg-blue-50/40 border-2 border-blue-100 p-5 rounded-[24px] flex justify-between items-center group hover:border-c3c-blue transition-all">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-2xl bg-white flex items-center justify-center text-c3c-blue shadow-sm group-hover:bg-c3c-blue group-hover:text-white transition-all">
                                <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                            </div>
                            <div class="text-left">
                                <p class="text-[11px] font-black text-gray-800 uppercase tracking-tighter">Venda #${s.number}</p>
                                <p class="text-[9px] font-bold text-c3c-blue uppercase mt-0.5">${money.format(s.total)}</p>
                                <p class="text-[8px] font-black text-gray-400 uppercase mt-0.5">${date}</p>
                            </div>
                        </div>
                        <button onclick="removeLinkedSale('${s.id}', '${s.id_ca}')" title="Desvincular Venda" class="p-2 text-gray-300 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all">
                            <i data-lucide="unlink-2" class="w-4 h-4"></i>
                        </button>
