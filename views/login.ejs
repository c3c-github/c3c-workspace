<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - C3C Workplace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Montserrat', sans-serif;
            background: #1DDDBD linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%) 0% 0% no-repeat padding-box;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
        .fade-in { animation: fadeIn 0.5s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body class="h-screen flex items-center justify-center p-4">

    <div class="login-card w-full max-w-md rounded-[40px] shadow-2xl p-8 md:p-12 flex flex-col items-center text-center border border-white/20 fade-in">
        
        <img src="/assets/signatures/assinaturaLogo.png" alt="C3C Logo" class="h-12 mb-4">
        <h1 class="text-2xl font-black text-gray-800 mb-2 tracking-tighter uppercase">Workplace<span class="text-[#2978FF]">.</span></h1>
        <p class="text-gray-400 text-[10px] mb-10 font-black uppercase tracking-[0.2em]">Portal do Colaborador</p>

        <!-- MENSAGEM DE ERRO -->
        <div id="error-container" class="hidden w-full mb-6 p-4 bg-red-50 border border-red-100 rounded-2xl flex items-center gap-3 text-left animate-bounce">
            <i data-lucide="alert-circle" class="w-5 h-5 text-red-500 shrink-0"></i>
            <div>
                <p class="text-[10px] font-black text-red-600 uppercase tracking-widest">Erro de Acesso</p>
                <p id="error-message" class="text-xs text-red-500 font-bold leading-tight"></p>
            </div>
        </div>

        <div id="login-state" class="w-full space-y-6">
            <div class="flex justify-center mb-8">
                <div class="relative">
                    <div class="absolute inset-0 bg-[#1DDDBD] rounded-full animate-ping opacity-20"></div>
                    <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-white shadow-xl bg-white flex items-center justify-center relative z-10">
                        <img src="/assets/signatures/assinaturaCapivorce.png" alt="Capivorce" class="w-full h-full object-cover">
                    </div>
                </div>
            </div>

            <div class="mb-8">
                <h2 class="text-xl font-bold text-gray-800 mb-1">Bem-vindo de volta!</h2>
                <p class="text-xs text-gray-500 font-medium">Acesse sua conta para gerenciar suas horas.</p>
            </div>

            <button onclick="handleLogin()" class="flex items-center justify-center gap-3 w-full bg-[#1DDDBD] hover:opacity-90 text-white font-black uppercase text-xs tracking-widest py-5 rounded-[20px] shadow-xl shadow-blue-200 transition-all transform hover:-translate-y-1 active:scale-95 group" style="background: linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%);">
                <div class="bg-white p-1 rounded-md shadow-sm flex items-center justify-center">
                    <svg class="w-4 h-4" viewBox="0 0 23 23">
                        <path fill="#f35325" d="M1 1h10v10H1z"/>
                        <path fill="#81bc06" d="M12 1h10v10H12z"/>
                        <path fill="#05a6f0" d="M1 12h10v10H1z"/>
                        <path fill="#ffba08" d="M12 12h10v10H12z"/>
                    </svg>
                </div>
                Entrar com Microsoft 365
            </button>

            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest pt-4">Para time <span class="text-[#2978FF]">@C3Ceiros</span></p>
        </div>

        <!-- Estado de Carregamento -->
        <div id="loading-state" class="hidden flex-col items-center justify-center w-full fade-in py-10">
            <div class="w-16 h-16 border-4 border-gray-100 border-t-[#2978FF] rounded-full animate-spin mb-6"></div>
            <h3 class="text-lg font-bold text-gray-800 uppercase tracking-tighter">Autenticando...</h3>
            <p class="text-xs text-gray-400 font-bold uppercase mt-2">Conectando ao Azure AD</p>
        </div>

        <div class="mt-12 flex items-center gap-2 text-gray-300">
            <i data-lucide="shield-check" class="w-4 h-4"></i>
            <span class="text-[9px] font-black uppercase tracking-tighter">Ambiente Seguro & Criptografado</span>
        </div>
    </div>

    <script>
        lucide.createIcons();

        // Simulação de erro via Query Param (ex: /?error=Acesso Negado)
        document.addEventListener('DOMContentLoaded', () => {
            const params = new URLSearchParams(window.location.search);
            const error = params.get('error');
            if (error) {
                showError(error);
            }
        });

        function showError(msg) {
            document.getElementById('error-message').innerText = msg;
            document.getElementById('error-container').classList.remove('hidden');
            document.getElementById('error-container').classList.add('flex');
        }

        function handleLogin() {
            document.getElementById('login-state').classList.add('hidden');
            document.getElementById('loading-state').classList.remove('hidden');
            document.getElementById('loading-state').classList.add('flex');
            setTimeout(() => {
                window.location.href = '/auth/login';
            }, 500);
        }
    </script>
</body>
</html>
