<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestão de Serviços - C3C Workspace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { 
                        c3c: { 
                            blue: '#2978FF', 
                            teal: '#1DDDBD', 
                            gray: '#F2F2F2',
                            dark: '#000000'
                        } 
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .bg-c3c-gradient { background: transparent linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%) 0% 0% no-repeat padding-box; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
        .modal-tab-active { border-bottom: 3px solid #2978FF; color: #2978FF; font-weight: 800; background-color: #F8FAFC; }
        .modal-tab-inactive { border-bottom: 3px solid transparent; color: #94A3B8; }
        .modal-tab-inactive:hover { color: #475569; background-color: #F9FAFB; }
        .input-inline { background: transparent; border: 1px solid transparent; width: 100%; border-radius: 8px; padding: 4px 8px; transition: all 0.2s; }
        .input-inline:hover { border-color: #E2E8F0; background: white; }
        .input-inline:focus { border-color: #2978FF; background: white; outline: none; box-shadow: 0 0 0 4px rgba(41, 120, 255, 0.05); }
        .table-dense th, .table-dense td { padding: 8px 12px; font-size: 11px; vertical-align: middle; }
        .readonly-field { background-color: #F3F4F6; color: #6B7280; cursor: not-allowed; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#F8FAFC]">

    <%- include('partials/sidebar', { page: 'services' }) %>

    <main class="flex-1 flex flex-col md:ml-64 relative w-full transition-all duration-300 overflow-hidden">
        
        <!-- HEADER -->
        <header class="h-20 bg-white border-b border-gray-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-20 shrink-0">
            <div class="flex items-center gap-4 text-left">
                <button onclick="document.getElementById('sidebar').classList.toggle('-translate-x-full')" class="md:hidden p-2 text-gray-600 hover:bg-gray-100 rounded-lg">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <div>
                    <h1 class="text-lg md:text-xl font-bold text-gray-800 flex items-center gap-2 tracking-tight">Gestão de Serviços <span class="text-c3c-blue">📁</span></h1>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest hidden sm:block">Portfólio de Contratos e Baseline Comercial</p>
                </div>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="relative group hidden lg:block">
                    <i data-lucide="search" class="w-4 h-4 text-gray-300 absolute left-4 top-1/2 -translate-y-1/2 group-focus-within:text-c3c-blue transition-colors"></i>
                    <input type="text" id="search-input" onkeyup="filterServices()" placeholder="Buscar por serviço ou cliente..." class="w-72 pl-11 pr-4 py-2.5 bg-gray-50 border border-gray-100 rounded-2xl text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all">
                </div>
                <div class="h-8 w-px bg-gray-100 hidden lg:block"></div>
                
                <div class="flex items-center bg-gray-50 border border-gray-100 rounded-xl px-3 py-1.5 gap-2 shadow-sm focus-within:ring-2 focus-within:ring-c3c-blue transition-all">
                    <i data-lucide="filter" class="w-3.5 h-3.5 text-c3c-blue"></i>
                    <select id="status-filter" onchange="filterServices()" class="bg-transparent text-[10px] font-black text-gray-500 uppercase tracking-widest outline-none cursor-pointer pr-6">
                        <option value="active" selected>Ativos</option>
                        <option value="inactive">Inativos</option>
                        <option value="all">Todos</option>
                    </select>
                </div>

                <button onclick="openServiceModal()" class="bg-c3c-gradient text-white text-[10px] font-black uppercase tracking-widest px-6 py-3 rounded-xl shadow-lg shadow-blue-100 transition-all active:scale-95 flex items-center gap-2">
                    <i data-lucide="plus" class="w-4 h-4"></i> Novo Serviço
                </button>
            </div>
        </header>

        <!-- CONTEÚDO -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 fade-in custom-scrollbar bg-gray-50/30 text-left">
            <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6" id="services-grid">
                <!-- Cards de Serviço injetados via JS -->
            </div>
            <div id="no-results" class="hidden flex-col items-center justify-center py-32 text-center opacity-30">
                <i data-lucide="search-x" class="w-16 h-16 text-gray-300 mb-4"></i>
                <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest">Nenhum serviço encontrado</h3>
            </div>
        </div>
    </main>

    <!-- MEGA MODAL SERVIÇO PREMIUM -->
    <div id="service-modal" class="fixed inset-0 bg-black/60 backdrop-blur-md hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-[48px] shadow-2xl w-full max-w-[95vw] h-[95vh] flex flex-col transform scale-95 transition-all overflow-hidden border border-white/20">
            
            <!-- LOADER -->
            <div id="modal-loader" class="absolute inset-0 bg-white/90 z-[100] flex items-center justify-center hidden">
                <div class="flex flex-col items-center gap-4">
                    <div class="w-12 h-12 border-4 border-blue-100 border-t-c3c-blue rounded-full animate-spin"></div>
                    <p class="text-[10px] font-black text-c3c-blue uppercase tracking-[0.3em] animate-pulse">Processando dados...</p>
                </div>
            </div>

            <!-- HEADER MODAL -->
            <header class="p-8 border-b border-gray-100 bg-gray-50/50 shrink-0">
                <div class="flex justify-between items-start mb-8">
                    <div class="text-left">
                        <div class="flex items-center gap-3 mb-2">
                            <span id="badge-status" class="bg-teal-50 text-teal-600 text-[9px] px-3 py-1 rounded-full border border-teal-100 font-black uppercase tracking-widest">Ativo</span>
                            <span class="text-[10px] font-black text-gray-300 uppercase tracking-[0.2em] italic" id="modal-svc-id">#ID...</span>
                        </div>
                        <h3 class="text-3xl font-black text-gray-800 tracking-tighter uppercase leading-tight" id="modal-svc-title">Novo Serviço</h3>
                    </div>
                    <div class="flex items-center gap-4">
                        <button onclick="saveService()" class="px-10 py-4 bg-c3c-gradient text-white font-black uppercase text-xs tracking-widest rounded-2xl shadow-xl shadow-blue-100 hover:opacity-90 transition-all active:scale-95 flex items-center gap-2"><i data-lucide="check" class="w-4 h-4"></i> Salvar Alterações</button>
                        <button onclick="closeModal('service-modal')" class="p-3 bg-white hover:bg-red-50 text-gray-400 hover:text-red-500 rounded-full transition-all shadow-sm"><i data-lucide="x" class="w-6 h-6"></i></button>
                    </div>
                </div>

                <!-- SUMMARY CARDS -->
                <div class="grid grid-cols-3 gap-6">
                    <div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm flex justify-between items-center text-left">
                        <div><p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Baseline Comercial</p><p class="text-xl font-black text-gray-800 tracking-tighter" id="card-prop-rev">R$ 0,00</p></div>
                        <div class="text-right px-4 py-2 bg-blue-50 rounded-2xl border border-blue-50"><p class="text-[8px] font-black text-c3c-blue uppercase">Margem</p><p class="text-sm font-black text-c3c-blue" id="card-prop-margin">0%</p></div>
                    </div>
                    <div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm flex justify-between items-center text-left">
                        <div><p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Previsão Alocação</p><p class="text-xl font-black text-gray-800 tracking-tighter" id="card-fcst-rev">R$ 0,00</p></div>
                        <div class="text-right px-4 py-2 bg-indigo-50 rounded-2xl border border-indigo-50"><p class="text-[8px] font-black text-indigo-600 uppercase">Margem</p><p class="text-sm font-black text-indigo-600" id="card-fcst-margin">0%</p></div>
                    </div>
                    <div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm flex justify-between items-center text-left">
                        <div><p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Resultado Realizado</p><p class="text-xl font-black text-gray-800 tracking-tighter" id="card-act-rev">R$ 0,00</p></div>
                        <div class="text-right px-4 py-2 bg-teal-50 rounded-2xl border border-teal-50"><p class="text-[8px] font-black text-teal-600 uppercase">Margem</p><p class="text-sm font-black text-teal-600" id="card-act-margin">0%</p></div>
                    </div>
                </div>
            </header>

            <!-- TABS MODAL -->
            <div class="flex px-10 border-b border-gray-100 bg-white shrink-0 gap-10 overflow-x-auto no-scrollbar">
                <button onclick="switchTab('general')" id="tab-general" class="modal-tab-active py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Geral</button>
                <button onclick="switchTab('commercial')" id="tab-commercial" class="modal-tab-inactive py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Baseline</button>
                <button onclick="switchTab('execution')" id="tab-execution" class="modal-tab-inactive py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Previsão</button>
                <button onclick="switchTab('billing')" id="tab-billing" class="modal-tab-inactive py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Faturamento (ERP)</button>
                <button onclick="switchTab('realized')" id="tab-realized" class="modal-tab-inactive py-5 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap transition-all">Extrato Real</button>
            </div>

            <!-- CONTEÚDO TABS -->
            <div class="flex-1 overflow-y-auto p-10 custom-scrollbar bg-gray-50/30">
                <!-- 1. GERAL -->
                <div id="view-general" class="fade-in max-w-5xl mx-auto space-y-8 text-left">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                        <div class="space-y-6">
                            <h4 class="text-xs font-black text-c3c-blue uppercase tracking-[0.3em] border-b border-blue-50 pb-3 flex items-center gap-2"><i data-lucide="info" class="w-4 h-4"></i> Dados do Contrato</h4>
                            <div class="space-y-4">
                                <div><label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Nome do Serviço</label><input type="text" id="input-svc-name" class="w-full bg-white border border-gray-200 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all"></div>
                                <div class="grid grid-cols-2 gap-4">
                                    <div><label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Cliente (SF)</label><div class="relative"><input list="sf-accounts-list" id="input-sf-account" class="w-full bg-white border border-gray-200 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all pr-10"><i data-lucide="search" class="w-4 h-4 text-gray-300 absolute right-4 top-1/2 -translate-y-1/2"></i></div><datalist id="sf-accounts-list"></datalist></div>
                                    <div><label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Cliente (Conta Azul)</label><div class="relative"><input list="ca-clients-list" id="input-ca-client" class="w-full bg-white border border-gray-200 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all pr-10" placeholder="Vincular CNPJ..."><i data-lucide="link" class="w-4 h-4 text-gray-300 absolute right-4 top-1/2 -translate-y-1/2"></i></div><datalist id="ca-clients-list"></datalist></div>
                                </div>
                                <div class="grid grid-cols-2 gap-4">
                                    <div><label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Tipo de Serviço</label><select id="input-svc-type" class="w-full bg-white border border-gray-200 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all cursor-pointer"><option>Suporte</option><option>Projeto</option><option>Alocação</option></select></div>
                                    <div><label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Data Início</label><input type="date" id="input-svc-start" class="w-full bg-white border border-gray-200 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all"></div>
                                </div>
                                <div class="grid grid-cols-2 gap-4">
                                    <div><label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Data Fim Original</label><input type="date" id="input-svc-end-orig" class="w-full bg-white border border-gray-200 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all"></div>
                                    <div><label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Data Fim Real</label><input type="date" id="input-svc-end-real" class="w-full bg-white border border-gray-200 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all"></div>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-6">
                            <h4 class="text-xs font-black text-c3c-blue uppercase tracking-[0.3em] border-b border-blue-50 pb-3 flex items-center gap-2"><i data-lucide="users" class="w-4 h-4"></i> Governança e Liderança</h4>
                            <div class="space-y-4">
                                <div><label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Líder de Projeto</label><div class="relative"><input list="people-list" id="input-lead-project" class="w-full bg-white border border-gray-200 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all pr-10"><i data-lucide="user" class="w-4 h-4 text-gray-300 absolute right-4 top-1/2 -translate-y-1/2"></i></div></div>
                                <div><label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Coordenador</label><div class="relative"><input list="people-list" id="input-coordinator" class="w-full bg-white border border-gray-200 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all pr-10"><i data-lucide="user" class="w-4 h-4 text-gray-300 absolute right-4 top-1/2 -translate-y-1/2"></i></div></div>
                                <div><label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Líder Técnico</label><div class="relative"><input list="people-list" id="input-tech-lead" class="w-full bg-white border border-gray-200 rounded-2xl px-5 py-3 text-xs font-bold focus:ring-4 focus:ring-blue-50 focus:border-c3c-blue outline-none transition-all pr-10"><i data-lucide="user" class="w-4 h-4 text-gray-300 absolute right-4 top-1/2 -translate-y-1/2"></i></div></div>
                                <datalist id="people-list"></datalist>
                            </div>
                        </div>
                    </div>

                    <div class="mt-12 bg-white rounded-3xl border border-gray-100 p-8 shadow-sm">
                        <h4 class="text-xs font-black text-gray-800 uppercase tracking-widest mb-6 flex items-center gap-2"><i data-lucide="file-text" class="w-4 h-4 text-c3c-blue"></i> Documentação do Projeto</h4>
                        <div id="docs-list-container" class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                            <!-- Documentos injetados via JS -->
                            <p class="text-[10px] font-bold text-gray-300 uppercase tracking-widest italic col-span-full py-8 text-center bg-gray-50/50 rounded-2xl border border-dashed border-gray-100">Nenhum documento anexado.</p>
                        </div>
                        <button onclick="openUploadModal()" class="w-full bg-gray-50 hover:bg-blue-50 text-c3c-blue text-[10px] font-black uppercase tracking-widest px-6 py-4 rounded-2xl border border-dashed border-blue-100 transition-all flex items-center justify-center gap-2 active:scale-[0.99]"><i data-lucide="upload-cloud" class="w-4 h-4"></i> Anexar Proposta ou Contrato</button>
                    </div>
                </div>

                <!-- 2. BASELINE COMERCIAL -->
                <div id="view-commercial" class="hidden fade-in space-y-8 text-left">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-c3c-blue/5 p-6 rounded-3xl border border-blue-50">
                        <div><h4 class="text-sm font-black text-c3c-blue uppercase tracking-widest">Orçamento Vendido (Baseline)</h4><p class="text-[10px] font-bold text-blue-400 uppercase tracking-widest mt-1">Defina os itens da proposta comercial aceita pelo cliente.</p></div>
                        <div class="flex items-center gap-4 bg-white px-4 py-2 rounded-2xl border border-blue-100 shadow-sm"><label class="text-[9px] font-black text-gray-400 uppercase tracking-widest">Tabela de Preços:</label><select id="select-pricebook" onchange="onPricebookChange()" class="text-xs font-black text-c3c-blue uppercase outline-none bg-transparent cursor-pointer pr-4"></select></div>
                    </div>
                    
                    <div class="bg-white rounded-[32px] border border-gray-100 shadow-xl overflow-hidden">
                        <table class="w-full text-left table-dense">
                            <thead class="bg-gray-50/80 border-b border-gray-100">
                                <tr>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest py-5 px-6">Produto / Perfil</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Taxa Venda</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Custo Est.</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Início</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Fim</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Dias</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">%</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Hrs Totais</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right bg-blue-50/50">Receita Total</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Custo Total</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center px-6">Ação</th>
                                </tr>
                            </thead>
                            <tbody id="commercial-rows" class="divide-y divide-gray-50"></tbody>
                            <tfoot class="bg-gray-50/50 border-t border-gray-100 font-black text-gray-800">
                                <tr class="h-16">
                                    <td colspan="7" class="text-right uppercase text-[10px] tracking-widest pr-8 text-gray-400">Totais Baseline:</td>
                                    <td class="text-right text-xs" id="comm-total-hours">0h</td>
                                    <td class="text-right text-xs text-c3c-blue bg-blue-50/50" id="comm-total-rev">R$ 0,00</td>
                                    <td class="text-right text-xs text-red-600" id="comm-total-cost">R$ 0,00</td>
                                    <td class="px-6 text-center text-xs text-indigo-600" id="comm-total-margin">0%</td>
                                </tr>
                            </tfoot>
                        </table>
                        <div class="p-4 bg-gray-50/30 border-t border-gray-50"><button onclick="addCommercialRow()" class="w-full py-4 bg-white border border-gray-100 hover:border-blue-100 hover:bg-blue-50 text-[10px] font-black text-c3c-blue uppercase tracking-[0.2em] rounded-2xl transition-all flex items-center justify-center gap-2 active:scale-[0.99] shadow-sm"><i data-lucide="plus" class="w-4 h-4"></i> Adicionar Item Comercial</button></div>
                    </div>
                </div>

                <!-- 3. PREVISÃO ALOCAÇÃO -->
                <div id="view-execution" class="hidden fade-in space-y-8 text-left">
                    <div class="bg-indigo-600 rounded-3xl p-8 text-white shadow-xl shadow-indigo-100 flex justify-between items-center overflow-hidden relative">
                        <div class="relative z-10">
                            <h4 class="text-lg font-black uppercase tracking-tighter">Planejamento de Alocação</h4>
                            <p class="text-indigo-100 text-[10px] font-bold uppercase tracking-widest mt-1">Defina quais consultores realizarão os itens vendidos e o custo hora real.</p>
                        </div>
                        <i data-lucide="user-check" class="w-32 h-32 absolute -right-4 -bottom-4 opacity-10"></i>
                    </div>

                    <div class="bg-white rounded-[32px] border border-gray-100 shadow-xl overflow-hidden">
                        <table class="w-full text-left table-dense">
                            <thead class="bg-gray-50/80 border-b border-gray-100">
                                <tr>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest py-5 px-6">Vínculo Baseline</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Consultor</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Taxa (P)</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Custo (R)</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Início</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Fim</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">%</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Hrs</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right bg-indigo-50/50">Receita Prev.</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">Custo Prev.</th>
                                    <th class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-center px-6">Ação</th>
                                </tr>
