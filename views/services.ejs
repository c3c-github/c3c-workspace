                        <div class="space-y-6">
                            <h4 class="text-xs font-black text-gray-800 uppercase tracking-[0.3em] flex items-center gap-2"><i data-lucide="pie-chart" class="w-4 h-4 text-indigo-500"></i> Saúde Financeira</h4>
                            <div class="bg-white p-8 rounded-[32px] border border-gray-100 shadow-xl space-y-8">
                                <div class="space-y-2">
                                    <div class="flex justify-between items-end"><span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Burn Rate Alocação</span><span class="text-xs font-black text-indigo-600" id="burn-rate-pct">0%</span></div>
                                    <div class="w-full h-3 bg-gray-50 rounded-full overflow-hidden border border-gray-100"><div class="h-full bg-indigo-500 transition-all duration-1000" style="width: 0%" id="burn-rate-bar"></div></div>
                                </div>
                                <div class="space-y-2">
                                    <div class="flex justify-between items-end"><span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Aderência ao Baseline</span><span class="text-xs font-black text-teal-600" id="baseline-pct">0%</span></div>
                                    <div class="w-full h-3 bg-gray-50 rounded-full overflow-hidden border border-gray-100"><div class="h-full bg-teal-500 transition-all duration-1000" style="width: 0%" id="baseline-bar"></div></div>
