<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aprovações - C3C Workplace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { 
                        c3c: { 
                            blue: '#2978FF', 
                            teal: '#1DDDBD', 
                            gray: '#F2F2F2',
                            dark: '#000000'
                        } 
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #F8FAFC; }
        .bg-c3c-gradient { background: transparent linear-gradient(118deg, #1DDDBD 0%, #1ED9C0 45%, #2978FF 100%) 0% 0% no-repeat padding-box; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
    </style>
</head>
<body class="h-screen flex overflow-hidden bg-[#F8FAFC]">

    <%- include('partials/sidebar', { page: 'approvals' }) %>

    <main class="flex-1 flex flex-col md:ml-64 relative w-full transition-all duration-300 overflow-hidden">
        
        <!-- HEADER -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-4 md:px-8 sticky top-0 z-20 shrink-0">
            <div class="flex items-center gap-4 text-left">
                <button onclick="document.getElementById('sidebar').classList.toggle('-translate-x-full')" class="md:hidden p-2 text-gray-600 hover:bg-gray-100 rounded-lg">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <div>
                    <h1 class="text-lg md:text-xl font-bold text-gray-800 flex items-center gap-2 tracking-tight">Aprovação de Horas <span class="text-c3c-blue">✅</span></h1>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest hidden sm:block">Valide os apontamentos da sua equipe</p>
                </div>
            </div>
            
            <div class="flex items-center bg-gray-50 border border-gray-200 rounded-xl px-2 py-1 gap-2 shadow-sm focus-within:ring-2 focus-within:ring-c3c-blue transition-all">
                <button onclick="changePeriod(1)" class="p-2 hover:bg-white rounded-lg text-gray-400 hover:text-c3c-blue transition-colors"><i data-lucide="chevron-left" class="w-4 h-4"></i></button>
                <div class="flex flex-col items-center px-2 min-w-[140px]">
                    <span id="period-display" class="text-xs font-black text-gray-700 tracking-tighter">Carregando...</span>
                </div>
                <button onclick="changePeriod(-1)" class="p-2 hover:bg-white rounded-lg text-gray-400 hover:text-c3c-blue transition-colors"><i data-lucide="chevron-right" class="w-4 h-4"></i></button>
            </div>
        </header>

        <!-- CONTEÚDO -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 fade-in custom-scrollbar text-left">
            
            <div class="mb-10 flex justify-between items-end">
                <div>
                    <h2 class="text-2xl font-black text-gray-800 tracking-tighter uppercase leading-tight">Projetos Pendentes</h2>
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mt-1">Analise os apontamentos consolidados por serviço</p>
                </div>
                <button onclick="updatePeriodDisplay()" class="p-3 bg-white border border-gray-100 rounded-2xl text-c3c-blue hover:shadow-md transition-all active:scale-95 shadow-sm"><i data-lucide="refresh-cw" class="w-5 h-5"></i></button>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8" id="approval-cards-container">
                <!-- Cards injetados via JS -->
            </div>
        </div>
    </main>

    <!-- MODAL DETALHES PROJETO -->
    <div id="modal-approval" class="fixed inset-0 bg-black/60 backdrop-blur-md z-[60] hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-[40px] shadow-2xl w-full max-w-7xl overflow-hidden transform scale-95 transition-all flex flex-col max-h-[90vh]">
            
            <header class="p-8 border-b border-gray-100 flex justify-between items-center bg-gray-50/50 shrink-0">
                <div class="text-left">
                    <h3 id="modal-title" class="text-2xl font-black text-gray-800 tracking-tighter uppercase leading-tight">...</h3>
                    <p class="text-[10px] font-black text-c3c-blue uppercase tracking-[0.2em] mt-1">Extrato consolidado por recurso</p>
                </div>
                <button onclick="closeModal()" class="p-3 text-gray-400 hover:bg-white hover:text-red-500 rounded-full shadow-sm transition-all"><i data-lucide="x"></i></button>
            </header>

            <!-- DASHBOARD MODAL -->
            <div class="px-8 py-6 bg-white border-b border-gray-100 flex flex-wrap gap-8 items-center shrink-0">
                <div class="flex flex-col text-left"><span class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Previsto Total</span><span id="sum-prev" class="text-lg font-black text-gray-800">--h</span></div>
                <div class="flex flex-col text-left"><span class="text-[9px] font-black text-c3c-blue uppercase tracking-widest mb-1">Realizado Total</span><span id="sum-real" class="text-lg font-black text-c3c-blue">--h</span></div>
                <div class="flex flex-col text-left"><span class="text-[9px] font-black text-orange-500 uppercase tracking-widest mb-1">Extras Total (x2)</span><span id="sum-ext" class="text-lg font-black text-orange-500">--h</span></div>
                <div class="flex-1 min-w-[200px] flex flex-col">
                    <div class="flex justify-between items-center mb-2"><span class="text-[9px] font-black text-gray-400 uppercase tracking-widest">Conformidade Total</span><span id="sum-conf" class="text-xs font-black text-teal-600">--%</span></div>
                    <div class="h-2 bg-gray-100 rounded-full overflow-hidden shadow-inner"><div id="sum-bar" class="h-full bg-teal-500 transition-all duration-700" style="width: 0%"></div></div>
                </div>
            </div>

            <!-- TABELA RECURSOS -->
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                <table class="w-full text-left">
                    <thead class="bg-gray-50/50 border-b border-gray-100 sticky top-0 z-10">
                        <tr class="text-[10px] font-black text-gray-400 uppercase tracking-widest">
                            <th class="px-8 py-4">Recurso</th>
                            <th class="px-4 py-4 text-right">Previsto</th>
                            <th class="px-4 py-4 text-center">Normais</th>
                            <th class="px-4 py-4 text-center">Extra(Pg)</th>
                            <th class="px-4 py-4 text-center">Extra(Bc)</th>
                            <th class="px-4 py-4 text-center">Aus(Bc)</th>
                            <th class="px-4 py-4 text-center">Aus(Out)</th>
                            <th class="px-4 py-4 text-right">Realizado</th>
                            <th class="px-4 py-4 text-center">Conf.</th>
                            <th class="px-8 py-4 text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="modal-table-body" class="divide-y divide-gray-50"></tbody>
                    <tfoot id="modal-table-footer"></tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- MODAL EXTRATO DETALHADO -->
    <div id="modal-activities" class="fixed inset-0 bg-black/70 backdrop-blur-md z-[70] hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-[40px] shadow-2xl w-full max-w-5xl overflow-hidden transform scale-95 transition-all flex flex-col max-h-[85vh]">
            <header class="p-8 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <div class="text-left">
                    <h3 class="text-xl font-black text-gray-800 tracking-tighter uppercase leading-tight">Extrato do Recurso</h3>
                    <p class="text-[10px] font-black text-c3c-blue uppercase tracking-widest mt-1">Análise individual dos lançamentos</p>
                </div>
                <button onclick="closeActivityModal()" class="p-3 text-gray-400 hover:bg-white hover:text-red-500 rounded-full shadow-sm transition-all"><i data-lucide="x"></i></button>
            </header>

            <!-- MASS ACTIONS -->
            <div class="px-8 py-4 bg-white border-b border-gray-100 flex items-center justify-between gap-4">
                <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox" id="check-all-entries" onchange="toggleAllEntries(this)" class="w-5 h-5 rounded-lg border-2 border-gray-200 text-c3c-blue focus:ring-blue-100 transition-all">
                    <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest group-hover:text-gray-600">Selecionar Todos</span>
                </label>
                <div class="flex gap-3">
                    <button id="btn-mass-reject" onclick="openMassRejectModal()" class="hidden px-6 py-2.5 bg-red-50 text-red-600 rounded-xl text-[10px] font-black uppercase tracking-widest border border-red-100 hover:bg-red-100 transition-all">Reprovar Seleção</button>
                    <button id="btn-mass-approve" onclick="confirmMassApprove()" class="hidden px-6 py-2.5 bg-teal-50 text-teal-600 rounded-xl text-[10px] font-black uppercase tracking-widest border border-teal-100 hover:bg-teal-100 transition-all">Aprovar Seleção</button>
                </div>
            </div>

            <div class="flex-1 overflow-y-auto custom-scrollbar">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 sticky top-0 z-10 border-b border-gray-100">
                        <tr class="text-[9px] font-black text-gray-400 uppercase tracking-widest">
                            <th class="px-8 py-4 text-center">#</th>
                            <th class="px-4 py-4">Data</th>
                            <th class="px-4 py-4">Atividade / Justificativa</th>
                            <th class="px-4 py-4 text-right">Norm</th>
                            <th class="px-4 py-4 text-right">Ext(Pg)</th>
                            <th class="px-4 py-4 text-right">Ext(Bc)</th>
                            <th class="px-4 py-4 text-right">Aus(Bc)</th>
                            <th class="px-8 py-4 text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody id="activity-table-body" class="divide-y divide-gray-50"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- MODAL REJEIÇÃO -->
    <div id="modal-reject" class="fixed inset-0 bg-black/80 backdrop-blur-md z-[80] hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-[40px] shadow-2xl w-full max-w-md p-8 text-center animate-[fadeIn_0.2s_ease-out]">
            <div class="w-20 h-20 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-6 text-red-500"><i data-lucide="alert-triangle" class="w-10 h-10"></i></div>
            <h3 class="text-2xl font-black text-gray-800 tracking-tighter uppercase mb-2 leading-tight">Reprovar Lançamentos</h3>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-8">Informe o motivo para <span id="reject-person-name" class="text-red-500">...</span></p>
            
            <input type="hidden" id="reject-service-id">
            <input type="hidden" id="reject-person-id">
            
            <textarea id="reject-reason" rows="4" class="w-full bg-gray-50 border-2 border-gray-100 rounded-3xl p-5 text-sm font-medium focus:ring-4 focus:ring-red-50 outline-none mb-8 resize-none placeholder:text-gray-300" placeholder="Ex: Justificativa insuficiente, projeto incorreto..."></textarea>
            
            <div class="flex gap-4">
                <button onclick="document.getElementById('modal-reject').classList.add('hidden')" class="flex-1 py-4 text-gray-400 font-black uppercase text-[10px] tracking-widest hover:text-gray-600">Cancelar</button>
                <button onclick="confirmReject()" class="flex-[2] py-4 bg-red-600 text-white font-black uppercase text-xs tracking-widest rounded-2xl shadow-xl shadow-red-100 hover:bg-red-700 active:scale-95 transition-all">Confirmar Reprovação</button>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
        const API_URL = '/api';
        let availablePeriods = [], currentPeriodIndex = 0, currentProjectItem = null;

        document.addEventListener('DOMContentLoaded', loadPeriods);
        
        async function loadPeriods() {
            try {
                const res = await fetch(`${API_URL}/periods?type=manager`);
                if(res.status === 401) window.location.href = '/';
                const periods = await res.json();
                if(periods.length === 0) { document.getElementById('period-display').innerText = "Sem períodos"; return; }
                availablePeriods = periods; 
                // Seleção Inteligente: Período não finalizado mais antigo
                const nonFinalized = periods.filter(p => p.Status__c !== 'Finalizado/Pago');
                let suggestedId = nonFinalized.length > 0 ? nonFinalized[nonFinalized.length - 1].Id : periods[0].Id;
                currentPeriodIndex = periods.findIndex(p => p.Id === suggestedId);
                updatePeriodDisplay();
            } catch (err) { console.error(err); }
        }

        function updatePeriodDisplay() {
            if(!availablePeriods[currentPeriodIndex]) return;
            const p = availablePeriods[currentPeriodIndex];
            document.getElementById('period-display').innerText = p.Name;
            loadProjects(p.DataInicio__c, p.DataFim__c);
        }

        function changePeriod(dir) {
            const next = currentPeriodIndex + dir;
            if(next >= 0 && next < availablePeriods.length) { currentPeriodIndex = next; updatePeriodDisplay(); }
        }

        async function loadProjects(start, end) {
            const container = document.getElementById('approval-cards-container');
            container.innerHTML = '<div class="col-span-full py-20 text-center"><div class="w-12 h-12 border-4 border-blue-100 border-t-c3c-blue rounded-full animate-spin mx-auto mb-4"></div><p class="text-[10px] font-black text-gray-300 uppercase tracking-widest">Carregando projetos...</p></div>';
            try {
                const res = await fetch(`${API_URL}/approvals/projects?inicio=${start}&fim=${end}`);
                const projects = await res.json();
                container.innerHTML = '';
                if(projects.length === 0) { container.innerHTML = '<div class="col-span-full py-20 text-center border-2 border-dashed border-gray-100 rounded-[40px]"><p class="text-[10px] font-black text-gray-300 uppercase tracking-widest">Nenhum projeto encontrado</p></div>'; return; }
                projects.forEach(item => {
                    const isOpen = item.statusUI === 'Aberto';
                    let confColor = 'text-teal-600', barColor = 'bg-teal-500';
                    if(item.percentual > 105) { confColor = 'text-red-500'; barColor = 'bg-red-500'; }
                    else if(item.percentual < 95) { confColor = 'text-orange-500'; barColor = 'bg-orange-500'; }
                    const badge = isOpen ? '<span class="bg-orange-50 text-orange-600 text-[9px] font-black px-3 py-1 rounded-full border border-orange-100 uppercase tracking-widest">Pendente</span>' : '<span class="bg-teal-50 text-teal-600 text-[9px] font-black px-3 py-1 rounded-full border border-teal-100 uppercase tracking-widest">Aprovado</span>';
                    container.innerHTML += `
                    <div class="bg-white rounded-[40px] shadow-sm border border-gray-100 p-8 flex flex-col h-full hover:shadow-xl hover:shadow-blue-50 transition-all duration-300 group">
                        <div class="flex justify-between items-start mb-6">
                            <div class="text-left"><span class="text-[9px] font-black text-gray-300 uppercase tracking-widest block mb-1 truncate w-40" title="${item.client}">${item.client}</span><h3 class="text-xl font-black text-gray-800 tracking-tighter leading-tight truncate w-64 group-hover:text-c3c-blue transition-colors" title="${item.serviceName}">${item.serviceName}</h3></div>
                            ${badge}
                        </div>
                        <div class="grid grid-cols-4 gap-4 mb-8 bg-gray-50/50 rounded-3xl p-5 border border-gray-50">
                            <div class="text-left"><p class="text-[8px] text-gray-400 font-black uppercase tracking-widest mb-1">Previsto</p><p class="text-sm font-black text-gray-800">${item.metrics.alocado.toFixed(0)}h</p></div>
                            <div class="text-left border-l border-gray-200 pl-4"><p class="text-[8px] text-c3c-blue font-black uppercase tracking-widest mb-1">Realizado</p><p class="text-sm font-black text-c3c-blue">${item.metrics.ponderado.toFixed(0)}h</p></div>
                            <div class="text-left border-l border-gray-200 pl-4"><p class="text-[8px] text-orange-500 font-black uppercase tracking-widest mb-1">Extra(x2)</p><p class="text-sm font-black ${item.metrics.extra > 0 ? 'text-orange-500' : 'text-gray-300'}">${item.metrics.extra.toFixed(0)}h</p></div>
                            <div class="text-left border-l border-gray-200 pl-4"><p class="text-[8px] text-gray-400 font-black uppercase tracking-widest mb-1">Conf.</p><p class="text-sm font-black ${confColor}">${item.percentual}%</p></div>
                        </div>
                        <div class="mt-auto flex items-center justify-between pt-6 border-t border-gray-50">
                            <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest flex items-center gap-2"><i data-lucide="users" class="w-3.5 h-3.5"></i> ${item.teamSize} Recursos</span>
                            <button onclick='openModal(${JSON.stringify(item)})' class="px-8 py-3 bg-white border-2 border-blue-50 text-c3c-blue font-black uppercase text-[10px] tracking-widest rounded-2xl hover:bg-blue-50 hover:border-blue-100 transition-all active:scale-95 shadow-sm">Analisar</button>
                        </div>
                    </div>`;
                });
                lucide.createIcons();
            } catch (err) { container.innerHTML = '<p class="text-red-500 col-span-full text-center">Erro ao carregar dados.</p>'; }
        }

        async function openModal(item) {
            currentProjectItem = item; const { serviceId, serviceName, metrics, percentual } = item;
            const modal = document.getElementById('modal-approval'); const tbody = document.getElementById('modal-table-body');
            document.getElementById('modal-title').innerText = serviceName;
            document.getElementById('sum-prev').innerText = metrics.alocado.toFixed(0) + 'h';
            document.getElementById('sum-real').innerText = metrics.ponderado.toFixed(0) + 'h';
            document.getElementById('sum-ext').innerText = metrics.extra.toFixed(0) + 'h';
            document.getElementById('sum-conf').innerText = percentual + '%';
            document.getElementById('sum-bar').style.width = Math.min(percentual, 100) + '%';
            tbody.innerHTML = '<tr><td colspan="10" class="text-center py-20 text-gray-300 font-black uppercase text-[10px]"><i data-lucide="loader-2" class="w-6 h-6 animate-spin inline-block mb-2"></i><br>Carregando...</td></tr>';
            lucide.createIcons(); modal.classList.remove('hidden'); setTimeout(() => modal.querySelector('div').classList.remove('scale-95'), 10);
            const p = availablePeriods[currentPeriodIndex];
            try {
                const url = `${API_URL}/approvals/${serviceId}/resources?inicio=${p.DataInicio__c}&fim=${p.DataFim__c}`;
                const res = await fetch(url); const resources = await res.json();
                tbody.innerHTML = '';
                if (resources.length === 0) { tbody.innerHTML = '<tr><td colspan="10" class="text-center py-10 text-gray-400 font-bold uppercase text-[10px]">Sem dados</td></tr>'; return; }
                let tAloc=0, tNorm=0, tExPg=0, tExBc=0, tAuBc=0, tAuOu=0, tReal=0;
                resources.forEach(r => {
                    tAloc += r.alocado; tNorm += r.horasNormais; tExPg += r.horasExtrasPgto; tExBc += r.horasExtrasBanco; tAuBc += r.horasAusenciaBanco; tAuOu += r.horasAusenciaOutras; tReal += r.totalRealizado;
                    const val = (v, cls) => v > 0 ? `<span class="font-black ${cls}">${v.toFixed(1)}</span>` : '<span class="text-gray-300">-</span>';
                    let actions = '';
                    if(r.periodStatus === 'Em aprovação do serviço' && r.countPending > 0) {
                        actions = `<div class="flex justify-center gap-2 items-center"><button onclick="openActivityModal('${serviceId}', '${r.id}')" class="p-2 text-gray-400 hover:text-c3c-blue rounded-xl hover:bg-blue-50 transition-all"><i data-lucide="list-collapse" class="w-4 h-4"></i></button><button onclick="openRejectModal('${serviceId}', '${r.id}', '${r.name}')" class="p-2 text-red-400 hover:text-red-600 rounded-xl hover:bg-red-50 transition-all"><i data-lucide="x" class="w-4 h-4"></i></button><button onclick="approveAction('${serviceId}', '${r.id}', 'approve')" class="p-2 text-teal-500 hover:text-teal-700 rounded-xl hover:bg-teal-50 transition-all"><i data-lucide="check" class="w-4 h-4"></i></button></div>`;
                    } else {
                        let label = r.periodStatus || 'Aberto', bCls = 'text-gray-400 border-gray-100 bg-gray-50';
                        if (r.periodStatus === 'Aberto') { label = 'Rascunho'; bCls = 'text-blue-500 border-blue-50 bg-blue-50/50'; }
                        else if (r.countPending === 0) { label = 'Aprovado'; bCls = 'text-teal-600 border-teal-50 bg-teal-50/50'; }
                        actions = `<div class="flex justify-center items-center gap-2"><button onclick="openActivityModal('${serviceId}', '${r.id}')" class="text-gray-300 hover:text-c3c-blue p-2"><i data-lucide="eye" class="w-4 h-4"></i></button><span class="text-[8px] font-black uppercase px-2 py-0.5 rounded-full border ${bCls} tracking-widest">${label}</span></div>`;
                    }
                    let confClass = 'text-teal-600 font-bold';
                    if (r.percentual > 105) confClass = 'text-red-500 font-black';
                    else if (r.percentual < 95) confClass = 'text-orange-500 font-black';
                    tbody.innerHTML += `<tr class="hover:bg-gray-50/50 transition-colors border-b border-gray-50 last:border-0"><td class="py-4 px-8"><p class="text-xs font-black text-gray-800 uppercase tracking-tighter">${r.name}</p>${r.noContract ? '<span class="text-[8px] font-black text-red-500 uppercase tracking-widest">Sem Alocação</span>' : ''}</td><td class="py-4 text-right font-black text-gray-400 text-xs">${r.alocado.toFixed(0)}h</td><td class="py-4 text-center border-l border-gray-50">${val(r.horasNormais, 'text-gray-700')}</td><td class="py-4 text-center border-l border-gray-50">${val(r.horasExtrasPgto, 'text-orange-500')}</td><td class="py-4 text-center border-l border-gray-50">${val(r.horasExtrasBanco, 'text-purple-500')}</td><td class="py-4 text-center border-l border-gray-50">${val(r.horasAusenciaBanco, 'text-gray-500')}</td><td class="py-4 text-center border-l border-gray-50">${val(r.horasAusenciaOutras, 'text-red-400')}</td><td class="py-4 text-right font-black text-gray-800 border-l border-gray-50 pr-4 bg-gray-50/30">${r.totalRealizado.toFixed(1)}h</td><td class="py-4 text-center text-xs border-l border-gray-50 ${confClass}">${r.percentual}%</td><td class="py-4 text-center px-8">${actions}</td></tr>`;
                });
                const realServiceAloc = metrics.alocado;
                const tConf = realServiceAloc > 0 ? Math.round((tReal / realServiceAloc) * 100) : (tReal > 0 ? 100 : 0);
                document.getElementById('modal-table-footer').innerHTML = `<tr class="bg-gray-50 border-t-2 border-gray-100"><td class="py-6 px-8 text-gray-400 font-black uppercase text-[10px] tracking-widest">Consolidado</td><td class="py-6 text-right font-black text-gray-800 text-sm">${realServiceAloc.toFixed(0)}h</td><td class="py-6 text-center border-l border-white text-gray-800 font-black">${tNorm.toFixed(1)}h</td><td class="py-6 text-center border-l border-white text-orange-600 font-black">${tExPg.toFixed(1)}h</td><td class="py-6 text-center border-l border-white text-purple-600 font-black">${tExBc.toFixed(1)}h</td><td class="py-6 text-center border-l border-white text-gray-600 font-black">${tAuBc.toFixed(1)}h</td><td class="py-6 text-center border-l border-white text-red-600 font-black">${tAuOu.toFixed(1)}h</td><td class="py-6 text-right font-black text-c3c-blue pr-4 border-l border-white bg-blue-50/30">${tReal.toFixed(1)}h</td><td class="py-6 text-center font-black text-gray-800">${tConf}%</td><td class="py-6 px-8">-</td></tr>`;
                lucide.createIcons();
            } catch(e) { console.error(e); }
        }

        async function openActivityModal(serviceId, personId) {
            currentModalServiceId = serviceId; currentModalPersonId = personId;
            const modal = document.getElementById('modal-activities'); const tbody = document.getElementById('activity-table-body');
            tbody.innerHTML = '<tr><td colspan="8" class="text-center py-20 text-gray-300 font-black uppercase text-[10px]"><i data-lucide="loader-2" class="w-6 h-6 animate-spin inline-block mb-2"></i><br>Carregando extrato...</td></tr>';
            lucide.createIcons(); modal.classList.remove('hidden'); document.getElementById('check-all-entries').checked = false; updateMassActionButtons();
            const p = availablePeriods[currentPeriodIndex];
            try {
                const res = await fetch(`${API_URL}/approvals/${serviceId}/resources/${personId}/activities?inicio=${p.DataInicio__c}&fim=${p.DataFim__c}`);
                const activities = await res.json();
                tbody.innerHTML = '';
                if(activities.length === 0) { tbody.innerHTML = '<tr><td colspan="8" class="text-center py-10 text-gray-400 font-bold uppercase text-[10px]">Nenhum registro encontrado</td></tr>'; return; }
                activities.forEach(a => {
                    const justificativa = a.justificativa ? `<br><span class="text-[9px] text-gray-400 font-medium tracking-tight italic">"${a.justificativa}"</span>` : '';
                    let stBadge = `<span class="text-[8px] font-black uppercase bg-gray-50 text-gray-400 px-2 py-0.5 rounded-full border border-gray-100">${a.status}</span>`, canSelect = false;
                    if (a.status === 'Em aprovação do serviço') { stBadge = `<span class="text-[8px] font-black uppercase bg-blue-50 text-c3c-blue px-2 py-0.5 rounded-full border border-blue-100">Pendente</span>`; canSelect = true; }
                    else if (a.status === 'Aprovado') stBadge = `<span class="text-[8px] font-black uppercase bg-teal-50 text-teal-600 px-2 py-0.5 rounded-full border border-teal-100">Aprovado</span>`;
                    const val = (v, cls) => v > 0 ? `<span class="font-black ${cls}">${v.toFixed(1)}h</span>` : '<span class="text-gray-200">-</span>';
                    tbody.innerHTML += `<tr class="hover:bg-gray-50/50 border-b border-gray-50 last:border-0"><td class="py-4 px-8 text-center">${canSelect ? `<input type="checkbox" class="entry-checkbox w-4 h-4 rounded border-gray-200 text-c3c-blue focus:ring-blue-100" value="${a.id}" onchange="updateMassActionButtons()">` : '<i data-lucide="lock" class="w-3 h-3 text-gray-200 mx-auto"></i>'}</td><td class="py-4 px-4 text-[10px] font-black text-gray-400 uppercase tracking-tighter">${formatSafeDate(a.data)}</td><td class="py-4 px-4"><p class="text-xs font-bold text-gray-800 tracking-tight leading-tight">${a.atividade}</p>${justificativa}</td><td class="py-4 px-4 text-right border-l border-gray-50/50">${val(a.normal, 'text-gray-700')}</td><td class="py-4 px-4 text-right border-l border-gray-50/50">${val(a.extraPgto, 'text-orange-500')}</td><td class="py-4 px-4 text-right border-l border-gray-50/50">${val(a.extraBanco, 'text-purple-500')}</td><td class="py-4 px-4 text-right border-l border-gray-50/50">${val(a.ausenciaBanco, 'text-gray-500')}</td><td class="py-4 px-8 text-center border-l border-gray-50/50">${stBadge}</td></tr>`;
                });
                lucide.createIcons();
            } catch (err) { console.error(err); }
        }

        function toggleAllEntries(master) { document.querySelectorAll('.entry-checkbox').forEach(c => c.checked = master.checked); updateMassActionButtons(); }
        function updateMassActionButtons() {
            const count = document.querySelectorAll('.entry-checkbox:checked').length;
            const bA = document.getElementById('btn-mass-approve'), bR = document.getElementById('btn-mass-reject');
            bA.classList.toggle('hidden', count === 0); bR.classList.toggle('hidden', count === 0);
            if(count > 0) { bA.innerText = `Aprovar (${count})`; bR.innerText = `Reprovar (${count})`; }
        }

        async function confirmMassApprove() {
            const ids = Array.from(document.querySelectorAll('.entry-checkbox:checked')).map(cb => cb.value);
            if(!confirm(`Confirma aprovação de ${ids.length} itens?`)) return;
            const p = availablePeriods[currentPeriodIndex];
            try {
                const res = await fetch(`${API_URL}/approvals/action`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ entryIds: ids, action: 'approve', inicio: p.DataInicio__c, fim: p.DataFim__c }) });
                if ((await res.json()).success) { await openActivityModal(currentModalServiceId, currentModalPersonId); await openModal(currentProjectItem); loadProjects(p.DataInicio__c, p.DataFim__c); }
            } catch (e) { alert('Erro na aprovação.'); }
        }

        function openRejectModal(sId, pId, name) {
            document.getElementById('reject-service-id').value = sId; document.getElementById('reject-person-id').value = pId;
            document.getElementById('reject-person-name').innerText = name; document.getElementById('reject-reason').value = '';
            document.getElementById('modal-reject').classList.remove('hidden');
        }

        function openMassRejectModal() {
            const count = document.querySelectorAll('.entry-checkbox:checked').length;
            document.getElementById('reject-person-name').innerText = `${count} lançamentos`;
            document.getElementById('reject-service-id').value = 'MASS'; document.getElementById('reject-person-id').value = 'MASS';
            document.getElementById('reject-reason').value = ''; document.getElementById('modal-reject').classList.remove('hidden');
        }

        async function confirmReject() {
            const isMass = document.getElementById('reject-service-id').value === 'MASS'; const reason = document.getElementById('reject-reason').value.trim();
            if(!reason) { alert("Informe o motivo."); return; }
            const p = availablePeriods[currentPeriodIndex];
            const payload = { action: 'reject', motivo: reason, inicio: p.DataInicio__c, fim: p.DataFim__c };
            if (isMass) payload.entryIds = Array.from(document.querySelectorAll('.entry-checkbox:checked')).map(cb => cb.value);
            else { payload.serviceId = document.getElementById('reject-service-id').value; payload.personId = document.getElementById('reject-person-id').value; }
            try {
                const res = await fetch(`${API_URL}/approvals/action`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                if ((await res.json()).success) { document.getElementById('modal-reject').classList.add('hidden'); if (currentModalServiceId && currentModalPersonId && !isMass) await openActivityModal(currentModalServiceId, currentModalPersonId); await openModal(currentProjectItem); loadProjects(p.DataInicio__c, p.DataFim__c); }
            } catch (e) { alert('Erro técnico.'); }
        }

        async function approveAction(sId, pId, action) {
            if(!confirm('Aprovar todos os itens pendentes deste recurso?')) return;
            const p = availablePeriods[currentPeriodIndex];
            try {
                const res = await fetch(`${API_URL}/approvals/action`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ serviceId: sId, personId: pId, action, inicio: p.DataInicio__c, fim: p.DataFim__c }) });
                if ((await res.json()).success) { openModal(currentProjectItem); loadProjects(p.DataInicio__c, p.DataFim__c); }
            } catch (err) { alert('Erro técnico.'); }
        }

        function formatSafeDate(d) { if (!d) return '-'; const p = d.split('-'); return p.length === 3 ? `${p[2]}/${p[1]}/${p[0]}` : d; }
        function closeModal() { document.getElementById('modal-approval').querySelector('div').classList.add('scale-95'); setTimeout(() => document.getElementById('modal-approval').classList.add('hidden'), 200); }
        function closeActivityModal() { document.getElementById('modal-activities').classList.add('hidden'); }
    </script>
</body>
</html>
