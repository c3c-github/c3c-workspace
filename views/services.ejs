        async function removeLinkedSale(saleSfId, caId) {
            if(!confirm("Deseja desvincular esta venda? Todas as parcelas vinculadas a ela também serão removidas.")) return;
            
            // Se a venda tem um ID do Salesforce válido, precisamos excluir via API (que valida o forecast)
            if (saleSfId && saleSfId !== 'undefined' && !saleSfId.startsWith('new')) {
                document.getElementById('modal-loader').classList.remove('hidden');
                try {
                    const res = await fetch(`/api/services/sales/${saleSfId}/${currentServiceData.id}`, { method: 'DELETE' });
                    const data = await res.json();
                    
                    if (data.success) {
                        showToast('Venda e parcelas desvinculadas com sucesso!');
                        // Recarrega o modal para atualizar a lista de parcelas e vendas
                        openServiceModal(currentServiceData.id);
                    } else {
                        throw new Error(data.error || 'Falha ao desvincular');
                    }
                } catch(e) {
                    showToast(e.message, 'error');
                    document.getElementById('modal-loader').classList.add('hidden');
                }
            } else {
                // Caso seja uma venda que acabou de ser vinculada ou o ID não carregou corretamente
                linkedSales = linkedSales.filter(s => (s.id_ca || s.id) !== caId);
                
                // Também remove as parcelas locais vinculadas a essa venda do ERP
                const billingList = document.getElementById('svc-billing-list');
                Array.from(document.querySelectorAll(`.billing-row[data-origin-sale-id="${caId}"]`)).forEach(tr => tr.remove());
                
                renderLinkedSales();
                calculateBillingTotals();
                showToast('Vínculo removido localmente.');
            }
        }

